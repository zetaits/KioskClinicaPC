# Estado runtime del servidor: config sembrada (data/) y assets subidos por el panel (assets/).
# No es código; se genera al ejecutar y no debe versionarse.
src/Kiosk.Server/data/
src/Kiosk.Server/assets/

# Visual Studio / Rider files
.vs/
.idea/
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio cache/options
.vs/
# Rider cache/options
.idea/

# ReSharper
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user

# NuGet Packages
*.nupkg
# NuGet Symbol Packages
*.snupkg
# The packages folder can be ignored because of Package Restore
**/[Pp]ackages/*
# except build/, which is used as an MSBuild target.
!**/[Pp]ackages/build/

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Artefactos del instalador (dotnet publish + Inno Setup)
publish/
installer/Output/

# Local agent notes
CLAUDE.md

# Claude Code / Ruflo / agent tooling (no forma parte del código del proyecto)
.claude/
.claude-flow/
.swarm/
.hive-mind/
.ruflo/
.roo/
.mcp.json
ruvector.db
*.ruv
memory/

# Artefactos accidentales de shell (redirecciones rotas: "0", "{})", ",", "1",
# "_isDetected"...). gitignore no distingue "fichero sin extensión" de directorio,
# así que el filtro genérico vive en el hook .githooks/pre-commit (core.hooksPath),
# que bloquea cualquier basura sin extensión en la raíz al hacer commit.
