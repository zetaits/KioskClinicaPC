<Application x:Class="KioskClinicaPC.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <ResourceDictionary>
            <!-- ═══ COLOR PALETTE ═══ -->
            <Color x:Key="Bg0Color">#04020a</Color>
            <Color x:Key="Bg1Color">#0a0716</Color>
            <Color x:Key="Bg2Color">#140b24</Color>
            <Color x:Key="Bg3Color">#1c1135</Color>
            
            <!-- oklch(0.72 0.20 35) → warm red-orange -->
            <Color x:Key="CyanColor">#F37A4A</Color>
            <!-- oklch(0.55 0.20 28) → deep red-orange -->
            <Color x:Key="Cyan2Color">#B8431F</Color>
            <!-- oklch(0.80 0.18 65) → amber-orange -->
            <Color x:Key="MagentaColor">#FFB069</Color>
            <!-- oklch(0.62 0.20 50) → darker amber -->
            <Color x:Key="Magenta2Color">#D87639</Color>
            <!-- oklch(0.88 0.17 100) → warm gold -->
            <Color x:Key="OkColor">#F0D26B</Color>
            <!-- oklch(0.78 0.20 70) → amber highlight -->
            <Color x:Key="AmberColor">#FFA75C</Color>
            
            <Color x:Key="Text0Color">#ffffff</Color>
            <Color x:Key="Text1Color">#d6d2e8</Color>
            <Color x:Key="Text2Color">#a59ec2</Color>
            <Color x:Key="Text3Color">#6f6890</Color>
            
            <Color x:Key="Line1Color">#14FFFFFF</Color>
            <Color x:Key="Line2Color">#29FFFFFF</Color>

            <SolidColorBrush x:Key="Bg0Brush" Color="{StaticResource Bg0Color}" />
            <SolidColorBrush x:Key="Bg1Brush" Color="{StaticResource Bg1Color}" />
            <SolidColorBrush x:Key="Bg2Brush" Color="{StaticResource Bg2Color}" />
            <SolidColorBrush x:Key="Bg3Brush" Color="{StaticResource Bg3Color}" />
            <SolidColorBrush x:Key="CyanBrush" Color="{StaticResource CyanColor}" />
            <SolidColorBrush x:Key="Cyan2Brush" Color="{StaticResource Cyan2Color}" />
            <SolidColorBrush x:Key="MagentaBrush" Color="{StaticResource MagentaColor}" />
            <SolidColorBrush x:Key="Magenta2Brush" Color="{StaticResource Magenta2Color}" />
            <SolidColorBrush x:Key="OkBrush" Color="{StaticResource OkColor}" />
            <SolidColorBrush x:Key="AmberBrush" Color="{StaticResource AmberColor}" />
            <SolidColorBrush x:Key="Text0Brush" Color="{StaticResource Text0Color}" />
            <SolidColorBrush x:Key="Text1Brush" Color="{StaticResource Text1Color}" />
            <SolidColorBrush x:Key="Text2Brush" Color="{StaticResource Text2Color}" />
            <SolidColorBrush x:Key="Text3Brush" Color="{StaticResource Text3Color}" />
            <SolidColorBrush x:Key="Line1Brush" Color="{StaticResource Line1Color}" />
            <SolidColorBrush x:Key="Line2Brush" Color="{StaticResource Line2Color}" />

            <!-- ═══ FONT FAMILY ═══ -->
            <FontFamily x:Key="SpaceGrotesk">pack://application:,,,/KioskClinicaPC;component/Fonts/#Space Grotesk</FontFamily>
            <FontFamily x:Key="ChakraPetch">pack://application:,,,/KioskClinicaPC;component/Fonts/#Chakra Petch</FontFamily>
            <FontFamily x:Key="JetBrainsMono">pack://application:,,,/KioskClinicaPC;component/Fonts/#JetBrains Mono</FontFamily>

            <!-- ═══ GLASS CARD STYLE ═══ -->
            <Style x:Key="GlassCard" TargetType="Border">
                <Setter Property="Background" Value="{StaticResource Bg2Brush}" />
                <Setter Property="BorderBrush" Value="{StaticResource Line1Brush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="12" />
                <Setter Property="Padding" Value="20" />
            </Style>

            <!-- ═══ BUTTON STYLES ═══ -->
            <Style x:Key="PrimaryButton" TargetType="Button">
                <Setter Property="Background">
                    <Setter.Value>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="{StaticResource CyanColor}" Offset="0"/>
                            <GradientStop Color="{StaticResource MagentaColor}" Offset="1"/>
                        </LinearGradientBrush>
                    </Setter.Value>
                </Setter>
                <Setter Property="Foreground" Value="White" />
                <Setter Property="FontFamily" Value="{StaticResource SpaceGrotesk}" />
                <Setter Property="FontSize" Value="16" />
                <Setter Property="FontWeight" Value="Bold" />
                <Setter Property="Padding" Value="24,14" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="10"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="SecondaryButton" TargetType="Button">
                <Setter Property="Background" Value="#FF2A2A4A" />
                <Setter Property="Foreground" Value="White" />
                <Setter Property="FontFamily" Value="{StaticResource SpaceGrotesk}" />
                <Setter Property="FontSize" Value="14" />
                <Setter Property="Padding" Value="16,10" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="8"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="DangerButton" TargetType="Button">
                <Setter Property="Background" Value="#FFDA3030" />
                <Setter Property="Foreground" Value="White" />
                <Setter Property="FontFamily" Value="{StaticResource SpaceGrotesk}" />
                <Setter Property="FontSize" Value="14" />
                <Setter Property="Padding" Value="16,10" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="8"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ═══ TEXTBOX STYLE ═══ -->
            <Style x:Key="ConfigTextBox" TargetType="TextBox">
                <Setter Property="FontSize" Value="14" />
                <Setter Property="FontFamily" Value="{StaticResource JetBrainsMono}" />
                <Setter Property="Background" Value="{StaticResource Bg1Brush}" />
                <Setter Property="Foreground" Value="{StaticResource Text0Brush}" />
                <Setter Property="CaretBrush" Value="{StaticResource CyanBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource Line1Brush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Padding" Value="10,8" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TextBox">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8"
                                    Padding="{TemplateBinding Padding}">
                                <ScrollViewer x:Name="PART_ContentHost" />
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ═══ SECTION CARD ═══ -->
            <Style x:Key="SectionCard" TargetType="Border">
                <Setter Property="Background" Value="#FF0A0716" />
                <Setter Property="BorderBrush" Value="{StaticResource Line1Brush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="12" />
                <Setter Property="Padding" Value="22" />
                <Setter Property="Margin" Value="0,0,0,16" />
            </Style>

            <!-- ═══ DARK SCROLLBAR ═══ -->
            <Style x:Key="ScrollThumb" TargetType="Thumb">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Thumb">
                            <Border x:Name="ThumbBorder" CornerRadius="4" Background="#33FFFFFF" Margin="2,0" />
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="ThumbBorder" Property="Background" Value="#80F37A4A" />
                                </Trigger>
                                <Trigger Property="IsDragging" Value="True">
                                    <Setter TargetName="ThumbBorder" Property="Background" Value="#CCF37A4A" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="ScrollBarTransparentRepeat" TargetType="RepeatButton">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Focusable" Value="False" />
                <Setter Property="IsTabStop" Value="False" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="RepeatButton">
                            <Border Background="Transparent" />
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style TargetType="{x:Type ScrollBar}">
                <Setter Property="Width" Value="10" />
                <Setter Property="MinWidth" Value="10" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ScrollBar">
                            <Grid Background="Transparent">
                                <Track x:Name="PART_Track" IsDirectionReversed="True" Orientation="{TemplateBinding Orientation}">
                                    <Track.DecreaseRepeatButton>
                                        <RepeatButton Style="{StaticResource ScrollBarTransparentRepeat}" Command="ScrollBar.PageUpCommand" />
                                    </Track.DecreaseRepeatButton>
                                    <Track.Thumb>
                                        <Thumb Style="{StaticResource ScrollThumb}" MinHeight="36" />
                                    </Track.Thumb>
                                    <Track.IncreaseRepeatButton>
                                        <RepeatButton Style="{StaticResource ScrollBarTransparentRepeat}" Command="ScrollBar.PageDownCommand" />
                                    </Track.IncreaseRepeatButton>
                                </Track>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="Orientation" Value="Horizontal">
                        <Setter Property="Width" Value="Auto" />
                        <Setter Property="Height" Value="10" />
                        <Setter Property="MinWidth" Value="0" />
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- ═══ CHOICE CARD (RadioButton como tarjeta seleccionable / segmento) ═══
                 Content = título; Tag = subtítulo (p.ej. la garantía). Seleccionada: borde + tinte
                 de acento y punto relleno. Sustituye al RadioButton nativo (gris, sin pulir). -->
            <Style x:Key="ChoiceCard" TargetType="RadioButton">
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Foreground" Value="{StaticResource Text0Brush}"/>
                <Setter Property="FontFamily" Value="{StaticResource SpaceGrotesk}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="RadioButton">
                            <Border x:Name="bd" CornerRadius="10" BorderThickness="1.5"
                                    Background="{StaticResource Bg1Brush}" BorderBrush="{StaticResource Line1Brush}"
                                    Padding="16,13">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="{TemplateBinding Content}" FontSize="15" FontWeight="SemiBold"
                                                   Foreground="{StaticResource Text0Brush}"/>
                                        <TextBlock Text="{TemplateBinding Tag}" FontSize="11" Margin="0,3,0,0"
                                                   FontFamily="{StaticResource JetBrainsMono}" Foreground="{StaticResource Text2Brush}"/>
                                    </StackPanel>
                                    <Grid Grid.Column="1" Width="22" Height="22" VerticalAlignment="Center" Margin="12,0,0,0">
                                        <Ellipse x:Name="ring" Stroke="{StaticResource Line2Brush}" StrokeThickness="2" Fill="Transparent"/>
                                        <Ellipse x:Name="dot" Width="10" Height="10" Fill="{StaticResource CyanBrush}" Opacity="0"/>
                                    </Grid>
                                </Grid>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource Line2Brush}"/>
                                </Trigger>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource CyanBrush}"/>
                                    <Setter TargetName="bd" Property="Background" Value="#1FF37A4A"/>
                                    <Setter TargetName="ring" Property="Stroke" Value="{StaticResource CyanBrush}"/>
                                    <Setter TargetName="dot" Property="Opacity" Value="1"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ═══ TOGGLE SWITCH (CheckBox como interruptor moderno) ═══
                 Pista + pulgar que se desliza. On = acento. Reemplaza el CheckBox cuadrado nativo. -->
            <Style x:Key="ToggleSwitch" TargetType="CheckBox">
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Foreground" Value="{StaticResource Text1Brush}"/>
                <Setter Property="FontFamily" Value="{StaticResource SpaceGrotesk}"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="CheckBox">
                            <StackPanel Orientation="Horizontal" Background="Transparent">
                                <Border x:Name="track" Width="48" Height="28" CornerRadius="14"
                                        Background="{StaticResource Bg3Brush}" BorderBrush="{StaticResource Line2Brush}" BorderThickness="1">
                                    <Ellipse x:Name="thumb" Width="20" Height="20" HorizontalAlignment="Left" Margin="4,0,0,0"
                                             Fill="{StaticResource Text2Brush}"/>
                                </Border>
                                <ContentPresenter VerticalAlignment="Center" Margin="12,0,0,0"/>
                            </StackPanel>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="track" Property="BorderBrush" Value="{StaticResource Text2Brush}"/>
                                </Trigger>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="thumb" Property="HorizontalAlignment" Value="Right"/>
                                    <Setter TargetName="thumb" Property="Margin" Value="0,0,4,0"/>
                                    <Setter TargetName="thumb" Property="Fill" Value="White"/>
                                    <Setter TargetName="track" Property="Background" Value="{StaticResource CyanBrush}"/>
                                    <Setter TargetName="track" Property="BorderBrush" Value="{StaticResource CyanBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ═══ PASSWORDBOX STYLE ═══ -->
            <Style x:Key="ConfigPasswordBox" TargetType="PasswordBox">
                <Setter Property="FontSize" Value="16" />
                <Setter Property="FontFamily" Value="{StaticResource JetBrainsMono}" />
                <Setter Property="Background" Value="{StaticResource Bg1Brush}" />
                <Setter Property="Foreground" Value="{StaticResource Text0Brush}" />
                <Setter Property="CaretBrush" Value="{StaticResource CyanBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource Line1Brush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Padding" Value="10,8" />
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>
