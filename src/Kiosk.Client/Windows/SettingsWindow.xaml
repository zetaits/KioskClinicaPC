<Window x:Class="KioskClinicaPC.Windows.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Panel de Configuración"
        Height="900" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#FF04020A"
        Foreground="White"
        FontFamily="{StaticResource SpaceGrotesk}"
        Loaded="Window_Loaded"
        WindowStyle="None"
        ResizeMode="NoResize"
        BorderBrush="#FFF37A4A"
        BorderThickness="1">

    <Window.Resources>
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource ChakraPetch}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="SectionHint" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource JetBrainsMono}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#FF4D4767"/>
            <Setter Property="Margin" Value="0,4,0,16"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource JetBrainsMono}"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Foreground" Value="#FF8A82A8"/>
            <Setter Property="Margin" Value="2,0,0,6"/>
        </Style>
        <Style x:Key="Field" TargetType="StackPanel">
            <Setter Property="Margin" Value="0,0,0,14"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Height="64">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#FF0A0716" Offset="0"/>
                    <GradientStop Color="#FF140B24" Offset="1"/>
                </LinearGradientBrush>
            </Grid.Background>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="28,0,0,0">
                <Border Width="10" Height="10" CornerRadius="5" Background="#FFF37A4A" VerticalAlignment="Center" Margin="0,0,12,0">
                    <Border.Effect>
                        <DropShadowEffect Color="#FFF37A4A" BlurRadius="10" ShadowDepth="0" Opacity="0.8"/>
                    </Border.Effect>
                </Border>
                <TextBlock Text="PANEL DE CONFIGURACIÓN" FontFamily="{StaticResource ChakraPetch}"
                           FontWeight="Bold" FontSize="20" Foreground="White" VerticalAlignment="Center"/>
                <TextBlock Text="· CLINICAPC" FontFamily="{StaticResource JetBrainsMono}" FontSize="12"
                           Foreground="#FF8A82A8" VerticalAlignment="Center" Margin="12,2,0,0"/>
            </StackPanel>
            <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,20,0"
                    Width="36" Height="36" Foreground="#FF8A82A8" Background="Transparent" BorderThickness="0"
                    FontSize="16" Cursor="Hand" Click="CloseButton_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#1AFFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <Border Height="1" VerticalAlignment="Bottom" Background="{StaticResource Line1Brush}"/>
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="28,22,22,22">
            <StackPanel>

                <!-- Precios -->
                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitle}" Text="Precios"/>
                        <TextBlock Style="{StaticResource SectionHint}" Text="Precio de venta y precio rebajado mostrados en la ficha."/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="PRECIO PRINCIPAL"/>
                                <TextBox x:Name="PriceTextBox" Style="{StaticResource ConfigTextBox}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="PRECIO DESCUENTO"/>
                                <TextBox x:Name="DiscountedPriceTextBox" Style="{StaticResource ConfigTextBox}"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Estado y garantía -->
                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitle}" Text="Estado y garantía"/>
                        <TextBlock Style="{StaticResource SectionHint}" Text="El estado del equipo determina los años de garantía que se muestran en la ficha."/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <RadioButton x:Name="NewRadio" Grid.Column="0" Style="{StaticResource ChoiceCard}" GroupName="Condition"
                                         Content="Nuevo" Tag="3 años de garantía" Checked="ConditionRadio_Checked"/>
                            <RadioButton x:Name="UsedRadio" Grid.Column="2" Style="{StaticResource ChoiceCard}" GroupName="Condition"
                                         Content="De ocasión" Tag="1 año de garantía" Checked="ConditionRadio_Checked"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Pantalla Attract · textos rotativos (un set por estado del equipo) -->
                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <StackPanel.Resources>
                            <DataTemplate x:Key="AttractSlideTemplate">
                                <Border Background="#0AFFFFFF" BorderBrush="{StaticResource Line1Brush}" BorderThickness="1" Padding="14" Margin="0,0,0,12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Style="{StaticResource FieldLabel}" Text="ANTETÍTULO (pequeño, arriba)"/>
                                            <TextBox Style="{StaticResource ConfigTextBox}" Margin="0,0,0,8"
                                                     Text="{Binding Eyebrow, UpdateSourceTrigger=PropertyChanged}"/>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="12"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Style="{StaticResource FieldLabel}" Text="TITULAR 1"/>
                                                    <TextBox Style="{StaticResource ConfigTextBox}" Margin="0,0,0,8"
                                                             Text="{Binding Title1, UpdateSourceTrigger=PropertyChanged}"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Style="{StaticResource FieldLabel}" Text="TITULAR 2 (acento)"/>
                                                    <TextBox Style="{StaticResource ConfigTextBox}" Margin="0,0,0,8"
                                                             Text="{Binding Title2, UpdateSourceTrigger=PropertyChanged}"/>
                                                </StackPanel>
                                            </Grid>
                                            <TextBlock Style="{StaticResource FieldLabel}" Text="SUBTÍTULO"/>
                                            <TextBox Style="{StaticResource ConfigTextBox}"
                                                     Text="{Binding Subtitle, UpdateSourceTrigger=PropertyChanged}"/>
                                        </StackPanel>
                                        <Button Grid.Column="1" Content="✕ Quitar" VerticalAlignment="Top" Margin="12,18,0,0"
                                                Padding="10,6" Background="#1AFF5252" Foreground="#FFFF8A8A" BorderThickness="0"
                                                Cursor="Hand" Tag="{Binding}" Click="RemoveSlide_Click"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </StackPanel.Resources>

                        <TextBlock Style="{StaticResource SectionTitle}" Text="Pantalla de espera (Attract) · Textos"/>
                        <TextBlock Style="{StaticResource SectionHint}" Text="Mensajes que van rotando en la pantalla inicial. Solo se editan los del estado seleccionado arriba."/>

                        <!-- Con servidor de contenido, los slides son compartidos y los gestiona el panel: se
                             ocultan aquí para no editar algo que el servidor sobrescribiría. -->
                        <TextBlock x:Name="SlidesServerNote" Visibility="Collapsed" Style="{StaticResource SectionHint}"
                                   Foreground="{StaticResource CyanBrush}" TextWrapping="Wrap" Margin="0,8,0,0"
                                   Text="Este kiosko recibe los textos de la pantalla de espera desde el panel del servidor. Se gestionan allí, iguales para toda la tienda."/>

                        <!-- Set "De ocasión": visible solo cuando UsedRadio está marcado -->
                        <StackPanel x:Name="UsedSlidesPanel">
                            <TextBlock Style="{StaticResource FieldLabel}" Margin="0,10,0,10" Text="◆ EQUIPO DE OCASIÓN"/>
                            <ItemsControl x:Name="SlidesItemsControl" ItemTemplate="{StaticResource AttractSlideTemplate}"/>
                            <Button Content="+ Añadir texto" HorizontalAlignment="Left" Margin="0,4,0,0"
                                    Padding="14,8" Background="#1A00F0FF" Foreground="{StaticResource CyanBrush}" BorderThickness="0"
                                    Cursor="Hand" Click="AddSlide_Click"/>
                        </StackPanel>

                        <!-- Set "Nuevo": visible solo cuando NewRadio está marcado -->
                        <StackPanel x:Name="NewSlidesPanel" Visibility="Collapsed">
                            <TextBlock Style="{StaticResource FieldLabel}" Margin="0,10,0,10" Text="◆ EQUIPO NUEVO"/>
                            <ItemsControl x:Name="SlidesNewItemsControl" ItemTemplate="{StaticResource AttractSlideTemplate}"/>
                            <Button Content="+ Añadir texto" HorizontalAlignment="Left" Margin="0,4,0,0"
                                    Padding="14,8" Background="#1A00F0FF" Foreground="{StaticResource CyanBrush}" BorderThickness="0"
                                    Cursor="Hand" Click="AddSlideNew_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Hardware override -->
                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitle}" Text="Anulación manual de hardware"/>
                        <TextBlock Style="{StaticResource SectionHint}" Text="Deja un campo en blanco para usar la detección automática."/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="18"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Grid.Column="0" Style="{StaticResource Field}">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="PROCESADOR"/>
                                <TextBox x:Name="CpuTextBox" Style="{StaticResource ConfigTextBox}"/>
                            </StackPanel>
                            <StackPanel Grid.Row="0" Grid.Column="2" Style="{StaticResource Field}">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="RENDIMIENTO"/>
                                <TextBox x:Name="CoresTextBox" Style="{StaticResource ConfigTextBox}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="0" Style="{StaticResource Field}">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="MEMORIA RAM"/>
                                <TextBox x:Name="RamTextBox" Style="{StaticResource ConfigTextBox}"/>
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="2" Style="{StaticResource Field}">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="GRÁFICOS"/>
                                <TextBox x:Name="GpuTextBox" Style="{StaticResource ConfigTextBox}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="2" Grid.Column="0" Style="{StaticResource Field}">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="ALMACENAMIENTO"/>
                                <TextBox x:Name="StorageTextBox" Style="{StaticResource ConfigTextBox}"/>
                            </StackPanel>
                            <StackPanel Grid.Row="2" Grid.Column="2" Style="{StaticResource Field}">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="PANTALLA"/>
                                <TextBox x:Name="ScreenTextBox" Style="{StaticResource ConfigTextBox}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="3" Grid.Column="0" Style="{StaticResource Field}">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="SISTEMA"/>
                                <TextBox x:Name="OsTextBox" Style="{StaticResource ConfigTextBox}"/>
                            </StackPanel>
                            <StackPanel Grid.Row="3" Grid.Column="2" Style="{StaticResource Field}">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="BATERÍA"/>
                                <TextBox x:Name="BatteryTextBox" Style="{StaticResource ConfigTextBox}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="4" Grid.Column="0" Style="{StaticResource Field}">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="CONECTIVIDAD"/>
                                <TextBox x:Name="WifiTextBox" Style="{StaticResource ConfigTextBox}"/>
                            </StackPanel>
                            <StackPanel Grid.Row="4" Grid.Column="2" Style="{StaticResource Field}">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="CÁMARA"/>
                                <TextBox x:Name="CameraTextBox" Style="{StaticResource ConfigTextBox}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="5" Grid.Column="0" Style="{StaticResource Field}">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="PUERTOS"/>
                                <TextBox x:Name="PortsTextBox" Style="{StaticResource ConfigTextBox}"/>
                            </StackPanel>
                            <StackPanel Grid.Row="5" Grid.Column="2" Style="{StaticResource Field}">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="SKU"/>
                                <TextBox x:Name="SkuTextBox" Style="{StaticResource ConfigTextBox}"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Detalle técnico (fila de tokens del StatStrip en la página de specs) -->
                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitle}" Text="Detalle técnico (ficha de specs)"/>
                        <TextBlock Style="{StaticResource SectionHint}" Text="Tokens separados por &#183; (p.ej. &quot;4800 MHz &#183; DDR5 &#183; 2 m&#243;dulos&quot;). En blanco usa lo detectado; si no hay detecci&#243;n, no se muestra nada."/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="18"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Grid.Column="0" Style="{StaticResource Field}">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="RAM · DETALLE"/>
                                <TextBox x:Name="RamDetailTextBox" Style="{StaticResource ConfigTextBox}"/>
                            </StackPanel>
                            <StackPanel Grid.Row="0" Grid.Column="2" Style="{StaticResource Field}">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="ALMACENAMIENTO · DETALLE"/>
                                <TextBox x:Name="StorageDetailTextBox" Style="{StaticResource ConfigTextBox}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="0" Style="{StaticResource Field}">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="PANTALLA · DETALLE"/>
                                <TextBox x:Name="ScreenDetailTextBox" Style="{StaticResource ConfigTextBox}"/>
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="2" Style="{StaticResource Field}">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="BATERÍA · DETALLE"/>
                                <TextBox x:Name="BatteryDetailTextBox" Style="{StaticResource ConfigTextBox}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="2" Grid.Column="0" Style="{StaticResource Field}">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="GRÁFICOS · DETALLE"/>
                                <TextBox x:Name="GpuDetailTextBox" Style="{StaticResource ConfigTextBox}"/>
                            </StackPanel>
                            <StackPanel Grid.Row="2" Grid.Column="2" Style="{StaticResource Field}">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="CONECTIVIDAD · DETALLE"/>
                                <TextBox x:Name="WifiDetailTextBox" Style="{StaticResource ConfigTextBox}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="3" Grid.Column="0" Style="{StaticResource Field}">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="CÁMARA · DETALLE"/>
                                <TextBox x:Name="CameraDetailTextBox" Style="{StaticResource ConfigTextBox}"/>
                            </StackPanel>
                            <StackPanel Grid.Row="3" Grid.Column="2" Style="{StaticResource Field}">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="PUERTOS · DETALLE"/>
                                <TextBox x:Name="PortsDetailTextBox" Style="{StaticResource ConfigTextBox}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="4" Grid.Column="0" Style="{StaticResource Field}">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="SISTEMA · DETALLE"/>
                                <TextBox x:Name="OsDetailTextBox" Style="{StaticResource ConfigTextBox}"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Tiempos -->
                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitle}" Text="Kiosko · Tiempos"/>
                        <TextBlock Style="{StaticResource SectionHint}" Text="Valores en segundos."/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="INACTIVIDAD → ESPERA"/>
                                <TextBox x:Name="InactivityTextBox" Style="{StaticResource ConfigTextBox}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="AUTO-ANÁLISIS"/>
                                <TextBox x:Name="AutoScanTextBox" Style="{StaticResource ConfigTextBox}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="4">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="INTERVALO SLIDES"/>
                                <TextBox x:Name="SlideIntervalTextBox" Style="{StaticResource ConfigTextBox}"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Servidor de contenido -->
                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitle}" Text="Servidor de contenido"/>
                        <TextBlock Style="{StaticResource SectionHint}" Text="URL del servidor de la tienda. En blanco = modo local (este kiosko usa solo su propia configuración). Con URL, descarga el contenido compartido (tienda, slides, textos, eventos) y sincroniza la pantalla de espera con el resto."/>
                        <StackPanel Style="{StaticResource Field}">
                            <TextBlock Style="{StaticResource FieldLabel}" Text="URL DEL SERVIDOR (p.ej. http://192.168.1.50:5099)"/>
                            <TextBox x:Name="ServerUrlTextBox" Style="{StaticResource ConfigTextBox}"/>
                        </StackPanel>
                        <StackPanel Style="{StaticResource Field}">
                            <TextBlock Style="{StaticResource FieldLabel}" Text="API KEY (en blanco si el servidor es abierto)"/>
                            <TextBox x:Name="ServerApiKeyTextBox" Style="{StaticResource ConfigTextBox}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="TestConnectionButton" Content="Probar conexión" Style="{StaticResource SecondaryButton}"
                                    Padding="16,8" Click="TestConnectionButton_Click"/>
                            <TextBlock x:Name="ConnectionStatusText" VerticalAlignment="Center" Margin="14,0,0,0"
                                       FontFamily="{StaticResource JetBrainsMono}" FontSize="11" Foreground="#FF8A82A8"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Seguridad -->
                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitle}" Text="Seguridad · Cambiar contraseña"/>
                        <TextBlock Style="{StaticResource SectionHint}" Text="Deja los campos en blanco para mantener la contraseña actual."/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="CONTRASEÑA ACTUAL"/>
                                <PasswordBox x:Name="CurrentPasswordBox" Style="{StaticResource ConfigPasswordBox}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="NUEVA"/>
                                <PasswordBox x:Name="NewPasswordBox" Style="{StaticResource ConfigPasswordBox}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="4">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="CONFIRMAR"/>
                                <PasswordBox x:Name="ConfirmPasswordBox" Style="{StaticResource ConfigPasswordBox}"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Modo edición -->
                <Border Style="{StaticResource SectionCard}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Style="{StaticResource SectionTitle}" Text="Modo edición libre"/>
                            <TextBlock Style="{StaticResource SectionHint}" Margin="0,4,0,0"
                                       Text="Navega el kiosko y toca cualquier texto para editarlo en pantalla."/>
                            <TextBlock x:Name="EditModeServerNote" Visibility="Collapsed" Style="{StaticResource SectionHint}"
                                       Foreground="{StaticResource CyanBrush}" TextWrapping="Wrap" Margin="0,6,0,0"
                                       Text="Desactivado: el contenido editable inline (slides, textos, marketing) es compartido y se gestiona desde el panel del servidor. El precio y las especificaciones de este equipo se editan en los campos de arriba."/>
                        </StackPanel>
                        <Button Grid.Column="1" x:Name="EditModeButton" Content="✏  Activar"
                                Style="{StaticResource PrimaryButton}" VerticalAlignment="Center"
                                Click="EditModeButton_Click"/>
                    </Grid>
                </Border>

                <!-- Zona de peligro -->
                <Border Style="{StaticResource SectionCard}" BorderBrush="#55DA3030">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitle}" Foreground="#FFE76A6A" Text="Energía y sistema"/>
                        <TextBlock Style="{StaticResource SectionHint}" Text="Acciones que cierran la aplicación o el equipo."/>
                        <WrapPanel>
                            <Button Content="Salir del kiosko" Style="{StaticResource SecondaryButton}" Margin="0,0,10,10" Click="ExitKiosk_Click"/>
                            <Button Content="Reiniciar app" Style="{StaticResource SecondaryButton}" Margin="0,0,10,10" Click="RestartApp_Click"/>
                            <Button Content="Reiniciar PC" Style="{StaticResource SecondaryButton}" Margin="0,0,10,10" Click="RestartPc_Click"/>
                            <Button Content="Apagar PC" Style="{StaticResource SecondaryButton}" Margin="0,0,10,10" Click="ShutdownPc_Click"/>
                            <Button Content="Restaurar valores por defecto" Style="{StaticResource SecondaryButton}" Margin="0,0,10,10" Click="RestoreDefaults_Click"/>
                            <Button x:Name="CheckUpdateButton" Content="⬇  Buscar actualizaciones" Style="{StaticResource SecondaryButton}" Margin="0,0,10,10" Click="CheckUpdateButton_Click"/>
                            <Button x:Name="UninstallButton" Content="🗑  Desinstalar" Style="{StaticResource DangerButton}" Margin="0,0,10,10" Click="UninstallButton_Click"/>
                        </WrapPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Bottom action bar -->
        <Border Grid.Row="2" Background="#FF0A0716" Padding="24,16">
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="16" ShadowDepth="0" Opacity="0.4" Direction="90"/>
            </Border.Effect>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="CancelButton" Content="Cancelar"
                        Style="{StaticResource SecondaryButton}" Padding="22,11"
                        Click="CloseButton_Click" IsCancel="True" Margin="0,0,12,0" />
                <Button x:Name="SaveButton" Content="Guardar cambios"
                        Style="{StaticResource PrimaryButton}" Padding="26,11"
                        Click="SaveButton_Click" IsDefault="True" />
            </StackPanel>
        </Border>
    </Grid>

</Window>
