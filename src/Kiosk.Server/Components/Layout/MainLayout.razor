@inherits LayoutComponentBase

<div class="layout">
    <header class="topbar">
        <span class="brand">Kiosk · ClinicaPC</span>
        <AuthorizeView>
            <Authorized>
                <nav class="nav">
                    <NavLink href="/" Match="NavLinkMatch.All">Inicio</NavLink>
                    <NavLink href="/contenido">Contenido</NavLink>
                    <NavLink href="/imagenes">Imágenes</NavLink>
                    <NavLink href="/eventos">Eventos</NavLink>
                    <NavLink href="/seguridad">Seguridad</NavLink>
                </nav>
                <form class="logout" method="post" action="/logout">
                    <AntiforgeryToken />
                    <button type="submit">Salir</button>
                </form>
            </Authorized>
        </AuthorizeView>
    </header>
    <main class="content">
        @Body
    </main>
</div>
