@page "/seguridad"
@attribute [Authorize]
@rendermode InteractiveServer
@inject PanelAuthStore Auth
@inject ContentResolver Content
@inject FleetRegistry Fleet

<div class="split even" style="max-width:920px;">
    <div class="card" style="padding:26px;">
        <div style="display:flex;align-items:center;gap:11px;margin-bottom:6px;">
            <div class="icon-badge">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#FFB069" stroke-width="1.9"><rect x="4.5" y="10" width="15" height="10" rx="2" /><path d="M8 10V7a4 4 0 0 1 8 0v3" /></svg>
            </div>
            <h2 style="margin:0;">Contraseña de administración</h2>
        </div>
        <p class="muted" style="margin:0 0 22px;font-size:13px;">
            Abre este panel. La contraseña de los ajustes de cada kiosko se cambia en el propio equipo.
        </p>

        <div class="stack" style="gap:15px;">
            <div>
                <label>Contraseña actual</label>
                <input type="password" @bind="_current" />
            </div>
            <div>
                <label>Nueva contraseña</label>
                <input type="password" @bind="_new" @bind:event="oninput" />
                <div class="strength">
                    @for (int i = 0; i < 4; i++)
                    {
                        <span class="@(i < _strength ? $"on {StrengthCss}" : "")"></span>
                    }
                </div>
                <div class="strength-note" style="color:@StrengthColor;">Fortaleza: @StrengthLabel · mín. 6 caracteres</div>
            </div>
            <div>
                <label>Repetir nueva</label>
                <input type="password" @bind="_repeat" />
            </div>
            <button class="primary" style="margin-top:4px;padding:13px;border-radius:10px;font-size:14px;" @onclick="Change">
                Cambiar contraseña del panel
            </button>
        </div>
    </div>

    <div style="display:flex;flex-direction:column;gap:20px;">
        <div class="card" style="padding:22px;">
            <h2 class="mono" style="margin:0 0 15px;">// Estado del sistema</h2>
            <div class="kv">
                <div class="r">
                    <span class="k">Versión de contenido</span>
                    <span class="v"><span class="dot sm online"></span>@Content.Version()</span>
                </div>
                <div class="r">
                    <span class="k">Hora de la tienda</span>
                    <span class="v">@Content.NowLocal.ToString("dd/MM/yyyy HH:mm")</span>
                </div>
                <div class="r">
                    <span class="k">Evento activo</span>
                    <span class="v">@(Content.ActiveEvent()?.Name ?? "ninguno")</span>
                </div>
                <div class="r">
                    <span class="k">Equipos en red</span>
                    <span class="v">@Fleet.OnlineCount / @Fleet.Devices.Count online</span>
                </div>
            </div>
        </div>

        <div class="card sunken" style="padding:22px;">
            <h2 class="mono" style="margin:0 0 14px;">// Accesos recientes al panel</h2>
            <p class="muted" style="margin:0;font-size:13px;">
                Pendiente: el registro de accesos todavía no se guarda. El servidor ya frena los intentos
                repetidos por IP en el login.
            </p>
        </div>

        <div class="card" style="padding:22px;">
            <h2 style="margin:0 0 6px;font-size:16px;">Bloqueo automático</h2>
            <p class="muted" style="margin:0 0 16px;font-size:12.5px;">
                Pendiente: la sesión del panel dura 7 días con renovación deslizante.
            </p>
            <div style="display:flex;align-items:center;justify-content:space-between;">
                <span style="font-size:13.5px;color:var(--text);">Cerrar sesión tras 15 min inactivo</span>
                <div class="toggle" style="opacity:.55;">
                    <input type="checkbox" disabled />
                    <span class="track"></span>
                </div>
            </div>
        </div>
    </div>
</div>

<Toast Message="@_message" IsError="_error" />

@code {
    private string _current = "", _new = "", _repeat = "";
    private string? _message;
    private bool _error;

    // Medidor orientativo (0-4): longitud + variedad de caracteres. No bloquea nada por sí solo.
    private int _strength => string.IsNullOrEmpty(_new) ? 0 : Score(_new);

    private static int Score(string pw)
    {
        int s = 0;
        if (pw.Length >= 6) s++;
        if (pw.Length >= 10) s++;
        if (pw.Any(char.IsDigit) && pw.Any(char.IsLetter)) s++;
        if (pw.Any(c => !char.IsLetterOrDigit(c))) s++;
        return s;
    }

    private string StrengthCss => _strength switch { <= 1 => "weak", 2 => "mid", _ => "" };
    private string StrengthLabel => _strength switch { 0 => "—", 1 => "débil", 2 => "mejorable", 3 => "buena", _ => "fuerte" };
    private string StrengthColor => _strength switch { 0 => "var(--dim)", 1 => "var(--danger-soft)", 2 => "var(--accent-2)", _ => "var(--ok)" };

    private void Change()
    {
        _message = null;
        if (!Auth.Verify(_current)) { Fail("La contraseña actual no es correcta."); return; }
        if (_new.Length < 6) { Fail("La nueva contraseña debe tener al menos 6 caracteres."); return; }
        if (_new != _repeat) { Fail("Las contraseñas nuevas no coinciden."); return; }

        Auth.SetPassword(_new);
        _current = _new = _repeat = "";
        _error = false;
        _message = "Contraseña cambiada.";
    }

    private void Fail(string msg) { _error = true; _message = msg; }
}
