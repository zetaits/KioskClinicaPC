@page "/ordenadores"
@attribute [Authorize]
@rendermode InteractiveServer
@inject FleetRegistry Registry
@* Flota de kioscos de la tienda. PENDIENTE: los datos vienen de FleetRegistry, que aún es de muestra, y las
   órdenes (reiniciar/apagar) no tienen canal de control; precio y nombre se editan solo en memoria. *@

<div class="fleet-toolbar">
    <div class="search">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#6f6890" stroke-width="2"><circle cx="11" cy="11" r="7" /><path d="M21 21l-4-4" /></svg>
        <input type="text" placeholder="Buscar equipo, IP o hardware…" @bind="_search" @bind:event="oninput" />
    </div>

    <div style="display:flex;gap:6px;">
        <button class="filter @(_filter == Filter.All ? "on" : "")" @onclick="() => _filter = Filter.All">Todos · @Registry.Devices.Count</button>
        <button class="filter @(_filter == Filter.Online ? "on" : "")" @onclick="() => _filter = Filter.Online">Online · @Registry.OnlineCount</button>
        <button class="filter @(_filter == Filter.Offline ? "on" : "")" @onclick="() => _filter = Filter.Offline">Caídos · @Registry.OfflineCount</button>
    </div>

    <div style="display:flex;align-items:center;gap:8px;margin-left:auto;">
        <span class="mono-label" style="font-size:10px;letter-spacing:.14em;color:var(--dim);">Vista</span>
        <div class="viewtoggle">
            <button class="@(_cards ? "on" : "")" @onclick="() => _cards = true">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7" rx="1.5" /><rect x="14" y="3" width="7" height="7" rx="1.5" /><rect x="3" y="14" width="7" height="7" rx="1.5" /><rect x="14" y="14" width="7" height="7" rx="1.5" /></svg>Tarjetas
            </button>
            <button class="@(!_cards ? "on" : "")" @onclick="() => _cards = false">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18M3 12h18M3 18h18" /></svg>Tabla
            </button>
        </div>
    </div>
</div>

<div class="fleet-summary">
    <span class="dot sm online"></span>
    @Registry.Devices.Count equipos en red · <span class="m">precio medio expuesto</span> <b>@Registry.AveragePrice.ToString("N0", _es) €</b>
</div>

@{ var shown = Shown().ToList(); }

@if (shown.Count == 0)
{
    <div class="card">
        <p class="muted" style="margin:0;">Ningún equipo coincide con el filtro.</p>
    </div>
}
else if (_cards)
{
    <div class="fleet-grid">
        @foreach (var d in shown)
        {
            <div class="pc-card">
                <div class="top">
                    <span class="dot @FleetRegistry.StatusCss(d.Status)"></span>
                    <span class="status">@FleetRegistry.StatusLabel(d.Status)</span>
                    <span class="screen-badge @FleetRegistry.ScreenCss(d.Screen)">@FleetRegistry.ScreenLabel(d.Screen)</span>
                    <span class="ip">@d.Ip</span>
                </div>

                <div class="name-row">
                    <span class="n">@d.Name</span>
                    <button class="icon sm" title="Renombrar equipo" @onclick="() => OpenRename(d)">
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20h9M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4z" /></svg>
                    </button>
                </div>
                <div class="equip">@d.Equipment</div>
                <div class="cpu">@d.Cpu</div>

                <div class="price-box">
                    <div>
                        <div class="k">Precio expuesto</div>
                        <div class="v">
                            <span class="now">@PriceLabel(d)</span>
                            @if (d.HasOldPrice)
                            {
                                <span class="old">@d.OldPrice.ToString("N0", _es) €</span>
                            }
                        </div>
                    </div>
                    <button class="accent" style="font-size:12px;padding:8px 12px;" @onclick="() => OpenPrice(d)">Editar</button>
                </div>

                <div class="meta">
                    <span>⏱ @d.Uptime</span><span>app @d.AppVersion</span>
                </div>

                <div class="actions">
                    <button @onclick="() => AskRestart(d)">
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M21 12a9 9 0 1 1-2.6-6.4M21 4v4h-4" /></svg>Reiniciar
                    </button>
                    <button @onclick='() => Pending($"reiniciar la app de {d.Name}")'>
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M12 2v6M5 8a8 8 0 1 0 14 0" /></svg>Reiniciar app
                    </button>
                    <button class="danger span" @onclick="() => AskShutdown(d)">
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M12 4v8M6.4 7A8 8 0 1 0 18 8" /></svg>Apagar equipo
                    </button>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="fleet-table">
        <div class="r head">
            <span>Equipo</span><span>Equipo expuesto</span><span>Pantalla</span><span>Precio</span><span>Uptime</span><span style="text-align:right;">Acciones</span>
        </div>
        @foreach (var d in shown)
        {
            <div class="r">
                <div class="name-cell">
                    <span class="dot @FleetRegistry.StatusCss(d.Status)"></span>
                    <span class="n">@d.Name</span>
                    <button class="icon sm" title="Renombrar" style="width:24px;height:24px;" @onclick="() => OpenRename(d)">
                        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20h9M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4z" /></svg>
                    </button>
                </div>
                <div class="equip-cell">
                    <div class="e">@d.Equipment</div>
                    <div class="c">@d.Cpu</div>
                </div>
                <span class="screen-badge @FleetRegistry.ScreenCss(d.Screen)">@FleetRegistry.ScreenLabel(d.Screen)</span>
                <span class="price">@PriceLabel(d)</span>
                <span class="uptime">@d.Uptime</span>
                <div class="acts">
                    <button class="icon" title="Precio" style="color:var(--accent-2);font-family:var(--font-display);font-weight:700;" @onclick="() => OpenPrice(d)">€</button>
                    <button class="icon" title="Reiniciar" @onclick="() => AskRestart(d)">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M21 12a9 9 0 1 1-2.6-6.4M21 4v4h-4" /></svg>
                    </button>
                    <button class="icon danger" title="Apagar" @onclick="() => AskShutdown(d)">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M12 4v8M6.4 7A8 8 0 1 0 18 8" /></svg>
                    </button>
                </div>
            </div>
        }
    </div>
}

@* ── Modal de precio ── *@
@if (_price is not null)
{
    <div class="modal-backdrop" @onclick="() => _price = null">
        <div class="modal" style="width:400px;" @onclick:stopPropagation="true">
            <div class="eyebrow">// Precio expuesto</div>
            <h2>@_price.Device.Name</h2>
            <p>@_price.Device.Equipment</p>
            <div class="row" style="margin-bottom:22px;flex-wrap:nowrap;">
                <div style="flex:1;">
                    <label>Precio (€)</label>
                    <input type="number" class="display accent" @bind="_price.Value" />
                </div>
                <div style="flex:1;">
                    <label>Antes (€)</label>
                    <input type="number" class="display" @bind="_price.OldValue" />
                </div>
            </div>
            <div class="actions" style="display:flex;gap:10px;">
                <button style="flex:1;padding:12px;border-radius:10px;font-size:14px;" @onclick="() => _price = null">Cancelar</button>
                <button class="primary" style="flex:1.4;padding:12px;border-radius:10px;font-size:14px;" @onclick="SavePrice">Aplicar al equipo</button>
            </div>
        </div>
    </div>
}

@* ── Modal de renombrar ── *@
@if (_rename is not null)
{
    <div class="modal-backdrop" @onclick="() => _rename = null">
        <div class="modal" style="width:400px;" @onclick:stopPropagation="true">
            <div class="eyebrow">// Renombrar equipo</div>
            <h2>@_rename.Device.Name</h2>
            <p>El nombre identifica el equipo en el panel y en los avisos. No afecta al hostname del sistema.</p>
            <label>Nuevo nombre</label>
            <input type="text" class="accent" style="font-size:15px;margin-bottom:22px;" @bind="_rename.Value" />
            <div class="actions" style="display:flex;gap:10px;">
                <button style="flex:1;padding:12px;border-radius:10px;font-size:14px;" @onclick="() => _rename = null">Cancelar</button>
                <button class="primary" style="flex:1.4;padding:12px;border-radius:10px;font-size:14px;" @onclick="SaveRename">Guardar nombre</button>
            </div>
        </div>
    </div>
}

<ConfirmDialog Model="_confirm" OnClose="() => _confirm = null" />
<Toast Message="@_toast" />

@code {
    private static readonly System.Globalization.CultureInfo _es = new("es-ES");

    private enum Filter { All, Online, Offline }

    private sealed class PriceEdit
    {
        public FleetDevice Device { get; init; } = null!;
        public decimal Value { get; set; }
        public decimal OldValue { get; set; }
    }

    private sealed class RenameEdit
    {
        public FleetDevice Device { get; init; } = null!;
        public string Value { get; set; } = "";
    }

    private string _search = "";
    private Filter _filter = Filter.All;
    private bool _cards = true;
    private PriceEdit? _price;
    private RenameEdit? _rename;
    private ConfirmDialog.Options? _confirm;
    private string? _toast;

    private IEnumerable<FleetDevice> Shown()
    {
        var q = Registry.Devices.AsEnumerable();

        q = _filter switch
        {
            Filter.Online => q.Where(d => d.IsOnline),
            Filter.Offline => q.Where(d => !d.IsOnline),
            _ => q
        };

        if (!string.IsNullOrWhiteSpace(_search))
        {
            string s = _search.Trim();
            q = q.Where(d =>
                d.Name.Contains(s, StringComparison.OrdinalIgnoreCase) ||
                d.Ip.Contains(s, StringComparison.OrdinalIgnoreCase) ||
                d.Equipment.Contains(s, StringComparison.OrdinalIgnoreCase) ||
                d.Cpu.Contains(s, StringComparison.OrdinalIgnoreCase));
        }

        return q;
    }

    private static string PriceLabel(FleetDevice d) =>
        d.Price > 0 ? d.Price.ToString("N0", _es) + " €" : "—";

    private void OpenPrice(FleetDevice d) =>
        _price = new PriceEdit { Device = d, Value = d.Price, OldValue = d.OldPrice };

    private void SavePrice()
    {
        if (_price is null) return;
        Registry.SetPrice(_price.Device.Id, _price.Value, _price.OldValue);
        _toast = $"Precio de «{_price.Device.Name}» guardado solo en el panel: aún no viaja al equipo.";
        _price = null;
    }

    private void OpenRename(FleetDevice d) =>
        _rename = new RenameEdit { Device = d, Value = d.Name };

    private void SaveRename()
    {
        if (_rename is null) return;
        Registry.Rename(_rename.Device.Id, _rename.Value);
        _toast = $"Equipo renombrado a «{_rename.Device.Name}».";
        _rename = null;
    }

    private void AskRestart(FleetDevice d) => _confirm = new()
    {
        Title = $"Reiniciar {d.Name}",
        Body = "El equipo se reiniciará y volverá al modo kiosko en aproximadamente un minuto.",
        Label = "Reiniciar equipo",
        Confirmed = EventCallback.Factory.Create(this, () => { _confirm = null; Pending($"reiniciar {d.Name}"); })
    };

    private void AskShutdown(FleetDevice d) => _confirm = new()
    {
        Title = $"Apagar {d.Name}",
        Body = "El equipo se apagará y habrá que encenderlo a mano en la tienda.",
        Label = "Apagar equipo",
        Confirmed = EventCallback.Factory.Create(this, () => { _confirm = null; Pending($"apagar {d.Name}"); })
    };

    private void Pending(string what) =>
        _toast = $"Sin efecto: {what} todavía no está implementado.";
}
