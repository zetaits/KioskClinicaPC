@rendermode InteractiveServer
@inject FleetRegistry Fleet
@* Botonera de emergencia del encabezado. Isla interactiva dentro del layout (que se renderiza estático).
   PENDIENTE: el envío real de órdenes a los kioscos necesita el canal de control que aún no existe. *@

<div class="emergency">
    <button @onclick="AskRestart">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12a9 9 0 1 1-2.6-6.4M21 4v4h-4" /></svg>Reiniciar todos
    </button>
    <button class="danger" @onclick="AskShutdown">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 4v8M6.4 7A8 8 0 1 0 18 8" /></svg>Apagar todos
    </button>
</div>

<ConfirmDialog Model="_confirm" OnClose="() => _confirm = null" />
<Toast Message="@_toast" />

@code {
    private ConfirmDialog.Options? _confirm;
    private string? _toast;

    private void AskRestart() => _confirm = new()
    {
        Title = "Reiniciar toda la flota",
        Body = $"Se reiniciarán los {Fleet.OnlineCount} equipos online. Cada uno volverá al modo kiosko en ~1 minuto." +
               (Fleet.OfflineCount > 0 ? $" Los {Fleet.OfflineCount} equipos sin conexión se omiten." : ""),
        Label = $"Reiniciar {Fleet.OnlineCount} equipos",
        Confirmed = EventCallback.Factory.Create(this, Pending)
    };

    private void AskShutdown() => _confirm = new()
    {
        Title = "Apagar toda la flota",
        Body = $"Se apagarán los {Fleet.OnlineCount} equipos online. Habrá que encenderlos a mano en la tienda.",
        Label = $"Apagar {Fleet.OnlineCount} equipos",
        Confirmed = EventCallback.Factory.Create(this, Pending)
    };

    private void Pending()
    {
        _confirm = null;
        _toast = "Sin efecto: el envío de órdenes a la flota todavía no está implementado.";
    }
}
