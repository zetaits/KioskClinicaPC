@using KioskClinicaPC.Core.Config
@* Editor reutilizable de una lista de slides de atracción (usado en Contenido y en Eventos). *@

<div style="display:flex;flex-direction:column;gap:12px;">
    @for (int i = 0; i < Slides.Count; i++)
    {
        var s = Slides[i];
        <div class="slide-item">
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px;">
                <div class="k" style="margin:0;">Slide @((i + 1).ToString("00"))</div>
                <button class="icon sm" title="Quitar slide" @onclick="() => Remove(s)">✕</button>
            </div>
            <input type="text" class="line" style="font-family:var(--font-mono);font-weight:400;font-size:11px;color:var(--muted);" placeholder="Eyebrow" @bind="s.Eyebrow" />
            <input type="text" class="line" placeholder="Título 1" @bind="s.Title1" />
            <input type="text" class="line accent" placeholder="Título 2 (acento)" @bind="s.Title2" />
            <input type="text" class="line sub" placeholder="Subtítulo" @bind="s.Subtitle" />
        </div>
    }
</div>

<button class="accent" style="margin-top:12px;font-size:12px;padding:8px 13px;border-radius:8px;" @onclick="Add">+ Añadir slide</button>

@code {
    [Parameter, EditorRequired] public List<AttractSlide> Slides { get; set; } = new();

    private void Add() => Slides.Add(new AttractSlide());
    private void Remove(AttractSlide s) => Slides.Remove(s);
}
