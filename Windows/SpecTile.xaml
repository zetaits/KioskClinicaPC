<UserControl x:Class="KioskClinicaPC.Windows.SpecTile"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:KioskClinicaPC.Windows"
             mc:Ignorable="d"
             d:DesignHeight="100" d:DesignWidth="400"
             Background="#1C1C1E" Margin="5"
             x:Name="root">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <Image Source="{Binding ElementName=root, Path=IconSource}" Width="60" Height="60" Margin="10,0,10,0" VerticalAlignment="Center"/>

        <StackPanel Grid.Column="1" VerticalAlignment="Center">
            <TextBlock Text="{Binding ElementName=root, Path=Label}" Foreground="#A2A2A7" FontSize="12" FontWeight="SemiBold"/>
            <TextBlock Text="{Binding ElementName=root, Path=Value}" Foreground="White" FontSize="18" FontWeight="Bold" TextWrapping="Wrap"/>
            <TextBlock Text="{Binding ElementName=root, Path=Benefit}" Foreground="#A2A2A7" FontSize="14" TextWrapping="Wrap"/>
        </StackPanel>

        <StackPanel Grid.Column="2" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="10">
            <TextBlock Text="{Binding ElementName=root, Path=Tag}" Background="#FF007ACC" Foreground="White" Padding="8,4" FontSize="10" FontWeight="Bold"/>
        </StackPanel>

        <Button Grid.Column="2" VerticalAlignment="Bottom" HorizontalAlignment="Right"
                Content="?" Margin="5"/>
    </Grid>
</UserControl>
