<Window x:Class="KioskClinicaPC.Windows.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Panel de Configuración" 
        Height="650" Width="800"
        WindowStartupLocation="CenterScreen"
        Background="#FF1E1E1E"
        Foreground="White"
        FontFamily="Segoe UI Light"
        Loaded="Window_Loaded"
        WindowStyle="None"
        ResizeMode="NoResize"
        BorderBrush="#FF007ACC" 
        BorderThickness="1">

    <Window.Resources>
        <Style x:Key="ConfigTextBox" TargetType="TextBox">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Background" Value="#FF333333"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="5"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" /> 
            <RowDefinition Height="*" />   
            <RowDefinition Height="Auto" /> 
        </Grid.RowDefinitions>
        
        <TextBlock Grid.Row="0"
                   Text="PANEL DE CONFIGURACIÓN"
                   FontSize="24" FontWeight="SemiBold"
                   Foreground="#FFCCCCCC"
                   HorizontalAlignment="Center"
                   Margin="0,20,0,0"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="25,20">
            <StackPanel>
                
                <TextBlock Text="Precios" FontSize="18" FontWeight="SemiBold" Foreground="#FF007ACC" Margin="0,0,0,10"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Precio Principal:" VerticalAlignment="Center" Margin="0,0,15,0" />
                    <TextBox Grid.Row="0" Grid.Column="1" x:Name="PriceTextBox" Style="{StaticResource ConfigTextBox}" />
                    
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Precio Descuento:" VerticalAlignment="Center" Margin="0,10,15,0" />
                    <TextBox Grid.Row="1" Grid.Column="1" x:Name="DiscountedPriceTextBox" Style="{StaticResource ConfigTextBox}" Margin="0,10,0,0" />
                </Grid>

                <Border Height="1" Background="#FF333333" Margin="0,20" />

                <TextBlock Text="Anulación Manual de Hardware" FontSize="18" FontWeight="SemiBold" Foreground="#FF007ACC" Margin="0,0,0,10"/>
                <TextBlock Text="Dejar en blanco para usar la detección automática." FontSize="12" Foreground="#FF888888" Margin="0,-5,0,15"/>
                
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Procesador:" VerticalAlignment="Center" Margin="0,0,15,0" />
                    <TextBox Grid.Row="0" Grid.Column="1" x:Name="CpuTextBox" Style="{StaticResource ConfigTextBox}" />

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Rendimiento:" VerticalAlignment="Center" Margin="0,10,15,0" />
                    <TextBox Grid.Row="1" Grid.Column="1" x:Name="CoresTextBox" Style="{StaticResource ConfigTextBox}" Margin="0,10,0,0" />
                    
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Memoria RAM:" VerticalAlignment="Center" Margin="0,10,15,0" />
                    <TextBox Grid.Row="2" Grid.Column="1" x:Name="RamTextBox" Style="{StaticResource ConfigTextBox}" Margin="0,10,0,0" />
                    
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Gráficos:" VerticalAlignment="Center" Margin="0,10,15,0" />
                    <TextBox Grid.Row="3" Grid.Column="1" x:Name="GpuTextBox" Style="{StaticResource ConfigTextBox}" Margin="0,10,0,0" />
                    
                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Almacenamiento:" VerticalAlignment="Center" Margin="0,10,15,0" />
                    <TextBox Grid.Row="4" Grid.Column="1" x:Name="StorageTextBox" Style="{StaticResource ConfigTextBox}" Margin="0,10,0,0" />
                    
                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Pantalla:" VerticalAlignment="Center" Margin="0,10,15,0" />
                    <TextBox Grid.Row="5" Grid.Column="1" x:Name="ScreenTextBox" Style="{StaticResource ConfigTextBox}" Margin="0,10,0,0" />
                    
                    <TextBlock Grid.Row="6" Grid.Column="0" Text="Sistema:" VerticalAlignment="Center" Margin="0,10,15,0" />
                    <TextBox Grid.Row="6" Grid.Column="1" x:Name="OsTextBox" Style="{StaticResource ConfigTextBox}" Margin="0,10,0,0" />

                </Grid>
            </StackPanel>
        </ScrollViewer>
        
        <Border Grid.Row="2" Background="#FF2D2D30" Padding="15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" x:Name="UninstallButton" Content="Desinstalar Kiosk" Width="150" Padding="8" Background="#DA3030" Foreground="White" BorderThickness="0" Click="UninstallButton_Click" />
                
                <Button Grid.Column="2" x:Name="CancelButton" Content="Cancelar" Width="120" Padding="8" Background="#FF555555" Foreground="White" BorderThickness="0" Click="CloseButton_Click" IsCancel="True" Margin="0,0,10,0" />
                <Button Grid.Column="3" x:Name="SaveButton" Content="Guardar" Width="120" Padding="8" Background="#FF007ACC" Foreground="White" BorderThickness="0" Click="SaveButton_Click" IsDefault="True" />
            </Grid>
        </Border>
    </Grid>

</Window>