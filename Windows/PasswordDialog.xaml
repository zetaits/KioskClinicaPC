<Window x:Class="KioskClinicaPC.PasswordDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Acceso Restringido" 
        Height="220" Width="400"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="#FF0A0716"
        Foreground="White"
        FontFamily="{StaticResource SpaceGrotesk}"
        BorderBrush="#FFF37A4A"
        BorderThickness="1">
    <Grid Margin="24">
        <StackPanel VerticalAlignment="Center">
            <TextBlock Text="🔒 Acceso Restringido"
                       FontSize="18" FontWeight="Bold"
                       Foreground="White"
                       Margin="0,0,0,4"/>
            <TextBlock Text="Introduce la contraseña de administrador:"
                       FontSize="13"
                       Foreground="#FF8888AA"
                       TextWrapping="Wrap"
                       Margin="0,0,0,14"/>
            
            <PasswordBox x:Name="PasswordInput"
                         FontSize="16"
                         Style="{StaticResource ConfigPasswordBox}"
                         KeyDown="PasswordInput_KeyDown"/>
            
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                <Button x:Name="OkButton" Content="Aceptar"
                        Style="{StaticResource PrimaryButton}"
                        Padding="20,10"
                        Click="OkButton_Click" IsDefault="True" Margin="0,0,10,0"/>
                <Button x:Name="CancelButton" Content="Cancelar"
                        Style="{StaticResource SecondaryButton}"
                        Padding="20,10"
                        IsCancel="True"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>