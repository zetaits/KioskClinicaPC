<Window x:Class="KioskClinicaPC.PasswordDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Acceso Restringido" 
        Height="200" Width="350"
        WindowStartupLocation="CenterScreen"
        WindowStyle="ToolWindow"
        Background="#FF1E1E1E"
        Foreground="White"
        FontFamily="Segoe UI Light">
    <Grid Margin="20">
        <StackPanel VerticalAlignment="Center">
            <TextBlock Text="Por favor, introduce la contraseña de administrador:"
                       FontSize="14"
                       Foreground="#FFCCCCCC"
                       TextWrapping="Wrap"
                       Margin="0,0,0,10"/>
            
            <PasswordBox x:Name="PasswordInput"
                         FontSize="16"
                         Background="#FF333333"
                         Foreground="White"
                         BorderThickness="0"
                         Padding="5"
                         KeyDown="PasswordInput_KeyDown"/>
            
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button x:Name="OkButton" Content="Aceptar"
                        Width="100" Padding="5" Margin="0,0,10,0"
                        Background="#FF007ACC" Foreground="White" BorderThickness="0"
                        Click="OkButton_Click" IsDefault="True"/>
                <Button x:Name="CancelButton" Content="Cancelar"
                        Width="100" Padding="5"
                        Background="#FF555555" Foreground="White" BorderThickness="0"
                        IsCancel="True"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>