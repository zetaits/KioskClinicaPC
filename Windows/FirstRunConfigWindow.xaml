<Window x:Class="KioskClinicaPC.Windows.FirstRunConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Configuración Inicial" 
        Height="350" Width="450"
        WindowStartupLocation="CenterScreen"
        Background="#FF1E1E1E"
        Foreground="White"
        FontFamily="Segoe UI Light"
        WindowStyle="None"
        ResizeMode="NoResize"
        BorderBrush="#FF007ACC" 
        BorderThickness="1">
    
    <Grid Margin="25">
        <StackPanel VerticalAlignment="Center">
            <TextBlock Text="Configuración Inicial del Kiosco"
                       FontSize="22" FontWeight="SemiBold"
                       Foreground="#FFCCCCCC" Margin="0,0,0,20"/>
            
            <TextBlock Text="Precio del Equipo (ej: 1.299 €):"
                       FontSize="14" Margin="0,0,0,5"/>
            
            <TextBox x:Name="PriceTextBox"
                     FontSize="18"
                     Background="#FF333333"
                     Foreground="White"
                     BorderThickness="0"
                     Padding="8"/>

            <TextBlock Text="Precio con Descuento (Opcional):"
                       FontSize="14" Margin="0,15,0,5"/>
            
            <TextBox x:Name="DiscountedPriceTextBox"
                     FontSize="18"
                     Background="#FF333333"
                     Foreground="White"
                     BorderThickness="0"
                     Padding="8"/>
            
            <TextBlock x:Name="ErrorText"
                       Text="El precio principal es obligatorio."
                       FontSize="14"
                       Foreground="#DA3030"
                       Margin="0,15,0,0"
                       Visibility="Collapsed"/>
            
            <Button x:Name="SaveButton" Content="Guardar y Continuar"
                    Width="180" Padding="8" Margin="0,20,0,0"
                    HorizontalAlignment="Right"
                    Background="#FF007ACC" Foreground="White" BorderThickness="0"
                    Click="SaveButton_Click" IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>