<Window x:Class="KioskClinicaPC.Windows.FirstRunConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Configuración Inicial"
        Height="660" Width="560"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource Bg0Brush}"
        Foreground="White"
        FontFamily="{StaticResource SpaceGrotesk}"
        WindowStyle="None"
        ResizeMode="NoResize"
        BorderBrush="{StaticResource CyanBrush}"
        BorderThickness="1">

    <Window.Resources>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource JetBrainsMono}"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Foreground" Value="{StaticResource Text2Brush}"/>
            <Setter Property="Margin" Value="2,0,0,7"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Height="76">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="{StaticResource Bg1Color}" Offset="0"/>
                    <GradientStop Color="{StaticResource Bg2Color}" Offset="1"/>
                </LinearGradientBrush>
            </Grid.Background>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="28,0,0,0">
                <Border Width="42" Height="42" CornerRadius="11" Margin="0,0,16,0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="{StaticResource CyanColor}" Offset="0"/>
                            <GradientStop Color="{StaticResource MagentaColor}" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Effect>
                        <DropShadowEffect Color="{StaticResource CyanColor}" BlurRadius="16" ShadowDepth="0" Opacity="0.6"/>
                    </Border.Effect>
                    <TextBlock Text="⚡" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Configuración inicial" FontFamily="{StaticResource ChakraPetch}"
                               FontSize="22" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="Define el precio y el estado del equipo para empezar."
                               FontSize="12" Foreground="{StaticResource Text2Brush}" Margin="0,2,0,0"/>
                </StackPanel>
            </StackPanel>
            <Border Height="1" VerticalAlignment="Bottom" Background="{StaticResource Line1Brush}"/>
        </Grid>

        <!-- Content -->
        <StackPanel Grid.Row="1" Margin="28,24,28,8">

            <!-- Precios -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Style="{StaticResource FieldLabel}" Text="PRECIO DEL EQUIPO"/>
                    <TextBox x:Name="PriceTextBox" Style="{StaticResource ConfigTextBox}" FontSize="18" Padding="12,11"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Style="{StaticResource FieldLabel}" Text="PRECIO CON DESCUENTO · OPCIONAL"/>
                    <TextBox x:Name="DiscountedPriceTextBox" Style="{StaticResource ConfigTextBox}" FontSize="18" Padding="12,11"/>
                </StackPanel>
            </Grid>

            <!-- Estado -->
            <TextBlock Style="{StaticResource FieldLabel}" Text="ESTADO DEL EQUIPO" Margin="2,22,0,7"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <RadioButton x:Name="NewRadio" Grid.Column="0" Style="{StaticResource ChoiceCard}" GroupName="Condition"
                             Content="Nuevo" Tag="3 años de garantía"/>
                <RadioButton x:Name="UsedRadio" Grid.Column="2" Style="{StaticResource ChoiceCard}" GroupName="Condition"
                             Content="De ocasión" Tag="1 año · sello reacondicionado" IsChecked="True"/>
            </Grid>

            <TextBlock x:Name="ErrorText"
                       Text="El precio principal es obligatorio."
                       FontSize="13" Foreground="#FFFF6B6B" Margin="2,16,0,0"
                       Visibility="Collapsed"/>
        </StackPanel>

        <!-- Footer -->
        <Border Grid.Row="2" Background="{StaticResource Bg1Brush}" Padding="28,16">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="SaveButton" Content="Guardar y continuar  →"
                        Style="{StaticResource PrimaryButton}"
                        Click="SaveButton_Click" IsDefault="True"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
