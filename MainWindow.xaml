<Window x:Class="KioskClinicaPC.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:KioskClinicaPC"
        xmlns:core="clr-namespace:KioskClinicaPC.Core"
        xmlns:edit="clr-namespace:KioskClinicaPC.Controls"
        mc:Ignorable="d"
        Title="KioskClinicaPC"
        Foreground="{StaticResource Text0Brush}"
        FontFamily="{StaticResource SpaceGrotesk}"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowState="Maximized"
        Topmost="True"
        Loaded="Window_Loaded"
        Closing="Window_Closing"
        KeyDown="Window_KeyDown"
        PreviewMouseLeftButtonDown="Window_PreviewMouseLeftButtonDown"
        PreviewMouseDown="Window_PreviewActivity"
        PreviewTouchDown="Window_PreviewTouchActivity"
        Background="Black">
    
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <core:LeftMarginConverter x:Key="LeftMarginConverter"/>
        <core:StringToBrushConverter x:Key="StringBrushConverter"/>
        <core:PathToImageConverter x:Key="PathToImage"/>
        <core:OptionalPathToImageConverter x:Key="OptionalImage"/>
        <core:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis"/>
        
        <Style TargetType="TextBlock" x:Key="DisplayFont">
            <Setter Property="FontFamily" Value="{StaticResource ChakraPetch}"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="MonoFont">
            <Setter Property="FontFamily" Value="{StaticResource JetBrainsMono}"/>
        </Style>
    </Window.Resources>

    <!-- Fondo ambiente (no negro) para que las bandas de letterbox en paneles no 16:9 no sean
         vacíos negros, sino que se fundan con el fondo de la app. -->
    <Grid x:Name="WindowRoot" Background="{StaticResource Bg0Brush}">
    <Viewbox Stretch="Uniform" StretchDirection="Both" UseLayoutRounding="True" SnapsToDevicePixels="True">
        <Grid x:Name="RootGrid" Width="1920" Height="1080" ClipToBounds="True" Background="{StaticResource Bg0Brush}"
              TextOptions.TextFormattingMode="Ideal" TextOptions.TextRenderingMode="ClearType"
              RenderOptions.BitmapScalingMode="HighQuality">
            
            <!-- ================= AMBIENT BACKGROUNDS ================= -->
            <!-- Fondo estático (5 gradientes radiales pantalla completa + rejilla tileada). Nunca cambia,
                 así que se rasteriza una sola vez con BitmapCache: en render por software estos gradientes
                 se recomponían en CPU en cada invalidación. Cacheado = se paga una vez. -->
            <Grid IsHitTestVisible="False" CacheMode="BitmapCache">
                <!-- bg-mesh (orden CSS: el lineal es el fondo y los radiales van ENCIMA). En WPF lo
                     último se pinta arriba, así que el lineal va PRIMERO; antes iba el último y tapaba
                     (opaco) los radiales cálidos → fondo plano y oscuro. -->
                <!-- linear-gradient(180deg, bg-0, bg-1 55%, #07050f) — base -->
                <Rectangle>
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="{StaticResource Bg0Color}" Offset="0"/>
                            <GradientStop Color="{StaticResource Bg1Color}" Offset="0.55"/>
                            <GradientStop Color="#07050f" Offset="1"/>
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>
                <!-- radial-gradient(70% 55% at 82% 12%, magenta 24%, transparent 65%) -->
                <Rectangle Opacity="0.24">
                    <Rectangle.Fill>
                        <RadialGradientBrush Center="0.82,0.12" GradientOrigin="0.82,0.12" RadiusX="0.70" RadiusY="0.55">
                            <GradientStop Color="{StaticResource MagentaColor}" Offset="0"/>
                            <!-- Fade a alpha-0 del MISMO color (#00FFB069), no a Transparent (#00FFFFFF):
                                 WPF interpola sin premultiplicar → amber→transparent-blanco pasa por grises
                                 lechosos (halo blanco lechoso). Mismo hue con alpha 0 = desvanecido limpio. -->
                            <GradientStop Color="#00FFB069" Offset="0.65"/>
                        </RadialGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>
                <!-- radial-gradient(65% 50% at 12% 92%, cyan 30%, transparent 65%) -->
                <Rectangle Opacity="0.30">
                    <Rectangle.Fill>
                        <RadialGradientBrush Center="0.12,0.92" GradientOrigin="0.12,0.92" RadiusX="0.65" RadiusY="0.50">
                            <GradientStop Color="{StaticResource CyanColor}" Offset="0"/>
                            <GradientStop Color="#00F37A4A" Offset="0.65"/>
                        </RadialGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>
                <!-- radial-gradient(55% 45% at 50% 55%, deep warm 34%, transparent 70%) -->
                <Rectangle Opacity="0.34">
                    <Rectangle.Fill>
                        <RadialGradientBrush Center="0.50,0.55" GradientOrigin="0.50,0.55" RadiusX="0.55" RadiusY="0.45">
                            <GradientStop Color="#CC3D00" Offset="0"/>
                            <GradientStop Color="#00CC3D00" Offset="0.70"/>
                        </RadialGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>
                <!-- radial-gradient(45% 40% at 95% 78%, purple 60%, transparent 70%) -->
                <Rectangle Opacity="0.60">
                    <Rectangle.Fill>
                        <RadialGradientBrush Center="0.95,0.78" GradientOrigin="0.95,0.78" RadiusX="0.45" RadiusY="0.40">
                            <GradientStop Color="#331A66" Offset="0"/>
                            <GradientStop Color="#00331A66" Offset="0.70"/>
                        </RadialGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>

                <!-- bg-grid: 80px tiles with radial mask -->
                <Rectangle Opacity="0.05">
                    <Rectangle.OpacityMask>
                        <RadialGradientBrush Center="0.5,0.5" RadiusX="0.45" RadiusY="0.35">
                            <GradientStop Color="Black" Offset="0.3"/>
                            <GradientStop Color="Transparent" Offset="0.8"/>
                        </RadialGradientBrush>
                    </Rectangle.OpacityMask>
                    <Rectangle.Fill>
                        <DrawingBrush Viewport="0,0,80,80" ViewportUnits="Absolute" TileMode="Tile">
                            <DrawingBrush.Drawing>
                                <DrawingGroup>
                                    <GeometryDrawing>
                                        <GeometryDrawing.Pen>
                                            <Pen Brush="White" Thickness="1"/>
                                        </GeometryDrawing.Pen>
                                        <GeometryDrawing.Geometry>
                                            <GeometryGroup>
                                                <LineGeometry StartPoint="0,0" EndPoint="80,0"/>
                                                <LineGeometry StartPoint="0,0" EndPoint="0,80"/>
                                            </GeometryGroup>
                                        </GeometryDrawing.Geometry>
                                    </GeometryDrawing>
                                </DrawingGroup>
                            </DrawingBrush.Drawing>
                        </DrawingBrush>
                    </Rectangle.Fill>
                </Rectangle>

                <!-- bg-grid fine: 16px sub-grid -->
                <Rectangle Opacity="0.03">
                    <Rectangle.OpacityMask>
                        <RadialGradientBrush Center="0.5,0.5" RadiusX="0.45" RadiusY="0.35">
                            <GradientStop Color="Black" Offset="0.3"/>
                            <GradientStop Color="Transparent" Offset="0.8"/>
                        </RadialGradientBrush>
                    </Rectangle.OpacityMask>
                    <Rectangle.Fill>
                        <DrawingBrush Viewport="0,0,16,16" ViewportUnits="Absolute" TileMode="Tile">
                            <DrawingBrush.Drawing>
                                <DrawingGroup>
                                    <GeometryDrawing>
                                        <GeometryDrawing.Pen>
                                            <Pen Brush="White" Thickness="1"/>
                                        </GeometryDrawing.Pen>
                                        <GeometryDrawing.Geometry>
                                            <GeometryGroup>
                                                <LineGeometry StartPoint="0,0" EndPoint="16,0"/>
                                                <LineGeometry StartPoint="0,0" EndPoint="0,16"/>
                                            </GeometryGroup>
                                        </GeometryDrawing.Geometry>
                                    </GeometryDrawing>
                                </DrawingGroup>
                            </DrawingBrush.Drawing>
                        </DrawingBrush>
                    </Rectangle.Fill>
                </Rectangle>

                <!-- bg-scanlines: repeating 4px horizontal lines -->
                <Rectangle Opacity="0.025">
                    <Rectangle.Fill>
                        <DrawingBrush Viewport="0,0,10,4" ViewportUnits="Absolute" TileMode="Tile">
                            <DrawingBrush.Drawing>
                                <GeometryDrawing Brush="White">
                                    <GeometryDrawing.Geometry>
                                        <RectangleGeometry Rect="0,2,10,1"/>
                                    </GeometryDrawing.Geometry>
                                </GeometryDrawing>
                            </DrawingBrush.Drawing>
                        </DrawingBrush>
                    </Rectangle.Fill>
                </Rectangle>

                <!-- bg-noise eliminado: añadía grano blanco aditivo en toda la pantalla (efecto "niebla
                     blanca"). El mockup (base.css) no lleva capa de ruido, solo grid + scanlines. -->

                <!-- bg-vignette eliminado (feedback v4 sesión 2): radios 0.40/0.35 dibujaban óvalo oscuro
                     en lugar de oscurecer esquinas. Visible en todas las pantallas. Comentado por si se
                     quiere restaurar con radios mayores (RadiusX/Y >= 0.80) y opacidad menor.
                <Rectangle>
                    <Rectangle.Fill>
                        <RadialGradientBrush Center="0.5,0.5" GradientOrigin="0.5,0.5" RadiusX="0.40" RadiusY="0.35">
                            <GradientStop Color="Transparent" Offset="0.50"/>
                            <GradientStop Color="#D9000000" Offset="1"/>
                        </RadialGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>
                -->


            </Grid>

            <!-- Capa de partículas: FUERA del Grid con BitmapCache. Si va dentro, su animación continua
                 (Canvas.Top/Opacity) re-rasteriza el caché del fondo cada frame; las líneas de 1px del
                 grid resamplean distinto en cada frame bajo el escalado fraccionario del Viewbox y el
                 fondo "tiembla" al animarse cualquier cosa (p.ej. al cambiar de spec). Fuera del caché,
                 el fondo se rasteriza una sola vez = source estable = sin shimmer. -->
            <Canvas x:Name="ParticleCanvas" IsHitTestVisible="False"/>

            <!-- Deriva ambiental: blob radial naranja difuminado que se desplaza muy lento (~26 s) para
                 dar movimiento continuo de fondo. NO va dentro del Grid cacheado estático (ese se
                 rasteriza una vez y no debe moverse). El degradado suave evita BlurEffect animado;
                 BitmapCache propio + animar solo el TranslateTransform = barato. Arranque y gating
                 (GraphicsQuality.IsLow) en Window_Loaded. -->
            <Grid x:Name="DriftLayer" IsHitTestVisible="False">
                <Ellipse Width="1300" Height="800" HorizontalAlignment="Center" VerticalAlignment="Center"
                         Opacity="0.42" RenderTransformOrigin="0.5,0.5" CacheMode="BitmapCache">
                    <Ellipse.RenderTransform>
                        <TranslateTransform x:Name="DriftTransform"/>
                    </Ellipse.RenderTransform>
                    <Ellipse.Fill>
                        <RadialGradientBrush Center="0.5,0.5" GradientOrigin="0.5,0.5" RadiusX="0.5" RadiusY="0.5">
                            <GradientStop Color="#80F37A4A" Offset="0"/>
                            <GradientStop Color="#00F37A4A" Offset="0.72"/>
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                </Ellipse>
            </Grid>

            <!-- ================= SCREENS ================= -->
            <Grid x:Name="ScreensContainer">
                
                <!-- ====== SCREEN 0: ATTRACT ====== -->
                <Grid x:Name="Screen0_Attract" Visibility="Visible" Opacity="1">
                    <Grid.Background>
                        <SolidColorBrush Color="Transparent"/>
                    </Grid.Background>
                    
                    <Rectangle Fill="Transparent" MouseLeftButtonDown="AttractScreen_Click" />

                    <!-- Wireframe orb behind text (monochrome orange, sphere-like).
                         En reposo: quieto, normal (lo de siempre). Cada cierto tiempo se dispara un
                         "episodio" (PlayOrbEpisode): se encoge un poco, se vuelve más tenue/fina y da
                         una vuelta, luego vuelve a reposo. Giro continuo descartado (mareaba). -->
                    <!-- Opacidad de reposo 0.32 (como el mockup: orbe fino y tenue, no la malla
                         brillante saturada que tapaba el fondo). El episodio la atenúa aún más. -->
                    <Viewbox x:Name="AttractOrb" Width="1480" Height="1480" HorizontalAlignment="Center" VerticalAlignment="Center"
                             Margin="0,-60,0,0" Opacity="0.32" IsHitTestVisible="False">
                        <!-- Centro de giro/escala SOLO vía CenterX/Y=50 (centro del canvas 100×100).
                             Antes había también RenderTransformOrigin="0.5,0.5" → doble centrado: el centro
                             efectivo caía en ~(100,100), y escalado ×14.8 el orbe orbitaba un punto fuera de
                             pantalla en vez de rotar sobre sí mismo. -->
                        <Canvas Width="100" Height="100">
                            <Canvas.Effect>
                                <DropShadowEffect Color="{StaticResource CyanColor}" BlurRadius="22"
                                                  ShadowDepth="0" Opacity="0.5"/>
                            </Canvas.Effect>
                            <Canvas.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform x:Name="AttractOrbScale" CenterX="50" CenterY="50"/>
                                    <RotateTransform x:Name="AttractOrbTransform" CenterX="50" CenterY="50"/>
                                </TransformGroup>
                            </Canvas.RenderTransform>

                            <!-- Outer ring -->
                            <Ellipse Canvas.Left="2" Canvas.Top="2" Width="96" Height="96"
                                     Stroke="{StaticResource CyanBrush}" StrokeThickness="0.28" Fill="Transparent"/>

                            <!-- Latitudes (top half) -->
                            <Ellipse Canvas.Left="2" Canvas.Top="3.0"  Width="96" Height="91.2" Stroke="{StaticResource CyanBrush}" StrokeThickness="0.22" Fill="Transparent" Opacity="0.85"/>
                            <Ellipse Canvas.Left="2" Canvas.Top="6.5"  Width="96" Height="84.6" Stroke="{StaticResource CyanBrush}" StrokeThickness="0.22" Fill="Transparent" Opacity="0.80"/>
                            <Ellipse Canvas.Left="2" Canvas.Top="10.5" Width="96" Height="76.4" Stroke="{StaticResource CyanBrush}" StrokeThickness="0.22" Fill="Transparent" Opacity="0.75"/>
                            <Ellipse Canvas.Left="2" Canvas.Top="15.0" Width="96" Height="67.0" Stroke="{StaticResource CyanBrush}" StrokeThickness="0.22" Fill="Transparent" Opacity="0.70"/>
                            <Ellipse Canvas.Left="2" Canvas.Top="19.5" Width="96" Height="56.0" Stroke="{StaticResource CyanBrush}" StrokeThickness="0.22" Fill="Transparent" Opacity="0.65"/>
                            <Ellipse Canvas.Left="2" Canvas.Top="24.5" Width="96" Height="44.0" Stroke="{StaticResource CyanBrush}" StrokeThickness="0.22" Fill="Transparent" Opacity="0.60"/>
                            <Ellipse Canvas.Left="2" Canvas.Top="30.0" Width="96" Height="30.0" Stroke="{StaticResource CyanBrush}" StrokeThickness="0.22" Fill="Transparent" Opacity="0.55"/>
                            <Ellipse Canvas.Left="2" Canvas.Top="36.0" Width="96" Height="16.0" Stroke="{StaticResource CyanBrush}" StrokeThickness="0.22" Fill="Transparent" Opacity="0.50"/>

                            <!-- Equator (refuerzo) -->
                            <Ellipse Canvas.Left="2" Canvas.Top="49.5" Width="96" Height="1.0" Stroke="{StaticResource CyanBrush}" StrokeThickness="0.32" Fill="Transparent" Opacity="1.0"/>

                            <!-- Latitudes (bottom half, mirror) -->
                            <Ellipse Canvas.Left="2" Canvas.Top="48.0" Width="96" Height="16.0" Stroke="{StaticResource CyanBrush}" StrokeThickness="0.22" Fill="Transparent" Opacity="0.50"/>
                            <Ellipse Canvas.Left="2" Canvas.Top="40.0" Width="96" Height="30.0" Stroke="{StaticResource CyanBrush}" StrokeThickness="0.22" Fill="Transparent" Opacity="0.55"/>
                            <Ellipse Canvas.Left="2" Canvas.Top="33.5" Width="96" Height="44.0" Stroke="{StaticResource CyanBrush}" StrokeThickness="0.22" Fill="Transparent" Opacity="0.60"/>
                            <Ellipse Canvas.Left="2" Canvas.Top="27.0" Width="96" Height="56.0" Stroke="{StaticResource CyanBrush}" StrokeThickness="0.22" Fill="Transparent" Opacity="0.65"/>
                            <Ellipse Canvas.Left="2" Canvas.Top="21.5" Width="96" Height="67.0" Stroke="{StaticResource CyanBrush}" StrokeThickness="0.22" Fill="Transparent" Opacity="0.70"/>
                            <Ellipse Canvas.Left="2" Canvas.Top="16.5" Width="96" Height="76.4" Stroke="{StaticResource CyanBrush}" StrokeThickness="0.22" Fill="Transparent" Opacity="0.75"/>
                            <Ellipse Canvas.Left="2" Canvas.Top="11.5" Width="96" Height="84.6" Stroke="{StaticResource CyanBrush}" StrokeThickness="0.22" Fill="Transparent" Opacity="0.80"/>
                            <Ellipse Canvas.Left="2" Canvas.Top="7.0"  Width="96" Height="91.2" Stroke="{StaticResource CyanBrush}" StrokeThickness="0.22" Fill="Transparent" Opacity="0.85"/>

                            <!-- Longitudes (vertical ellipses) -->
                            <Ellipse Canvas.Left="49.5" Canvas.Top="2" Width="1.0"  Height="96" Stroke="{StaticResource CyanBrush}" StrokeThickness="0.32" Fill="Transparent" Opacity="0.95"/>
                            <Ellipse Canvas.Left="46"   Canvas.Top="2" Width="8"    Height="96" Stroke="{StaticResource CyanBrush}" StrokeThickness="0.18" Fill="Transparent" Opacity="0.70"/>
                            <Ellipse Canvas.Left="42"   Canvas.Top="2" Width="16"   Height="96" Stroke="{StaticResource CyanBrush}" StrokeThickness="0.18" Fill="Transparent" Opacity="0.65"/>
                            <Ellipse Canvas.Left="37"   Canvas.Top="2" Width="26"   Height="96" Stroke="{StaticResource CyanBrush}" StrokeThickness="0.18" Fill="Transparent" Opacity="0.60"/>
                            <Ellipse Canvas.Left="31"   Canvas.Top="2" Width="38"   Height="96" Stroke="{StaticResource CyanBrush}" StrokeThickness="0.18" Fill="Transparent" Opacity="0.55"/>
                            <Ellipse Canvas.Left="24"   Canvas.Top="2" Width="52"   Height="96" Stroke="{StaticResource CyanBrush}" StrokeThickness="0.18" Fill="Transparent" Opacity="0.50"/>
                            <Ellipse Canvas.Left="16"   Canvas.Top="2" Width="68"   Height="96" Stroke="{StaticResource CyanBrush}" StrokeThickness="0.18" Fill="Transparent" Opacity="0.45"/>
                            <Ellipse Canvas.Left="8"    Canvas.Top="2" Width="84"   Height="96" Stroke="{StaticResource CyanBrush}" StrokeThickness="0.18" Fill="Transparent" Opacity="0.40"/>
                        </Canvas>
                    </Viewbox>

                    <!-- Vignette interior eliminado (feedback v4): dibujaba "halo ovalado" gris en el centro.
                         Conservado comentado por si hace falta restaurar.
                    <Rectangle IsHitTestVisible="False" Opacity="0.85">
                        <Rectangle.Fill>
                            <RadialGradientBrush Center="0.5,0.5" GradientOrigin="0.5,0.5" RadiusX="0.32" RadiusY="0.26">
                                <GradientStop Color="#E6000000" Offset="0"/>
                                <GradientStop Color="#73000000" Offset="0.55"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </RadialGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>
                    -->


                    <!-- Center content (eyebrow + 2 titles + subtitle + CTA + hint, all flowing) -->
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="{Binding EditMode.IsActive}" MaxWidth="1760" MaxHeight="940">
                        <!-- Eyebrow with line decorations -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,28">
                            <Rectangle Width="28" Height="1" Fill="{StaticResource CyanBrush}" VerticalAlignment="Center" Margin="0,0,14,0"/>
                            <TextBlock Text="{Binding CurrentSlide.Eyebrow}" Style="{StaticResource MonoFont}" Foreground="{StaticResource CyanBrush}" FontSize="18"/>
                            <Rectangle Width="28" Height="1" Fill="{StaticResource CyanBrush}" VerticalAlignment="Center" Margin="14,0,0,0"/>
                        </StackPanel>

                        <!-- 168px titles: auto-encogen a una caja fija para que el slide más largo no empuje el CTA al borde -->
                        <Viewbox StretchDirection="DownOnly" Stretch="Uniform" HorizontalAlignment="Center" MaxWidth="1280" MaxHeight="360" Margin="0,0,0,12">
                          <TextBlock Text="{Binding CurrentSlide.Title1}" Style="{StaticResource DisplayFont}" FontSize="168" Foreground="{StaticResource Text0Brush}" TextAlignment="Center" LineHeight="160" LineStackingStrategy="BlockLineHeight" TextWrapping="Wrap" Width="1280"/>
                        </Viewbox>

                        <!-- Title 2 — wraps to ~3 lines (matches mockup), clean orange neon (no chromatic glitch) -->
                        <Viewbox StretchDirection="DownOnly" Stretch="Uniform" HorizontalAlignment="Center" MaxWidth="1280" MaxHeight="360">
                        <Grid HorizontalAlignment="Center">
                            <!-- Neon core layer (tight blur, dense) -->
                            <TextBlock Text="{Binding CurrentSlide.Title2}" edit:Editable.IsOn="False" Style="{StaticResource DisplayFont}" FontSize="168" Foreground="{StaticResource CyanBrush}" TextAlignment="Center" LineHeight="160" LineStackingStrategy="BlockLineHeight" TextWrapping="Wrap" Width="1280" Opacity="0.6">
                                <TextBlock.Effect>
                                    <DropShadowEffect Color="{StaticResource CyanColor}" BlurRadius="16" ShadowDepth="0" Opacity="1"/>
                                </TextBlock.Effect>
                            </TextBlock>
                            <!-- Base title (wide halo) — gradient vertical: melocotón → naranja → dorado (feedback v4) -->
                            <TextBlock Text="{Binding CurrentSlide.Title2}" Style="{StaticResource DisplayFont}" FontSize="168" TextAlignment="Center" LineHeight="160" LineStackingStrategy="BlockLineHeight" TextWrapping="Wrap" Width="1280">
                                <TextBlock.Foreground>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#FF8C6E" Offset="0"/>
                                        <GradientStop Color="#F37A4A" Offset="0.45"/>
                                        <GradientStop Color="#FFC857" Offset="1"/>
                                    </LinearGradientBrush>
                                </TextBlock.Foreground>
                                <TextBlock.Effect>
                                    <DropShadowEffect Color="{StaticResource CyanColor}" BlurRadius="48" ShadowDepth="0" Opacity="0.85"/>
                                </TextBlock.Effect>
                            </TextBlock>
                        </Grid>
                        </Viewbox>

                        <!-- Subtitle -->
                        <TextBlock Text="{Binding CurrentSlide.Subtitle}" edit:Editable.Multiline="True" Foreground="{StaticResource Text1Brush}" FontSize="24" TextAlignment="Center" Margin="0,38,0,0" MaxWidth="1100" TextWrapping="Wrap"/>

                        <!-- CTA Button (HUD bracket-corner style) -->
                        <Grid HorizontalAlignment="Center" Margin="0,48,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Border x:Name="PulseButton" Grid.Row="1" Grid.Column="1"
                                    Background="#10F37A4A" BorderBrush="{StaticResource CyanBrush}" BorderThickness="2"
                                    Padding="36,18">
                                <Border.Effect>
                                    <DropShadowEffect Color="{StaticResource CyanColor}" BlurRadius="24" ShadowDepth="0" Opacity="0.35"/>
                                </Border.Effect>
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="12" Height="12" Fill="{StaticResource CyanBrush}" VerticalAlignment="Center" Margin="0,0,16,0">
                                        <Ellipse.Effect>
                                            <DropShadowEffect Color="{StaticResource CyanColor}" BlurRadius="12" ShadowDepth="0" Opacity="0.9"/>
                                        </Ellipse.Effect>
                                    </Ellipse>
                                    <TextBlock Text="{Binding Texts[attract.cta]}" Style="{StaticResource DisplayFont}" Foreground="{StaticResource Text0Brush}" FontSize="22"/>
                                </StackPanel>
                                <Border.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <!-- Pulso solo por opacidad: animar BlurRadius forzaba re-rasterizar
                                                 la sombra entera cada frame (caro en iGPU). El cambio de opacidad
                                                 da el mismo latido visual sin recalcular el blur. -->
                                            <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                <DoubleAnimation Storyboard.TargetProperty="(Border.Effect).(DropShadowEffect.Opacity)" From="0.30" To="0.60" Duration="0:0:1.1"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Border.Triggers>
                            </Border>

                            <!-- 4 L-bracket corners -->
                            <Path Grid.Row="0" Grid.Column="0" Stroke="{StaticResource CyanBrush}" StrokeThickness="2"
                                  Data="M 0,14 L 0,0 L 14,0">
                                <Path.Effect><DropShadowEffect Color="{StaticResource CyanColor}" BlurRadius="6" ShadowDepth="0" Opacity="0.9"/></Path.Effect>
                            </Path>
                            <Path Grid.Row="0" Grid.Column="2" Stroke="{StaticResource CyanBrush}" StrokeThickness="2"
                                  Data="M 0,0 L 14,0 L 14,14">
                                <Path.Effect><DropShadowEffect Color="{StaticResource CyanColor}" BlurRadius="6" ShadowDepth="0" Opacity="0.9"/></Path.Effect>
                            </Path>
                            <Path Grid.Row="2" Grid.Column="0" Stroke="{StaticResource CyanBrush}" StrokeThickness="2"
                                  Data="M 0,0 L 0,14 L 14,14">
                                <Path.Effect><DropShadowEffect Color="{StaticResource CyanColor}" BlurRadius="6" ShadowDepth="0" Opacity="0.9"/></Path.Effect>
                            </Path>
                            <Path Grid.Row="2" Grid.Column="2" Stroke="{StaticResource CyanBrush}" StrokeThickness="2"
                                  Data="M 0,14 L 14,14 L 14,0">
                                <Path.Effect><DropShadowEffect Color="{StaticResource CyanColor}" BlurRadius="6" ShadowDepth="0" Opacity="0.9"/></Path.Effect>
                            </Path>
                        </Grid>
                        <TextBlock Text="{Binding Texts[attract.hint]}" Style="{StaticResource MonoFont}" Foreground="{StaticResource Text2Brush}" FontSize="16" HorizontalAlignment="Center" Margin="0,22,0,0"/>
                    </StackPanel>

                    <!-- Slide indicator dots -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,110" IsHitTestVisible="False">
                        <Rectangle x:Name="SlideDot0" Width="32" Height="4" Fill="{StaticResource CyanBrush}" Margin="0,0,10,0">
                            <Rectangle.Effect>
                                <DropShadowEffect Color="{StaticResource CyanColor}" BlurRadius="10" ShadowDepth="0" Opacity="0.8"/>
                            </Rectangle.Effect>
                        </Rectangle>
                        <Rectangle x:Name="SlideDot1" Width="8" Height="4" Fill="#33FFFFFF" Margin="0,0,10,0"/>
                        <Rectangle x:Name="SlideDot2" Width="8" Height="4" Fill="#33FFFFFF"/>
                    </StackPanel>
                </Grid>

                <!-- ====== SCREEN 1: SCAN ====== -->
                <Grid x:Name="Screen1_Scan" Visibility="Collapsed" Opacity="0">
                    <Grid>
                        <!-- Anillo de progreso del radar (0–100 %). Hermano del radar (no hijo) y en su
                             propio lienzo 820 holgado: si fuera hijo del radar (760), la grid menor lo
                             recortaría en los 4 cardinales (donde el aro, ~788, sobresale del 760). -->
                        <Grid Width="820" Height="820" HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False">
                            <Path x:Name="ScanProgressRing" Stroke="{StaticResource CyanBrush}" StrokeThickness="4"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round" Opacity="0.9">
                                <Path.Effect>
                                    <DropShadowEffect Color="{StaticResource CyanColor}" BlurRadius="8" ShadowDepth="0" Opacity="0.9"/>
                                </Path.Effect>
                            </Path>
                        </Grid>

                        <!-- Huge Radar (760×760, centro 380,380) — variación lock-on del mockup -->
                        <Grid Width="760" Height="760" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <!-- 5 anillos concéntricos (mockup inset 0/84/168/252/330) -->
                            <Ellipse Stroke="#4DF37A4A" StrokeThickness="1"/>
                            <Ellipse Stroke="#4DF37A4A" StrokeThickness="1" Margin="84"/>
                            <Ellipse Stroke="#4DF37A4A" StrokeThickness="1" Margin="168"/>
                            <Ellipse Stroke="#4DF37A4A" StrokeThickness="1" Margin="252"/>
                            <Ellipse Stroke="#4DF37A4A" StrokeThickness="1" Margin="330"/>
                            <!-- Crosshair lines -->
                            <Rectangle Height="1" Fill="#4DF37A4A" VerticalAlignment="Center"/>
                            <Rectangle Width="1" Fill="#4DF37A4A" HorizontalAlignment="Center"/>
                            <!-- Sweep: cuña que pivota en el centro (380,380). Endpoint (691.76,190) =
                                 centro + 380·(sin60,-cos60), exactamente en el círculo exterior. Gira a
                                 1.7 s/vuelta (arrancado en code-behind durante el escaneo). -->
                            <Path Fill="{StaticResource CyanBrush}" Opacity="0.42" Data="M 380 380 L 380 0 A 380 380 0 0 1 691.76 190 Z">
                                <Path.OpacityMask>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0.5">
                                        <GradientStop Color="#CCFFFFFF" Offset="0"/>
                                        <GradientStop Color="#55FFFFFF" Offset="0.55"/>
                                        <GradientStop Color="Transparent" Offset="1"/>
                                    </LinearGradientBrush>
                                </Path.OpacityMask>
                                <Path.RenderTransform>
                                    <RotateTransform x:Name="ScanRadarTransform" Angle="0" CenterX="380" CenterY="380"/>
                                </Path.RenderTransform>
                            </Path>
                            <!-- Center dot with heavy glow -->
                            <Ellipse Width="18" Height="18" Fill="{StaticResource CyanBrush}" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Ellipse.Effect>
                                    <DropShadowEffect Color="{StaticResource CyanColor}" BlurRadius="60" ShadowDepth="0" Opacity="1"/>
                                </Ellipse.Effect>
                            </Ellipse>

                            <!-- Blips + retículas lock-on, ligados a los componentes reales (RadarBlips).
                                 Cada ítem se posiciona en (X,Y); el blip hace ping continuo y la retícula
                                 se revela cuando IsDetected pasa a true (sincronizado con el log). -->
                            <ItemsControl ItemsSource="{Binding RadarBlips}" IsHitTestVisible="False">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate><Canvas/></ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemContainerStyle>
                                    <Style TargetType="ContentPresenter">
                                        <Setter Property="Canvas.Left" Value="{Binding X}"/>
                                        <Setter Property="Canvas.Top" Value="{Binding Y}"/>
                                    </Style>
                                </ItemsControl.ItemContainerStyle>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <!-- Canvas 0×0 anclado en (X,Y); todo se posiciona relativo al punto. -->
                                        <Canvas Width="0" Height="0">
                                            <!-- Anillo de ping (continuo). Escala 10→64px (×6.4) + fade.
                                                 El desfase por blip (Pd) lo aplica el handler Loaded. -->
                                            <Ellipse x:Name="PingRing" Canvas.Left="-5" Canvas.Top="-5" Width="10" Height="10"
                                                     Stroke="{StaticResource MagentaBrush}" StrokeThickness="1.5" Opacity="0"
                                                     RenderTransformOrigin="0.5,0.5"
                                                     Loaded="ScanPingRing_Loaded" Tag="{Binding PingDelaySeconds}">
                                                <Ellipse.RenderTransform><ScaleTransform/></Ellipse.RenderTransform>
                                            </Ellipse>
                                            <!-- Blip: ámbar; al detectarse pasa a naranja con glow fuerte. -->
                                            <Ellipse Canvas.Left="-5" Canvas.Top="-5" Width="10" Height="10">
                                                <Ellipse.Style>
                                                    <Style TargetType="Ellipse">
                                                        <Setter Property="Fill" Value="{StaticResource MagentaBrush}"/>
                                                        <Setter Property="Effect">
                                                            <Setter.Value>
                                                                <DropShadowEffect Color="{StaticResource MagentaColor}" BlurRadius="12" ShadowDepth="0"/>
                                                            </Setter.Value>
                                                        </Setter>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsDetected}" Value="True">
                                                                <Setter Property="Fill" Value="{StaticResource CyanBrush}"/>
                                                                <Setter Property="Effect">
                                                                    <Setter.Value>
                                                                        <DropShadowEffect Color="{StaticResource CyanColor}" BlurRadius="18" ShadowDepth="0" Opacity="1"/>
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Ellipse.Style>
                                            </Ellipse>
                                            <!-- Retícula lock-on: oculta hasta IsDetected; entra con scale 1.5→1 + fade. -->
                                            <Grid Canvas.Left="-29" Canvas.Top="-29" Width="58" Height="58" RenderTransformOrigin="0.5,0.5">
                                                <Grid.RenderTransform><ScaleTransform ScaleX="1" ScaleY="1"/></Grid.RenderTransform>
                                                <Grid.Style>
                                                    <Style TargetType="Grid">
                                                        <Setter Property="Opacity" Value="0"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsDetected}" Value="True">
                                                                <DataTrigger.EnterActions>
                                                                    <BeginStoryboard>
                                                                        <Storyboard>
                                                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.3"/>
                                                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" From="1.5" To="1" Duration="0:0:0.4">
                                                                                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                                                            </DoubleAnimation>
                                                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" From="1.5" To="1" Duration="0:0:0.4">
                                                                                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                                                            </DoubleAnimation>
                                                                        </Storyboard>
                                                                    </BeginStoryboard>
                                                                </DataTrigger.EnterActions>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Grid.Style>
                                                <!-- 4 brackets en L -->
                                                <Path Stroke="{Binding AccentBrush}" StrokeThickness="2" HorizontalAlignment="Left" VerticalAlignment="Top" Data="M 0,14 L 0,0 L 14,0"/>
                                                <Path Stroke="{Binding AccentBrush}" StrokeThickness="2" HorizontalAlignment="Right" VerticalAlignment="Top" Data="M 0,0 L 14,0 L 14,14"/>
                                                <Path Stroke="{Binding AccentBrush}" StrokeThickness="2" HorizontalAlignment="Left" VerticalAlignment="Bottom" Data="M 0,0 L 0,14 L 14,14"/>
                                                <Path Stroke="{Binding AccentBrush}" StrokeThickness="2" HorizontalAlignment="Right" VerticalAlignment="Bottom" Data="M 0,14 L 14,14 L 14,0"/>
                                                <!-- Icono del componente -->
                                                <Path Data="{Binding IconData}" Fill="{Binding AccentBrush}" Stretch="Uniform" Width="26" Height="26"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Grid>
                                            <!-- Tag "{Label} · OK". Dos variantes: derecha (normal) / izquierda (flip). -->
                                            <Border Canvas.Left="34" Canvas.Top="-13" Background="#B30A0716" BorderThickness="2,0,0,0"
                                                    BorderBrush="{Binding AccentBrush}" Padding="8,4"
                                                    Visibility="{Binding Flip, Converter={StaticResource InverseBoolToVis}}">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Opacity" Value="0"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsDetected}" Value="True">
                                                                <DataTrigger.EnterActions>
                                                                    <BeginStoryboard><Storyboard><DoubleAnimation Storyboard.TargetProperty="Opacity" To="1" BeginTime="0:0:0.15" Duration="0:0:0.3"/></Storyboard></BeginStoryboard>
                                                                </DataTrigger.EnterActions>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Style="{StaticResource MonoFont}" FontSize="15" Foreground="{StaticResource Text0Brush}" TextWrapping="NoWrap">
                                                    <Run Text="{Binding LabelUpper, Mode=OneWay}"/><Run Text=" · OK"/>
                                                </TextBlock>
                                            </Border>
                                            <Border Canvas.Right="34" Canvas.Top="-13" Background="#B30A0716" BorderThickness="0,0,2,0"
                                                    BorderBrush="{Binding AccentBrush}" Padding="8,4"
                                                    Visibility="{Binding Flip, Converter={StaticResource BoolToVis}}">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Opacity" Value="0"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsDetected}" Value="True">
                                                                <DataTrigger.EnterActions>
                                                                    <BeginStoryboard><Storyboard><DoubleAnimation Storyboard.TargetProperty="Opacity" To="1" BeginTime="0:0:0.15" Duration="0:0:0.3"/></Storyboard></BeginStoryboard>
                                                                </DataTrigger.EnterActions>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Style="{StaticResource MonoFont}" FontSize="15" Foreground="{StaticResource Text0Brush}" TextWrapping="NoWrap">
                                                    <Run Text="{Binding LabelUpper, Mode=OneWay}"/><Run Text=" · OK"/>
                                                </TextBlock>
                                            </Border>
                                        </Canvas>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>

                        <!-- Log area at bottom left -->
                        <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="120,0,0,120">
                            <TextBlock Text="{Binding Texts[scan.logTitle]}" Style="{StaticResource MonoFont}" FontSize="16" Foreground="{StaticResource CyanBrush}" Margin="0,0,0,16"/>
                            <ItemsControl x:Name="ScanLogControl" ItemsSource="{Binding ScanLogs}" Width="720">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="40"/>
                                                <ColumnDefinition Width="22"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Time}" edit:Editable.IsOn="False" Style="{StaticResource MonoFont}" Foreground="{StaticResource Text3Brush}" FontSize="18" Grid.Column="0"/>
                                            <!-- Icono del componente (solo en líneas READ con id). -->
                                            <Path Grid.Column="1" Data="{Binding IconData}" Fill="{Binding AccentBrush}" Stretch="Uniform"
                                                  Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                  Visibility="{Binding HasIcon, Converter={StaticResource BoolToVis}}"/>
                                            <TextBlock Text="{Binding Step}" edit:Editable.IsOn="False" Style="{StaticResource MonoFont}" Foreground="{Binding Color, Converter={StaticResource StringBrushConverter}}" FontSize="18" Grid.Column="2" Margin="8,0,0,0"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <!-- % counter at bottom right -->
                        <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="0,0,120,120">
                            <TextBlock Text="{Binding Texts[scan.progress]}" Style="{StaticResource MonoFont}" FontSize="16" Foreground="{StaticResource CyanBrush}" Margin="0,0,0,12" HorizontalAlignment="Right"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBlock x:Name="ScanProgressText" Text="000" edit:Editable.IsOn="False" Style="{StaticResource DisplayFont}" FontSize="220" Foreground="{StaticResource Text0Brush}" LineHeight="200"/>
                                <TextBlock Text="%" Style="{StaticResource DisplayFont}" FontSize="220" Foreground="{StaticResource CyanBrush}" LineHeight="200"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Grid>

                <!-- ====== SCREEN 2: MAIN HUD ====== -->
                <Grid x:Name="Screen2_Main" Visibility="Collapsed" Opacity="0" RenderTransformOrigin="0.5,0.5">
                    <Grid.RenderTransform>
                        <ScaleTransform x:Name="MainRevealScale" ScaleX="1" ScaleY="1"/>
                    </Grid.RenderTransform>

                    <!-- IDENTITY BLOCK — left column at top:180. Ancho 440 = deja hueco al spotlight (x=600). -->
                    <StackPanel HorizontalAlignment="Left" VerticalAlignment="Top" Width="440" Margin="120,180,0,0">
                      <!-- Marca del equipo: logo si existe (Brands\<marca>.png); si no, el texto de siempre.
                           DownOnly: nunca amplía el PNG (evita pixelado); solo encoge si no cabe. -->
                      <Image Source="{Binding BrandLogoPath, Converter={StaticResource OptionalImage}}"
                             Visibility="{Binding HasBrandLogo, Converter={StaticResource BoolToVis}}"
                             HorizontalAlignment="Left" Stretch="Uniform" StretchDirection="DownOnly"
                             MaxHeight="120" MaxWidth="440" Margin="0,0,0,12">
                        <Image.Effect>
                          <DropShadowEffect Color="{StaticResource CyanColor}" BlurRadius="22" ShadowDepth="0" Opacity="0.35"/>
                        </Image.Effect>
                      </Image>
                      <!-- Marca/Modelo detectados: auto-encogen si el nombre real es largo (no se cortan) -->
                      <Viewbox StretchDirection="DownOnly" Stretch="Uniform" HorizontalAlignment="Left" MaxWidth="440" Margin="0,0,0,10"
                               Visibility="{Binding HasBrandLogo, Converter={StaticResource InverseBoolToVis}}">
                        <TextBlock Style="{StaticResource DisplayFont}" FontSize="58" LineHeight="58" Foreground="{StaticResource Text0Brush}" Text="{Binding DisplayConfig.ChassisName}"/>
                      </Viewbox>
                      <Viewbox StretchDirection="DownOnly" Stretch="Uniform" HorizontalAlignment="Left" MaxWidth="440">
                        <TextBlock Style="{StaticResource DisplayFont}" FontSize="58" LineHeight="58" Foreground="{StaticResource CyanBrush}" Text="{Binding DisplayConfig.ModelName}">
                          <TextBlock.Effect>
                            <DropShadowEffect Color="{StaticResource CyanColor}" BlurRadius="24" ShadowDepth="0" Opacity="0.6"/>
                          </TextBlock.Effect>
                        </TextBlock>
                      </Viewbox>

                      <TextBlock Foreground="{StaticResource Text1Brush}" FontSize="18" Margin="0,24,0,0">
                        <Run Text="{Binding DisplayConfig.Family}"/><Run Text=" · "/><Run Text="SKU " Foreground="{StaticResource Text2Brush}"/><Run Text="{Binding DisplayConfig.Sku}" Foreground="{StaticResource Text2Brush}"/>
                      </TextBlock>
                    
                      <StackPanel Orientation="Horizontal" Margin="0,32,0,0">
                        <!-- Píldora de grado/reacondicionado: borde + tinte dorado, punto luminoso -->
                        <Border Background="#1FF0D26B" BorderBrush="{StaticResource OkBrush}" BorderThickness="1.5" CornerRadius="8" Padding="14,11" Margin="0,0,12,0"
                                Visibility="{Binding ShowRefurbished, Converter={StaticResource BoolToVis}}">
                          <StackPanel Orientation="Horizontal">
                            <Ellipse Width="11" Height="11" Fill="{StaticResource OkBrush}" VerticalAlignment="Center" Margin="0,0,10,0">
                                <Ellipse.Effect>
                                    <DropShadowEffect Color="{StaticResource OkColor}" BlurRadius="12" ShadowDepth="0" Opacity="0.9"/>
                                </Ellipse.Effect>
                            </Ellipse>
                            <TextBlock Text="{Binding Texts[hud.badgeGrade]}" Style="{StaticResource MonoFont}" FontSize="18" FontWeight="Medium" Foreground="{StaticResource OkBrush}"/>
                          </StackPanel>
                        </Border>
                        <!-- Píldora de garantía: borde + tinte ámbar, icono de escudo -->
                        <Border Background="#1FFFA75C" BorderBrush="{StaticResource AmberBrush}" BorderThickness="1.5" CornerRadius="8" Padding="14,11">
                          <StackPanel Orientation="Horizontal">
                            <Path Data="M 12,2 L 21,5 L 21,11 C 21,16.5 17,20.5 12,22 C 7,20.5 3,16.5 3,11 L 3,5 Z M 10.5,14.5 L 8,12 L 9.4,10.6 L 10.5,11.7 L 14.6,7.6 L 16,9 Z"
                                  Fill="{StaticResource AmberBrush}" Stretch="Uniform" Width="20" Height="20" VerticalAlignment="Center" Margin="0,0,10,0">
                                <Path.Effect>
                                    <DropShadowEffect Color="{StaticResource AmberColor}" BlurRadius="12" ShadowDepth="0" Opacity="0.8"/>
                                </Path.Effect>
                            </Path>
                            <TextBlock Text="{Binding WarrantyText}" edit:Editable.IsOn="False" Style="{StaticResource MonoFont}" FontSize="18" FontWeight="Medium" Foreground="{StaticResource AmberBrush}" VerticalAlignment="Center"/>
                          </StackPanel>
                        </Border>
                      </StackPanel>
                    </StackPanel>

                    <!-- Component spotlight (centre-top) — sigue al componente resaltado (ActiveSpec):
                         icono grande con glow + nombre + valor. Cambia al ritmo del ciclo de tiles. -->
                    <StackPanel HorizontalAlignment="Left" VerticalAlignment="Top" Width="780" Margin="600,150,0,0">
                        <TextBlock Text="{Binding Texts[hud.productView]}" Style="{StaticResource MonoFont}" FontSize="18" Foreground="{StaticResource Text2Brush}" Margin="0,0,0,14"/>
                        <Grid Height="430">
                            <Border x:Name="SpotlightFrame" Background="#46140B24" BorderBrush="{StaticResource Line1Brush}" BorderThickness="1"/>

                            <!-- Tratamiento "Retícula + barrido" (spot-a del mockup): aro discontinuo que gira
                                 lento + haz horizontal que barre de arriba abajo, ambos con el acento del
                                 componente activo. Detrás del contenido y recortados al marco del bay. -->
                            <Grid ClipToBounds="True" DataContext="{Binding ActiveSpec}" IsHitTestVisible="False">
                                <!-- Retícula: aro discontinuo (300) + aro interior + 4 puntos cardinales; gira 14s.
                                     Subida ~38px para quedar centrada DETRÁS de la imagen del spec (que vive en la
                                     fila superior del contenido, por encima del centro del bay), no del marco. -->
                                <Grid Width="300" Height="300" HorizontalAlignment="Center" VerticalAlignment="Center"
                                      Margin="0,-38,0,0" Opacity="0.55" RenderTransformOrigin="0.5,0.5">
                                    <Grid.RenderTransform><RotateTransform x:Name="SpotReticleRotate"/></Grid.RenderTransform>
                                    <Grid.Triggers>
                                        <EventTrigger RoutedEvent="Loaded">
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetName="SpotReticleRotate" Storyboard.TargetProperty="Angle"
                                                                     From="0" To="360" Duration="0:0:14" RepeatBehavior="Forever"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Grid.Triggers>
                                    <Ellipse Stroke="{Binding AccentBrush, FallbackValue={StaticResource CyanBrush}}" StrokeThickness="1" StrokeDashArray="2 4"/>
                                    <Ellipse Margin="26" Stroke="{Binding AccentBrush, FallbackValue={StaticResource CyanBrush}}" StrokeThickness="1" Opacity="0.5"/>
                                    <Ellipse Width="8" Height="8" Fill="{Binding AccentBrush, FallbackValue={StaticResource CyanBrush}}" HorizontalAlignment="Center" VerticalAlignment="Top"    Margin="0,-4,0,0"/>
                                    <Ellipse Width="8" Height="8" Fill="{Binding AccentBrush, FallbackValue={StaticResource CyanBrush}}" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,-4"/>
                                    <Ellipse Width="8" Height="8" Fill="{Binding AccentBrush, FallbackValue={StaticResource CyanBrush}}" HorizontalAlignment="Left"   VerticalAlignment="Center" Margin="-4,0,0,0"/>
                                    <Ellipse Width="8" Height="8" Fill="{Binding AccentBrush, FallbackValue={StaticResource CyanBrush}}" HorizontalAlignment="Right"  VerticalAlignment="Center" Margin="0,0,-4,0"/>
                                </Grid>

                                <!-- Haz de barrido: banda horizontal (90px) que cae de arriba abajo (3.4s) con
                                     pausa al final (ritmo del mockup: baja en el 55% y espera). Línea superior
                                     más marcada del acento. Funde a alpha-0 negro (no Transparent=blanco). -->
                                <Grid Height="90" VerticalAlignment="Top">
                                    <Grid.RenderTransform><TranslateTransform x:Name="SpotBeamTranslate" Y="-90"/></Grid.RenderTransform>
                                    <Grid.Triggers>
                                        <EventTrigger RoutedEvent="Loaded">
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="SpotBeamTranslate" Storyboard.TargetProperty="Y" Duration="0:0:3.4" RepeatBehavior="Forever">
                                                        <LinearDoubleKeyFrame Value="-90" KeyTime="0%"/>
                                                        <LinearDoubleKeyFrame Value="430" KeyTime="55%"/>
                                                        <LinearDoubleKeyFrame Value="430" KeyTime="100%"/>
                                                    </DoubleAnimationUsingKeyFrames>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Grid.Triggers>
                                    <Rectangle Opacity="0.22">
                                        <Rectangle.Fill>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                <GradientStop Color="#00000000" Offset="0"/>
                                                <GradientStop Color="{Binding AccentColor, FallbackValue={StaticResource CyanColor}}" Offset="0.5"/>
                                                <GradientStop Color="#00000000" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Rectangle.Fill>
                                    </Rectangle>
                                    <Rectangle Height="1" VerticalAlignment="Top" Fill="{Binding AccentBrush, FallbackValue={StaticResource CyanBrush}}" Opacity="0.5"/>
                                </Grid>
                            </Grid>

                            <!-- contenido del componente activo. Anima (fade + slide-up) cada vez que cambia
                                 ActiveSpec: el binding del icono notifica TargetUpdated y dispara el storyboard. -->
                            <Grid x:Name="SpotlightContent" DataContext="{Binding ActiveSpec}" Margin="48,34" RenderTransformOrigin="0.5,0.5">
                                <Grid.RenderTransform>
                                    <TranslateTransform Y="0"/>
                                </Grid.RenderTransform>
                                <Grid.Triggers>
                                    <EventTrigger RoutedEvent="Binding.TargetUpdated">
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.38">
                                                    <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="26" To="0" Duration="0:0:0.42">
                                                    <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Grid.Triggers>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <!-- Visual del componente activo: foto real si existe, si no el icono vectorial.
                                     NotifyOnTargetUpdated en el icono mantiene vivo el fade+slide del bloque entero. -->
                                <Grid x:Name="SpotlightIcon" Grid.Row="0" Margin="0,0,0,22">
                                    <Path Data="{Binding IconData, FallbackValue='M 0,0', NotifyOnTargetUpdated=True}"
                                          Fill="{Binding AccentBrush, FallbackValue={StaticResource CyanBrush}}"
                                          Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"
                                          MaxHeight="230"
                                          Visibility="{Binding HasImage, Converter={StaticResource InverseBoolToVis}}">
                                        <Path.Effect>
                                            <DropShadowEffect Color="{Binding AccentColor}" BlurRadius="34" ShadowDepth="0" Opacity="0.55"/>
                                        </Path.Effect>
                                    </Path>
                                    <!-- Foto real: entra deslizándose hacia el centro + escala + fade (BackEase, pulido). -->
                                    <Image Source="{Binding ImagePath, Converter={StaticResource OptionalImage}, NotifyOnTargetUpdated=True}"
                                           Visibility="{Binding HasImage, Converter={StaticResource BoolToVis}}"
                                           Stretch="Uniform" MaxHeight="260" RenderTransformOrigin="0.5,0.5"
                                           RenderOptions.BitmapScalingMode="HighQuality">
                                        <Image.Effect>
                                            <DropShadowEffect Color="{Binding AccentColor}" BlurRadius="42" ShadowDepth="0" Opacity="0.5"/>
                                        </Image.Effect>
                                        <Image.RenderTransform>
                                            <TransformGroup>
                                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                                                <TranslateTransform X="0"/>
                                            </TransformGroup>
                                        </Image.RenderTransform>
                                        <Image.Triggers>
                                            <EventTrigger RoutedEvent="Binding.TargetUpdated">
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.45">
                                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                                        </DoubleAnimation>
                                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[1].(TranslateTransform.X)" From="-96" To="0" Duration="0:0:0.62">
                                                            <DoubleAnimation.EasingFunction><BackEase EasingMode="EaseOut" Amplitude="0.35"/></DoubleAnimation.EasingFunction>
                                                        </DoubleAnimation>
                                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)" From="0.88" To="1" Duration="0:0:0.62">
                                                            <DoubleAnimation.EasingFunction><BackEase EasingMode="EaseOut" Amplitude="0.3"/></DoubleAnimation.EasingFunction>
                                                        </DoubleAnimation>
                                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)" From="0.88" To="1" Duration="0:0:0.62">
                                                            <DoubleAnimation.EasingFunction><BackEase EasingMode="EaseOut" Amplitude="0.3"/></DoubleAnimation.EasingFunction>
                                                        </DoubleAnimation>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </EventTrigger>
                                        </Image.Triggers>
                                    </Image>
                                </Grid>
                                <StackPanel Grid.Row="1" HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding Label}" edit:Editable.IsOn="False" Style="{StaticResource MonoFont}" FontSize="18" Foreground="{StaticResource Text2Brush}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding Value}" edit:Editable.IsOn="False" Style="{StaticResource DisplayFont}" FontSize="34" Foreground="{StaticResource Text0Brush}" HorizontalAlignment="Center" Margin="0,6,0,0" TextAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </Grid>
                            <!-- corner brackets (top-left + bottom-right), 26×26 L marks -->
                            <Path Stroke="{StaticResource CyanBrush}" StrokeThickness="2" Width="26" Height="26" HorizontalAlignment="Left" VerticalAlignment="Top" Stretch="None" Data="M 0,26 L 0,0 L 26,0"/>
                            <Path Stroke="{StaticResource CyanBrush}" StrokeThickness="2" Width="26" Height="26" HorizontalAlignment="Right" VerticalAlignment="Bottom" Stretch="None" Data="M 0,26 L 26,26 L 26,0"/>
                        </Grid>
                    </StackPanel>

                    <!-- Component tile grid (bottom) — ordered, tappable, auto-cycling highlight.
                         Bajado para dar más alto al spotlight y cerrar el hueco inferior. -->
                    <StackPanel HorizontalAlignment="Left" VerticalAlignment="Top" Width="1260" Margin="120,628,0,0">
                        <TextBlock Text="{Binding Texts[hud.components]}" Style="{StaticResource MonoFont}" FontSize="18" Foreground="{StaticResource Text2Brush}" Margin="0,0,0,16"/>
                        <ItemsControl x:Name="SpecTiles" ItemsSource="{Binding Specs}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="5"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Click="SpecNode_Click" Height="176" Margin="0,0,14,14"
                                            Background="#AE140B24" BorderBrush="{StaticResource Line1Brush}" BorderThickness="1"
                                            Foreground="White" Cursor="Hand">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="RootBorder" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" RenderTransformOrigin="0.5,0.5">
                                                    <Border.RenderTransform>
                                                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                                                    </Border.RenderTransform>
                                                    <Border.Effect>
                                                        <DropShadowEffect Color="{StaticResource CyanColor}" BlurRadius="28" ShadowDepth="0" Opacity="0"/>
                                                    </Border.Effect>
                                                    <Border.Clip>
                                                        <PathGeometry Figures="M 0,0 L 238,0 L 238,164 L 226,176 L 0,176 Z"/>
                                                    </Border.Clip>
                                                    <Grid>
                                                        <!-- tinte de selección: sutil, concentrado en la parte baja (degradado) -->
                                                        <Rectangle x:Name="HighlightBg" Fill="{StaticResource CyanBrush}" Opacity="0">
                                                            <Rectangle.OpacityMask>
                                                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                                    <GradientStop Color="#00FFFFFF" Offset="0"/>
                                                                    <GradientStop Color="#40FFFFFF" Offset="0.55"/>
                                                                    <GradientStop Color="#CCFFFFFF" Offset="1"/>
                                                                </LinearGradientBrush>
                                                            </Rectangle.OpacityMask>
                                                        </Rectangle>
                                                        <Grid Margin="18,16,18,14">
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="*"/>
                                                                <RowDefinition Height="Auto"/>
                                                            </Grid.RowDefinitions>
                                                            <!-- top: icon + index -->
                                                            <Grid Grid.Row="0">
                                                                <Path x:Name="IconPath" Data="{Binding IconData, FallbackValue='M 0,0'}" Fill="{StaticResource Text1Brush}" Width="24" Height="24" Stretch="Uniform" HorizontalAlignment="Left"/>
                                                                <TextBlock Text="{Binding IndexText}" edit:Editable.IsOn="False" Style="{StaticResource MonoFont}" Foreground="{StaticResource Text3Brush}" FontSize="14" HorizontalAlignment="Right" VerticalAlignment="Top"/>
                                                            </Grid>
                                                            <!-- middle: label + value -->
                                                            <StackPanel Grid.Row="1" VerticalAlignment="Bottom">
                                                                <TextBlock x:Name="LblTxt" Text="{Binding Label}" Style="{StaticResource MonoFont}" Foreground="{StaticResource Text2Brush}" FontSize="16"/>
                                                                <TextBlock x:Name="ValTxt" Text="{Binding Value}" Style="{StaticResource DisplayFont}" Foreground="{StaticResource Text0Brush}" FontSize="20" Margin="0,5,0,0" TextWrapping="Wrap" TextTrimming="CharacterEllipsis"/>
                                                            </StackPanel>
                                                            <!-- footer: ver detalle -->
                                                            <TextBlock x:Name="CtaTxt" Grid.Row="2" Text="{Binding Texts[hud.tileCta], RelativeSource={RelativeSource AncestorType=Window}}" edit:Editable.IsOn="False" Style="{StaticResource MonoFont}" FontSize="14" Foreground="{StaticResource Text3Brush}" Margin="0,10,0,0"/>
                                                        </Grid>
                                                        <!-- borde de acento (overlay, aparece en fade al seleccionar) -->
                                                        <Border x:Name="AccentEdge" BorderBrush="{StaticResource CyanBrush}" BorderThickness="1.5" Opacity="0"/>
                                                        <!-- subrayado de progreso: crece durante el tiempo que el tile está activo -->
                                                        <Rectangle x:Name="Progress" Height="3" VerticalAlignment="Bottom" HorizontalAlignment="Stretch" Fill="{StaticResource CyanBrush}" Opacity="0.9" RenderTransformOrigin="0,0.5">
                                                            <Rectangle.RenderTransform>
                                                                <ScaleTransform ScaleX="0" ScaleY="1"/>
                                                            </Rectangle.RenderTransform>
                                                            <Rectangle.Effect>
                                                                <DropShadowEffect Color="{StaticResource CyanColor}" BlurRadius="10" ShadowDepth="0" Opacity="0.8"/>
                                                            </Rectangle.Effect>
                                                        </Rectangle>
                                                    </Grid>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <DataTrigger Binding="{Binding IsHighlighted}" Value="True">
                                                        <!-- color de icono/textos (inmediato) -->
                                                        <Setter TargetName="IconPath" Property="Fill" Value="{StaticResource CyanBrush}" />
                                                        <Setter TargetName="LblTxt" Property="Foreground" Value="{StaticResource CyanBrush}" />
                                                        <Setter TargetName="CtaTxt" Property="Foreground" Value="{StaticResource CyanBrush}" />
                                                        <DataTrigger.EnterActions>
                                                            <BeginStoryboard>
                                                                <Storyboard>
                                                                    <DoubleAnimation Storyboard.TargetName="AccentEdge" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.30">
                                                                        <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                                                    </DoubleAnimation>
                                                                    <DoubleAnimation Storyboard.TargetName="HighlightBg" Storyboard.TargetProperty="Opacity" To="0.16" Duration="0:0:0.30"/>
                                                                    <DoubleAnimation Storyboard.TargetName="RootBorder" Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)" To="0.5" Duration="0:0:0.30"/>
                                                                    <DoubleAnimation Storyboard.TargetName="RootBorder" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" From="0.97" To="1" Duration="0:0:0.32">
                                                                        <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                                                    </DoubleAnimation>
                                                                    <DoubleAnimation Storyboard.TargetName="RootBorder" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" From="0.97" To="1" Duration="0:0:0.32">
                                                                        <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                                                    </DoubleAnimation>
                                                                    <DoubleAnimation Storyboard.TargetName="Progress" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" From="0" To="1" Duration="0:0:2.8"/>
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </DataTrigger.EnterActions>
                                                        <DataTrigger.ExitActions>
                                                            <BeginStoryboard>
                                                                <Storyboard>
                                                                    <DoubleAnimation Storyboard.TargetName="AccentEdge" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.20"/>
                                                                    <DoubleAnimation Storyboard.TargetName="HighlightBg" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.20"/>
                                                                    <DoubleAnimation Storyboard.TargetName="RootBorder" Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)" To="0" Duration="0:0:0.20"/>
                                                                    <DoubleAnimation Storyboard.TargetName="Progress" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="0" Duration="0:0:0.15"/>
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </DataTrigger.ExitActions>
                                                    </DataTrigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="HighlightBg" Property="Opacity" Value="0.10" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- Right Price Strip -->
                    <StackPanel HorizontalAlignment="Right" VerticalAlignment="Top" Width="380" Margin="0,180,120,0">
                        <Border Background="#120A0A1A" BorderBrush="{StaticResource Line1Brush}" BorderThickness="1" Padding="26,28">
                            <StackPanel>
                                <TextBlock Text="{Binding Texts[price.label]}" Style="{StaticResource MonoFont}" FontSize="16" Foreground="{StaticResource MagentaBrush}"/>
                                <StackPanel Orientation="Horizontal" Margin="0,12,0,0" VerticalAlignment="Bottom">
                                    <TextBlock Text="{Binding FormattedPrice}" edit:Editable.IsOn="False" Style="{StaticResource DisplayFont}" FontSize="88" Foreground="{StaticResource Text0Brush}" LineHeight="88"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0" Visibility="{Binding HasDiscount, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="{Binding FormattedOriginalPrice}" edit:Editable.IsOn="False" Foreground="{StaticResource Text2Brush}" FontSize="18" TextDecorations="Strikethrough" Margin="0,0,12,0"/>
                                    <TextBlock Text="{Binding FormattedDiscount}" edit:Editable.IsOn="False" Style="{StaticResource MonoFont}" Foreground="{StaticResource MagentaBrush}" FontSize="18" FontWeight="Bold"/>
                                </StackPanel>
                                
                                <Border Margin="0,22,0,0" Padding="16,16" Background="#0AFFFFFF" BorderBrush="{StaticResource Line2Brush}" BorderThickness="1" CornerRadius="10">
                                    <StackPanel>
                                        <Grid>
                                            <TextBlock Text="{Binding Texts[price.installments]}" Style="{StaticResource MonoFont}" FontSize="16" Foreground="{StaticResource Text2Brush}" VerticalAlignment="Center"/>
                                            <!-- Alterna el plazo de cuotas 6 ⇄ 12 meses — botón grande y táctil -->
                                            <Button HorizontalAlignment="Right" Padding="16,11" Background="#26F37A4A" BorderBrush="{StaticResource CyanBrush}" BorderThickness="1.5"
                                                    Cursor="Hand" Click="InstallmentsToggle_Click" edit:Editable.IsOn="False">
                                                <TextBlock Text="{Binding InstallmentsToggleText}" Style="{StaticResource MonoFont}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource CyanBrush}"/>
                                            </Button>
                                        </Grid>
                                        <!-- Cuota mensual: héroe del bloque, acento -->
                                        <StackPanel Orientation="Horizontal" Margin="0,12,0,0" VerticalAlignment="Bottom">
                                            <TextBlock Text="{Binding InstallmentsPrefix}" edit:Editable.IsOn="False" Style="{StaticResource DisplayFont}" FontSize="30" Foreground="{StaticResource CyanBrush}"/>
                                            <TextBlock Text="{Binding FormattedMonthly}" edit:Editable.IsOn="False" Style="{StaticResource DisplayFont}" FontSize="30" Foreground="{StaticResource CyanBrush}"/>
                                        </StackPanel>
                                        <!-- "Sin intereses" como píldora verde -->
                                        <Border HorizontalAlignment="Left" Margin="0,10,0,0" Padding="10,5" CornerRadius="6"
                                                Background="#1FF0D26B" BorderBrush="{StaticResource OkBrush}" BorderThickness="1">
                                            <TextBlock Text="{Binding Texts[price.noInterest]}" Style="{StaticResource MonoFont}" FontSize="15" FontWeight="Medium" Foreground="{StaticResource OkBrush}"/>
                                        </Border>
                                    </StackPanel>
                                </Border>
                                
                                <!-- Full-width CTA button -->
                                <Button Margin="0,22,0,0" Padding="16" Background="{StaticResource CyanBrush}" Foreground="#02121a" BorderThickness="0" Cursor="Hand" HorizontalContentAlignment="Center">
                                    <Button.Clip>
                                        <PathGeometry Figures="M 12,0 L 330,0 L 330,40 L 318,52 L 0,52 L 0,12 Z"/>
                                    </Button.Clip>
                                    <TextBlock Text="{Binding Texts[price.cta]}" Style="{StaticResource DisplayFont}" FontWeight="Bold" FontSize="16" TextAlignment="Center"/>
                                    <Button.Effect>
                                        <DropShadowEffect Color="{StaticResource CyanColor}" BlurRadius="24" ShadowDepth="0" Opacity="0.6"/>
                                    </Button.Effect>
                                </Button>

                                <!-- QR (grande, escaneable) + texto debajo -->
                                <StackPanel Margin="0,18,0,0">
                                    <Border x:Name="QrBorder" Width="240" Height="240" Background="White" Padding="10" HorizontalAlignment="Center">
                                        <Image x:Name="QrImage" Stretch="Uniform" RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                                    </Border>
                                    <StackPanel Margin="0,14,0,0">
                                        <TextBlock Text="{Binding Texts[price.scanTitle]}" Style="{StaticResource MonoFont}" FontSize="16" Foreground="{StaticResource Text2Brush}" Margin="0,0,0,6" TextAlignment="Center"/>
                                        <TextBlock Text="{Binding Texts[price.scanText]}" edit:Editable.Multiline="True" Foreground="{StaticResource Text1Brush}" FontSize="17" TextWrapping="Wrap" LineHeight="24" TextAlignment="Center"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Indicador de stock retirado: mostraba datos fijos falsos (STOCK/RESERVADO)
                             no ligados a inventario real → engañoso en sala de ventas. -->
                    </StackPanel>
                </Grid>

                <!-- ====== SCREEN 3: DETAIL ====== -->
                <Grid x:Name="Screen3_Detail" Visibility="Collapsed" Opacity="0" DataContext="{Binding SelectedSpec}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="560"/>
                    </Grid.ColumnDefinitions>

                    <!-- LEFT: contenido arriba (fila *) + navegación SIEMPRE anclada abajo (fila Auto) -->
                    <!-- Top margin deja sitio bajo el logo (agrandado) para que la fila breadcrumb no choque. -->
                    <Grid Grid.Column="0" Margin="120,185,40,80">
                      <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                      </Grid.RowDefinitions>
                      <StackPanel Grid.Row="0">
                        <!-- header rail: accent bar + icon + "01 / 10 · Procesador" -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,26">
                          <Rectangle Width="46" Height="3" Fill="{Binding AccentBrush, FallbackValue={StaticResource CyanBrush}}" VerticalAlignment="Center" Margin="0,0,18,0">
                            <Rectangle.Effect>
                              <DropShadowEffect Color="{Binding AccentColor, FallbackValue={StaticResource CyanColor}}" BlurRadius="14" ShadowDepth="0" Opacity="0.9"/>
                            </Rectangle.Effect>
                          </Rectangle>
                          <Path Data="{Binding IconData, FallbackValue='M 0,0'}" Fill="{Binding AccentBrush, FallbackValue={StaticResource CyanBrush}}" Height="34" Width="34" Stretch="Uniform" VerticalAlignment="Center"/>
                          <TextBlock Text="{Binding IndexLabelFull}" edit:Editable.IsOn="False" Style="{StaticResource MonoFont}" FontSize="18" Foreground="{Binding AccentBrush, FallbackValue={StaticResource CyanBrush}}" VerticalAlignment="Center" Margin="14,0,0,0"/>
                        </StackPanel>

                        <!-- family eyebrow -->
                        <TextBlock Text="{Binding Family}" Style="{StaticResource MonoFont}" FontSize="18" Foreground="{StaticResource Text2Brush}" Margin="0,0,0,8"/>

                        <!-- hero: modelo concreto (DetailTitle). Auto-encoge si es largo (nunca se corta ni empuja la navegación). -->
                        <Viewbox StretchDirection="DownOnly" Stretch="Uniform" HorizontalAlignment="Left" MaxWidth="980" MaxHeight="240" Margin="0,0,0,12">
                          <TextBlock Text="{Binding DetailTitle}" edit:Editable.IsOn="False" Style="{StaticResource DisplayFont}" FontSize="116" LineHeight="110" Foreground="{Binding AccentBrush, FallbackValue={StaticResource CyanBrush}}" TextWrapping="Wrap" Width="980">
                            <TextBlock.Effect>
                              <DropShadowEffect Color="{Binding AccentColor, FallbackValue={StaticResource CyanColor}}" BlurRadius="42" ShadowDepth="0" Opacity="0.55"/>
                            </TextBlock.Effect>
                          </TextBlock>
                        </Viewbox>

                        <!-- nombre amigable (chip secundario): pequeño, oculto si no aporta nada al cliente -->
                        <TextBlock Text="{Binding DetailSubtitle}" edit:Editable.IsOn="False" Style="{StaticResource MonoFont}" FontSize="20" Foreground="{StaticResource Text2Brush}" TextWrapping="NoWrap" Margin="0,0,0,28" Visibility="{Binding HasDetailSubtitle, Converter={StaticResource BoolToVis}}"/>

                        <!-- StatStrip: Detail parsed into framed cells. Oculto si no hay detalle real. -->
                        <Border BorderBrush="{StaticResource Line1Brush}" BorderThickness="1" Background="#05FFFFFF" HorizontalAlignment="Left"
                                Visibility="{Binding HasDetail, Converter={StaticResource BoolToVis}}">
                          <ItemsControl ItemsSource="{Binding DetailTokens}">
                            <ItemsControl.ItemsPanel>
                              <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                              <DataTemplate>
                                <Border BorderBrush="{StaticResource Line1Brush}" BorderThickness="1,0,0,0" Padding="22,14" MinWidth="118">
                                  <StackPanel>
                                    <Rectangle Width="22" Height="2" Margin="0,0,0,8" HorizontalAlignment="Left"
                                               Fill="{Binding DataContext.AccentBrush, RelativeSource={RelativeSource AncestorType=ItemsControl}, FallbackValue={StaticResource CyanBrush}}"/>
                                    <TextBlock Text="{Binding}" edit:Editable.IsOn="False" Style="{StaticResource DisplayFont}" FontSize="19" Foreground="{StaticResource Text0Brush}" TextWrapping="NoWrap"/>
                                  </StackPanel>
                                </Border>
                              </DataTemplate>
                            </ItemsControl.ItemTemplate>
                          </ItemsControl>
                        </Border>

                        <!-- Metrics module: radial gauge + tier + honest scale (benchmarked specs) -->
                        <Border Margin="0,28,0,0" Padding="28,26" Background="#120A0A1A" BorderBrush="{StaticResource Line1Brush}" BorderThickness="1"
                                HorizontalAlignment="Left" Visibility="{Binding HasBench, Converter={StaticResource BoolToVis}}">
                          <StackPanel Orientation="Horizontal">
                            <edit:RadialGauge Value="{Binding BenchScore}" AccentColor="{Binding AccentColor}" GaugeSize="196" VerticalAlignment="Center" Margin="0,0,38,0"/>
                            <StackPanel Width="640" VerticalAlignment="Center">
                              <TextBlock Text="// RENDIMIENTO MEDIDO" Style="{StaticResource MonoFont}" FontSize="18" Foreground="{Binding AccentBrush, FallbackValue={StaticResource CyanBrush}}" Margin="0,0,0,14"/>
                              <TextBlock Text="{Binding Tier}" edit:Editable.IsOn="False" Style="{StaticResource DisplayFont}" FontSize="34" Foreground="{StaticResource Text0Brush}" Margin="0,0,0,8"/>
                              <TextBlock Text="{Binding BenchPercentLabel}" edit:Editable.IsOn="False" Style="{StaticResource MonoFont}" FontSize="16" Foreground="{StaticResource Text2Brush}" Margin="0,0,0,20"/>
                              <!-- honest position scale (0–640px = 0–100) -->
                              <Grid Height="10" Width="640" Background="#10FFFFFF" HorizontalAlignment="Left">
                                <Rectangle HorizontalAlignment="Left" Width="{Binding BenchBarWidth}" Fill="{Binding AccentBrush, FallbackValue={StaticResource CyanBrush}}">
                                  <Rectangle.Effect>
                                    <DropShadowEffect Color="{Binding AccentColor, FallbackValue={StaticResource CyanColor}}" BlurRadius="16" ShadowDepth="0" Opacity="0.8"/>
                                  </Rectangle.Effect>
                                </Rectangle>
                                <Rectangle Width="2" Height="20" Fill="{StaticResource Text0Brush}" HorizontalAlignment="Left" VerticalAlignment="Center"
                                           Margin="{Binding BenchMarkerLeft, Converter={StaticResource LeftMarginConverter}}"/>
                              </Grid>
                              <Grid Width="640" HorizontalAlignment="Left" Margin="0,10,0,0">
                                <TextBlock Text="BÁSICO" Style="{StaticResource MonoFont}" FontSize="16" Foreground="{StaticResource Text3Brush}" HorizontalAlignment="Left"/>
                                <TextBlock Text="TOPE DE GAMA" Style="{StaticResource MonoFont}" FontSize="16" Foreground="{StaticResource Text3Brush}" HorizontalAlignment="Right"/>
                              </Grid>
                            </StackPanel>
                          </StackPanel>
                        </Border>

                        <!-- Non-benchmarked specs: verified component panel -->
                        <Border Margin="0,28,0,0" Padding="26,22" Background="#120A0A1A" BorderBrush="{StaticResource Line1Brush}" BorderThickness="1"
                                HorizontalAlignment="Left" Visibility="{Binding HasBench, Converter={StaticResource InverseBoolToVis}}">
                          <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Path Data="{Binding IconData, FallbackValue='M 0,0'}" Fill="{Binding AccentBrush, FallbackValue={StaticResource CyanBrush}}" Height="28" Width="28" Stretch="Uniform" VerticalAlignment="Center"/>
                            <TextBlock Text="Componente verificado · operativo" Style="{StaticResource MonoFont}" FontSize="18" Foreground="{StaticResource Text1Brush}" VerticalAlignment="Center" Margin="18,0,32,0"/>
                            <Ellipse Width="9" Height="9" Fill="{StaticResource OkBrush}" VerticalAlignment="Center">
                              <Ellipse.Effect>
                                <DropShadowEffect Color="{StaticResource OkColor}" BlurRadius="10" ShadowDepth="0" Opacity="0.9"/>
                              </Ellipse.Effect>
                            </Ellipse>
                          </StackPanel>
                        </Border>

                      </StackPanel>

                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,40,0,0">
                            <Button Click="DetailPrev_Click" Content="◀ Anterior" Style="{StaticResource SecondaryButton}" Margin="0,0,16,0" Cursor="Hand"/>
                            <Button Click="DetailNext_Click" Content="Siguiente ▶" Style="{StaticResource SecondaryButton}" Margin="0,0,16,0" Cursor="Hand"/>
                            <Button Click="DetailBack_Click" Content="Volver al equipo" Style="{StaticResource SecondaryButton}" Cursor="Hand"/>
                        </StackPanel>
                    </Grid>

                    <!-- RIGHT -->
                    <StackPanel Grid.Column="1" Margin="0,138,120,0">
                        <!-- PHOTO HERO (.d-photo del mockup): foto real del componente (ImagePath) si existe;
                             si no, el icono vectorial enmarcado. Corchetes de esquina + etiqueta. Faltaba:
                             la columna derecha saltaba directa al bloque "QUÉ SIGNIFICA". El glow radial
                             funde a alpha-0 NEGRO (no a Transparent=blanco) para evitar halo lechoso. -->
                        <Border Height="264" BorderBrush="{StaticResource Line1Brush}" BorderThickness="1"
                                Background="#800A0716" ClipToBounds="True" Margin="0,0,0,26">
                          <Grid>
                            <!-- radial(70% 90% at 50% 30%, accent 14%) -->
                            <Rectangle Opacity="0.14">
                              <Rectangle.Fill>
                                <RadialGradientBrush Center="0.5,0.3" GradientOrigin="0.5,0.3" RadiusX="0.7" RadiusY="0.9">
                                  <GradientStop Color="{Binding AccentColor, FallbackValue={StaticResource CyanColor}}" Offset="0"/>
                                  <GradientStop Color="#00000000" Offset="0.7"/>
                                </RadialGradientBrush>
                              </Rectangle.Fill>
                            </Rectangle>

                            <!-- icono vectorial enmarcado (sin foto) -->
                            <Border Width="160" Height="160" HorizontalAlignment="Center" VerticalAlignment="Center"
                                    BorderThickness="1" Visibility="{Binding HasImage, Converter={StaticResource InverseBoolToVis}}">
                              <Border.BorderBrush>
                                <SolidColorBrush Color="{Binding AccentColor, FallbackValue={StaticResource CyanColor}}" Opacity="0.38"/>
                              </Border.BorderBrush>
                              <Border.Background>
                                <RadialGradientBrush>
                                  <GradientStop Color="{Binding AccentColor, FallbackValue={StaticResource CyanColor}}" Offset="0"/>
                                  <GradientStop Color="#00000000" Offset="0.72"/>
                                </RadialGradientBrush>
                              </Border.Background>
                              <Path Data="{Binding IconData, FallbackValue='M 0,0'}" Fill="{Binding AccentBrush, FallbackValue={StaticResource CyanBrush}}"
                                    Width="84" Height="84" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Path.Effect><DropShadowEffect Color="{Binding AccentColor, FallbackValue={StaticResource CyanColor}}" BlurRadius="16" ShadowDepth="0" Opacity="0.9"/></Path.Effect>
                              </Path>
                            </Border>

                            <!-- foto real del componente -->
                            <Image Source="{Binding ImagePath, Converter={StaticResource OptionalImage}}"
                                   Visibility="{Binding HasImage, Converter={StaticResource BoolToVis}}"
                                   Stretch="Uniform" MaxHeight="236" Margin="40,20"
                                   RenderOptions.BitmapScalingMode="HighQuality" HorizontalAlignment="Center" VerticalAlignment="Center">
                              <Image.Effect><DropShadowEffect Color="#000000" BlurRadius="40" ShadowDepth="16" Opacity="0.6"/></Image.Effect>
                            </Image>

                            <!-- corchetes de esquina (24×24 acento, inset 10) -->
                            <Path Data="M 0,24 L 0,0 L 24,0" Stroke="{Binding AccentBrush, FallbackValue={StaticResource CyanBrush}}" StrokeThickness="2" HorizontalAlignment="Left"  VerticalAlignment="Top"    Margin="10"/>
                            <Path Data="M 0,0 L 24,0 L 24,24" Stroke="{Binding AccentBrush, FallbackValue={StaticResource CyanBrush}}" StrokeThickness="2" HorizontalAlignment="Right" VerticalAlignment="Top"    Margin="10"/>
                            <Path Data="M 0,0 L 0,24 L 24,24" Stroke="{Binding AccentBrush, FallbackValue={StaticResource CyanBrush}}" StrokeThickness="2" HorizontalAlignment="Left"  VerticalAlignment="Bottom" Margin="10"/>
                            <Path Data="M 0,24 L 24,24 L 24,0" Stroke="{Binding AccentBrush, FallbackValue={StaticResource CyanBrush}}" StrokeThickness="2" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="10"/>

                            <!-- etiqueta: COMPONENTE REAL (foto) / ESQUEMA · {family} (icono) -->
                            <Border HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="16,0,0,14"
                                    Background="#990A0716" BorderBrush="{Binding AccentBrush, FallbackValue={StaticResource CyanBrush}}" BorderThickness="2,0,0,0" Padding="9,5">
                              <Grid>
                                <TextBlock Style="{StaticResource MonoFont}" FontSize="16" Foreground="{StaticResource Text2Brush}" Text="COMPONENTE REAL"
                                           edit:Editable.IsOn="False" Visibility="{Binding HasImage, Converter={StaticResource BoolToVis}}"/>
                                <TextBlock Style="{StaticResource MonoFont}" FontSize="16" Foreground="{StaticResource Text2Brush}"
                                           edit:Editable.IsOn="False" Visibility="{Binding HasImage, Converter={StaticResource InverseBoolToVis}}"><Run Text="ESQUEMA · "/><Run Text="{Binding Family}"/></TextBlock>
                              </Grid>
                            </Border>
                          </Grid>
                        </Border>

                        <Border Background="#120A0A1A" BorderBrush="{StaticResource Line1Brush}" BorderThickness="1" Padding="36" CornerRadius="0">
                          <StackPanel>
                            <TextBlock Text="// QUÉ SIGNIFICA" Style="{StaticResource MonoFont}" FontSize="18" Foreground="{Binding AccentBrush, FallbackValue={StaticResource CyanBrush}}" Margin="0,0,0,18"/>
                            <TextBlock Text="{Binding Summary}" edit:Editable.Multiline="True" FontSize="22" LineHeight="33" Foreground="{StaticResource Text0Brush}" TextWrapping="Wrap"/>
                    
                            <TextBlock Text="// PARA QUÉ TE SIRVE" Style="{StaticResource MonoFont}" FontSize="18" Foreground="{Binding AccentBrush, FallbackValue={StaticResource CyanBrush}}" Margin="0,38,0,18"/>
                            
                            <ItemsControl ItemsSource="{Binding Pros}">
                              <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                  <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <Border Width="28" Height="28" BorderBrush="{Binding DataContext.AccentBrush, RelativeSource={RelativeSource AncestorType=ItemsControl}}" BorderThickness="1" Background="#1AFFFFFF" Margin="0,0,16,0">
                                      <TextBlock Text="{Binding Index}" edit:Editable.IsOn="False" Style="{StaticResource MonoFont}" FontSize="16" Foreground="{Binding DataContext.AccentBrush, RelativeSource={RelativeSource AncestorType=ItemsControl}}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="{Binding Text}" edit:Editable.Multiline="True" Foreground="{StaticResource Text1Brush}" FontSize="20" VerticalAlignment="Center" TextWrapping="Wrap" MaxWidth="380"/>
                                  </StackPanel>
                                </DataTemplate>
                              </ItemsControl.ItemTemplate>
                            </ItemsControl>
                          </StackPanel>
                        </Border>

                        <!-- Mini spec thumbnails -->
                        <ItemsControl ItemsSource="{Binding Specs, RelativeSource={RelativeSource AncestorType=Window}}" Margin="0,30,0,0">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="5" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Click="SpecNode_Click" Margin="4" Cursor="Hand">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="NavBorder" Padding="6,10" Background="#05FFFFFF" BorderBrush="{StaticResource Line1Brush}" BorderThickness="1">
                                                    <StackPanel HorizontalAlignment="Center">
                                                        <Path x:Name="NavIcon" Data="{Binding IconData, FallbackValue='M 0,0'}" Fill="{StaticResource Text2Brush}" Height="18" Width="18" Stretch="Uniform" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                                        <TextBlock x:Name="NavLbl" Text="{Binding LabelShort}" edit:Editable.IsOn="False" Style="{StaticResource MonoFont}" FontSize="15" Foreground="{StaticResource Text2Brush}" HorizontalAlignment="Center"/>
                                                    </StackPanel>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <DataTrigger Binding="{Binding IsCurrentDetail}" Value="True">
                                                        <Setter TargetName="NavBorder" Property="BorderBrush" Value="{Binding AccentBrush, FallbackValue={StaticResource CyanBrush}}"/>
                                                        <Setter TargetName="NavBorder" Property="Background" Value="#14FFFFFF"/>
                                                        <Setter TargetName="NavIcon" Property="Fill" Value="{Binding AccentBrush, FallbackValue={StaticResource CyanBrush}}"/>
                                                        <Setter TargetName="NavLbl" Property="Foreground" Value="{StaticResource Text0Brush}"/>
                                                    </DataTrigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="NavBorder" Property="BorderBrush" Value="{StaticResource Text1Brush}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <TextBlock Text="{Binding Family}" edit:Editable.IsOn="False" Style="{StaticResource DisplayFont}" FontSize="720" LineHeight="576"
                               Foreground="#08FFFFFF" HorizontalAlignment="Right" VerticalAlignment="Top"
                               Margin="0,80,-120,0" Panel.ZIndex="-1" IsHitTestVisible="False"/>

                </Grid>

            </Grid>

            <!-- ================= MORPH OVERLAY (shared-element tarjeta→spotlight) ================= -->
            <!-- Encima de las pantallas (z>0) y por debajo del chrome (z40). El clon de la tarjeta
                 seleccionada vuela/escala aquí hasta el marco del spotlight. -->
            <Canvas x:Name="MorphLayer" Panel.ZIndex="30" IsHitTestVisible="False">
                <Border x:Name="MorphGhost" Visibility="Collapsed" IsHitTestVisible="False" RenderTransformOrigin="0,0">
                    <Border.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform x:Name="MorphGhostScale" ScaleX="1" ScaleY="1"/>
                            <TranslateTransform x:Name="MorphGhostTranslate" X="0" Y="0"/>
                        </TransformGroup>
                    </Border.RenderTransform>
                </Border>
            </Canvas>

            <!-- ================= ENTRANCE OVERLAY (animación de entrada a Main) ================= -->
            <!-- Por encima del chrome para que el logo "vuele" sobre todo; se oculta al terminar. -->
            <Grid x:Name="EntranceLayer" Panel.ZIndex="45" IsHitTestVisible="False">
                <!-- Logo de entrada (variantes Iris/ZoomThrough): centrado, escala/viaja, luego se oculta -->
                <Image x:Name="EntranceLogo" Source="Assets/clinicapc-logo.png" Height="72" Visibility="Hidden" Opacity="0"
                       HorizontalAlignment="Center" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                    <Image.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform x:Name="EntranceLogoScale" ScaleX="1" ScaleY="1"/>
                            <TranslateTransform x:Name="EntranceLogoTranslate" X="0" Y="0"/>
                        </TransformGroup>
                    </Image.RenderTransform>
                    <Image.Effect>
                        <DropShadowEffect x:Name="EntranceLogoGlow" Color="{StaticResource CyanColor}" BlurRadius="40" ShadowDepth="0" Opacity="0.85"/>
                    </Image.Effect>
                </Image>
            </Grid>

            <!-- ================= CHROME & BRACKETS (transparent overlay) ================= -->
            <Grid x:Name="ForegroundChrome" IsHitTestVisible="{Binding EditMode.IsActive}" Panel.ZIndex="40">
                <!-- Corner brackets: 44×44 L-shapes at 24px from each corner -->
                <Canvas IsHitTestVisible="False">
                    <Path Canvas.Left="24" Canvas.Top="24" Stroke="{StaticResource CyanBrush}" StrokeThickness="2" Data="M 0,44 L 0,0 L 44,0">
                        <Path.Effect><DropShadowEffect Color="{StaticResource CyanColor}" BlurRadius="6" ShadowDepth="0" Opacity="0.9"/></Path.Effect>
                    </Path>
                    <Path Canvas.Left="1852" Canvas.Top="24" Stroke="{StaticResource CyanBrush}" StrokeThickness="2" Data="M 44,44 L 44,0 L 0,0">
                        <Path.Effect><DropShadowEffect Color="{StaticResource CyanColor}" BlurRadius="6" ShadowDepth="0" Opacity="0.9"/></Path.Effect>
                    </Path>
                    <Path Canvas.Left="24" Canvas.Top="1012" Stroke="{StaticResource CyanBrush}" StrokeThickness="2" Data="M 0,0 L 0,44 L 44,44">
                        <Path.Effect><DropShadowEffect Color="{StaticResource CyanColor}" BlurRadius="6" ShadowDepth="0" Opacity="0.9"/></Path.Effect>
                    </Path>
                    <Path Canvas.Left="1852" Canvas.Top="1012" Stroke="{StaticResource CyanBrush}" StrokeThickness="2" Data="M 44,0 L 44,44 L 0,44">
                        <Path.Effect><DropShadowEffect Color="{StaticResource CyanColor}" BlurRadius="6" ShadowDepth="0" Opacity="0.9"/></Path.Effect>
                    </Path>
                </Canvas>

                <!-- TOP CHROME ROW: top 36, padding-x 64, transparent (no gradient bar) -->
                <Grid VerticalAlignment="Top" Margin="64,32,64,0" Height="120">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left">
                        <Image x:Name="HeaderLogo" Source="Assets/clinicapc-logo.png" Height="112" Margin="0,0,14,0" RenderTransformOrigin="0.5,0.5">
                            <Image.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform x:Name="HeaderLogoScale" ScaleX="1" ScaleY="1"/>
                                    <TranslateTransform x:Name="HeaderLogoTranslate" X="0" Y="0"/>
                                </TransformGroup>
                            </Image.RenderTransform>
                            <Image.Effect>
                                <DropShadowEffect x:Name="HeaderLogoGlow" Color="{StaticResource CyanColor}" BlurRadius="20" ShadowDepth="0" Opacity="0.75"/>
                            </Image.Effect>
                        </Image>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
                        <TextBlock Style="{StaticResource MonoFont}" Foreground="{StaticResource Text2Brush}" FontSize="14" VerticalAlignment="Center" Margin="0,0,32,0">
                            <Run Text="SKU "/><Run Text="{Binding DisplayConfig.Sku}" Foreground="{StaticResource Text0Brush}" FontWeight="Bold"/>
                        </TextBlock>
                        <TextBlock Text="{Binding CurrentScreenName}" edit:Editable.IsOn="False" Style="{StaticResource MonoFont}" Foreground="{StaticResource Text2Brush}" FontSize="14" VerticalAlignment="Center" Margin="0,0,32,0"/>
                        <TextBlock Text="{Binding CurrentTimeString}" edit:Editable.IsOn="False" Style="{StaticResource MonoFont}" Foreground="{StaticResource Text2Brush}" FontSize="14" VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>

                <!-- BOTTOM CHROME ROW: bottom 36, padding-x 64, transparent -->
                <Grid VerticalAlignment="Bottom" Margin="64,0,64,36" Height="24">
                    <TextBlock Style="{StaticResource MonoFont}" Foreground="{StaticResource Text2Brush}"
                               FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Left">
                        <Run Text="CLINICAPC · "/><Run Text="{Binding DisplayConfig.ShopAddress}" Foreground="{StaticResource Text0Brush}"/>
                    </TextBlock>
                    <TextBlock Style="{StaticResource MonoFont}" Foreground="{StaticResource Text2Brush}"
                               FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Right"
                               Text="{Binding DisplayConfig.ShopServices}"/>
                </Grid>
            </Grid>

        </Grid>
    </Viewbox>

        <!-- ===== OVERLAY (fuera del Viewbox: fijo, sobre todo) ===== -->
        <Border x:Name="SettingsHotspot" Width="120" Height="120"
                HorizontalAlignment="Right" VerticalAlignment="Top"
                Background="Transparent" Panel.ZIndex="100"
                MouseLeftButtonDown="SettingsHotspot_MouseDown"/>

        <Border x:Name="EditToolbar" VerticalAlignment="Top" HorizontalAlignment="Center"
                Margin="0,18,0,0" Panel.ZIndex="100"
                Background="#F20A0716" BorderBrush="#FFF37A4A" BorderThickness="1" CornerRadius="12"
                Padding="18,10"
                Visibility="{Binding EditMode.IsActive, Converter={StaticResource BoolToVis}}">
            <Border.Effect>
                <DropShadowEffect Color="#FFF37A4A" BlurRadius="24" ShadowDepth="0" Opacity="0.4"/>
            </Border.Effect>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Ellipse Width="10" Height="10" Fill="#FFF37A4A" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock Text="MODO EDICIÓN" FontFamily="{StaticResource JetBrainsMono}" FontWeight="Bold" Foreground="White" FontSize="14" VerticalAlignment="Center"/>
                <TextBlock Text="· toca cualquier texto para editarlo" FontFamily="{StaticResource JetBrainsMono}" Foreground="{StaticResource Text2Brush}" FontSize="12" VerticalAlignment="Center" Margin="8,0,0,0"/>
                <Rectangle Width="1" Height="22" Fill="{StaticResource Line2Brush}" Margin="18,0,18,0"/>
                <TextBlock Text="pantalla" FontFamily="{StaticResource JetBrainsMono}" Foreground="{StaticResource Text2Brush}" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <Button Content="Espera" Click="EditGoAttract_Click" Style="{StaticResource SecondaryButton}" Padding="10,6" Margin="0,0,6,0"/>
                <Button Content="Escaneo" Click="EditGoScan_Click" Style="{StaticResource SecondaryButton}" Padding="10,6" Margin="0,0,6,0"/>
                <Button Content="Resumen" Click="EditGoMain_Click" Style="{StaticResource SecondaryButton}" Padding="10,6" Margin="0,0,6,0"/>
                <Button Content="Detalle" Click="EditGoDetail_Click" Style="{StaticResource SecondaryButton}" Padding="10,6"/>
                <StackPanel Orientation="Horizontal" Margin="18,0,0,0" Visibility="{Binding IsAttractScreen, Converter={StaticResource BoolToVis}}">
                    <Button Content="◀" Click="EditPrevSlide_Click" Style="{StaticResource SecondaryButton}" Padding="10,6" Margin="0,0,6,0"/>
                    <TextBlock Text="slide" FontFamily="{StaticResource JetBrainsMono}" Foreground="{StaticResource Text2Brush}" FontSize="12" VerticalAlignment="Center"/>
                    <Button Content="▶" Click="EditNextSlide_Click" Style="{StaticResource SecondaryButton}" Padding="10,6" Margin="6,0,0,0"/>
                </StackPanel>
                <Rectangle Width="1" Height="22" Fill="{StaticResource Line2Brush}" Margin="18,0,18,0"/>
                <Button Content="Guardar" Click="EditSave_Click" Style="{StaticResource PrimaryButton}" Padding="18,8" Margin="0,0,8,0"/>
                <Button Content="Descartar" Click="EditDiscard_Click" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0"/>
                <Button Content="Salir" Click="EditExit_Click" Style="{StaticResource SecondaryButton}"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>