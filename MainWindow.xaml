<Window x:Class="KioskClinicaPC.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:KioskClinicaPC"
        xmlns:core="clr-namespace:KioskClinicaPC.Core"
        xmlns:edit="clr-namespace:KioskClinicaPC.Controls"
        mc:Ignorable="d"
        Title="KioskClinicaPC"
        Foreground="{StaticResource Text0Brush}"
        FontFamily="{StaticResource SpaceGrotesk}"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowState="Maximized"
        Topmost="True"
        Loaded="Window_Loaded"
        Closing="Window_Closing"
        KeyDown="Window_KeyDown"
        PreviewMouseLeftButtonDown="Window_PreviewMouseLeftButtonDown"
        Background="Black">
    
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <core:LeftMarginConverter x:Key="LeftMarginConverter"/>
        <core:StringToBrushConverter x:Key="StringBrushConverter"/>
        <core:PathToImageConverter x:Key="PathToImage"/>
        <core:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis"/>
        
        <Style TargetType="TextBlock" x:Key="DisplayFont">
            <Setter Property="FontFamily" Value="{StaticResource ChakraPetch}"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="MonoFont">
            <Setter Property="FontFamily" Value="{StaticResource JetBrainsMono}"/>
        </Style>
    </Window.Resources>

    <Grid x:Name="WindowRoot">
    <Viewbox Stretch="Uniform" StretchDirection="Both" UseLayoutRounding="True" SnapsToDevicePixels="True">
        <Grid x:Name="RootGrid" Width="1920" Height="1080" ClipToBounds="True" Background="{StaticResource Bg0Brush}"
              TextOptions.TextFormattingMode="Ideal" TextOptions.TextRenderingMode="ClearType"
              RenderOptions.BitmapScalingMode="HighQuality">
            
            <!-- ================= AMBIENT BACKGROUNDS ================= -->
            <Grid IsHitTestVisible="False">
                <!-- bg-mesh: 5 gradient layers matching CSS mockup -->
                <!-- radial-gradient(70% 55% at 82% 12%, magenta 24%, transparent 65%) -->
                <Rectangle Opacity="0.24">
                    <Rectangle.Fill>
                        <RadialGradientBrush Center="0.82,0.12" GradientOrigin="0.82,0.12" RadiusX="0.70" RadiusY="0.55">
                            <GradientStop Color="{StaticResource MagentaColor}" Offset="0"/>
                            <GradientStop Color="Transparent" Offset="0.65"/>
                        </RadialGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>
                <!-- radial-gradient(65% 50% at 12% 92%, cyan 28%, transparent 65%) -->
                <Rectangle Opacity="0.28">
                    <Rectangle.Fill>
                        <RadialGradientBrush Center="0.12,0.92" GradientOrigin="0.12,0.92" RadiusX="0.65" RadiusY="0.50">
                            <GradientStop Color="{StaticResource CyanColor}" Offset="0"/>
                            <GradientStop Color="Transparent" Offset="0.65"/>
                        </RadialGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>
                <!-- radial-gradient(55% 45% at 50% 55%, deep warm 32%, transparent 70%) -->
                <Rectangle Opacity="0.32">
                    <Rectangle.Fill>
                        <RadialGradientBrush Center="0.50,0.55" GradientOrigin="0.50,0.55" RadiusX="0.55" RadiusY="0.45">
                            <GradientStop Color="#CC3D00" Offset="0"/>
                            <GradientStop Color="Transparent" Offset="0.70"/>
                        </RadialGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>
                <!-- radial-gradient(45% 40% at 95% 78%, purple 60%, transparent 70%) -->
                <Rectangle Opacity="0.60">
                    <Rectangle.Fill>
                        <RadialGradientBrush Center="0.95,0.78" GradientOrigin="0.95,0.78" RadiusX="0.45" RadiusY="0.40">
                            <GradientStop Color="#331A66" Offset="0"/>
                            <GradientStop Color="Transparent" Offset="0.70"/>
                        </RadialGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>
                <!-- linear-gradient(180deg, bg-0, bg-1 55%, #07050f) -->
                <Rectangle>
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="{StaticResource Bg0Color}" Offset="0"/>
                            <GradientStop Color="{StaticResource Bg1Color}" Offset="0.55"/>
                            <GradientStop Color="#07050f" Offset="1"/>
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>

                <!-- bg-grid: 80px tiles with radial mask -->
                <Rectangle Opacity="0.05">
                    <Rectangle.OpacityMask>
                        <RadialGradientBrush Center="0.5,0.5" RadiusX="0.45" RadiusY="0.35">
                            <GradientStop Color="Black" Offset="0.3"/>
                            <GradientStop Color="Transparent" Offset="0.8"/>
                        </RadialGradientBrush>
                    </Rectangle.OpacityMask>
                    <Rectangle.Fill>
                        <DrawingBrush Viewport="0,0,80,80" ViewportUnits="Absolute" TileMode="Tile">
                            <DrawingBrush.Drawing>
                                <DrawingGroup>
                                    <GeometryDrawing>
                                        <GeometryDrawing.Pen>
                                            <Pen Brush="White" Thickness="1"/>
                                        </GeometryDrawing.Pen>
                                        <GeometryDrawing.Geometry>
                                            <GeometryGroup>
                                                <LineGeometry StartPoint="0,0" EndPoint="80,0"/>
                                                <LineGeometry StartPoint="0,0" EndPoint="0,80"/>
                                            </GeometryGroup>
                                        </GeometryDrawing.Geometry>
                                    </GeometryDrawing>
                                </DrawingGroup>
                            </DrawingBrush.Drawing>
                        </DrawingBrush>
                    </Rectangle.Fill>
                </Rectangle>

                <!-- bg-grid fine: 16px sub-grid -->
                <Rectangle Opacity="0.03">
                    <Rectangle.OpacityMask>
                        <RadialGradientBrush Center="0.5,0.5" RadiusX="0.45" RadiusY="0.35">
                            <GradientStop Color="Black" Offset="0.3"/>
                            <GradientStop Color="Transparent" Offset="0.8"/>
                        </RadialGradientBrush>
                    </Rectangle.OpacityMask>
                    <Rectangle.Fill>
                        <DrawingBrush Viewport="0,0,16,16" ViewportUnits="Absolute" TileMode="Tile">
                            <DrawingBrush.Drawing>
                                <DrawingGroup>
                                    <GeometryDrawing>
                                        <GeometryDrawing.Pen>
                                            <Pen Brush="White" Thickness="1"/>
                                        </GeometryDrawing.Pen>
                                        <GeometryDrawing.Geometry>
                                            <GeometryGroup>
                                                <LineGeometry StartPoint="0,0" EndPoint="16,0"/>
                                                <LineGeometry StartPoint="0,0" EndPoint="0,16"/>
                                            </GeometryGroup>
                                        </GeometryDrawing.Geometry>
                                    </GeometryDrawing>
                                </DrawingGroup>
                            </DrawingBrush.Drawing>
                        </DrawingBrush>
                    </Rectangle.Fill>
                </Rectangle>

                <!-- bg-scanlines: repeating 4px horizontal lines -->
                <Rectangle Opacity="0.025">
                    <Rectangle.Fill>
                        <DrawingBrush Viewport="0,0,10,4" ViewportUnits="Absolute" TileMode="Tile">
                            <DrawingBrush.Drawing>
                                <GeometryDrawing Brush="White">
                                    <GeometryDrawing.Geometry>
                                        <RectangleGeometry Rect="0,2,10,1"/>
                                    </GeometryDrawing.Geometry>
                                </GeometryDrawing>
                            </DrawingBrush.Drawing>
                        </DrawingBrush>
                    </Rectangle.Fill>
                </Rectangle>

                <!-- bg-noise: tiled noise pattern at 5% opacity -->
                <Rectangle Opacity="0.05">
                    <Rectangle.Fill>
                        <DrawingBrush Viewport="0,0,4,4" ViewportUnits="Absolute" TileMode="Tile">
                            <DrawingBrush.Drawing>
                                <DrawingGroup>
                                    <GeometryDrawing Brush="#40FFFFFF"><GeometryDrawing.Geometry><RectangleGeometry Rect="0,0,1,1"/></GeometryDrawing.Geometry></GeometryDrawing>
                                    <GeometryDrawing Brush="#20FFFFFF"><GeometryDrawing.Geometry><RectangleGeometry Rect="2,1,1,1"/></GeometryDrawing.Geometry></GeometryDrawing>
                                    <GeometryDrawing Brush="#30FFFFFF"><GeometryDrawing.Geometry><RectangleGeometry Rect="1,3,1,1"/></GeometryDrawing.Geometry></GeometryDrawing>
                                    <GeometryDrawing Brush="#10FFFFFF"><GeometryDrawing.Geometry><RectangleGeometry Rect="3,2,1,1"/></GeometryDrawing.Geometry></GeometryDrawing>
                                </DrawingGroup>
                            </DrawingBrush.Drawing>
                        </DrawingBrush>
                    </Rectangle.Fill>
                </Rectangle>

                <!-- bg-vignette eliminado (feedback v4 sesión 2): radios 0.40/0.35 dibujaban óvalo oscuro
                     en lugar de oscurecer esquinas. Visible en todas las pantallas. Comentado por si se
                     quiere restaurar con radios mayores (RadiusX/Y >= 0.80) y opacidad menor.
                <Rectangle>
                    <Rectangle.Fill>
                        <RadialGradientBrush Center="0.5,0.5" GradientOrigin="0.5,0.5" RadiusX="0.40" RadiusY="0.35">
                            <GradientStop Color="Transparent" Offset="0.50"/>
                            <GradientStop Color="#D9000000" Offset="1"/>
                        </RadialGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>
                -->


                <!-- Particle Layer -->
                <Canvas x:Name="ParticleCanvas" IsHitTestVisible="False"/>
            </Grid>

            <!-- ================= SCREENS ================= -->
            <Grid x:Name="ScreensContainer">
                
                <!-- ====== SCREEN 0: ATTRACT ====== -->
                <Grid x:Name="Screen0_Attract" Visibility="Visible" Opacity="1">
                    <Grid.Background>
                        <SolidColorBrush Color="Transparent"/>
                    </Grid.Background>
                    
                    <Rectangle Fill="Transparent" MouseLeftButtonDown="AttractScreen_Click" />

                    <!-- Wireframe orb behind text (monochrome orange, sphere-like) -->
                    <Viewbox Width="1480" Height="1480" HorizontalAlignment="Center" VerticalAlignment="Center"
                             Margin="0,-60,0,0" Opacity="1.0" IsHitTestVisible="False">
                        <Canvas Width="100" Height="100">
                            <Canvas.Effect>
                                <DropShadowEffect Color="{StaticResource CyanColor}" BlurRadius="22"
                                                  ShadowDepth="0" Opacity="0.7"/>
                            </Canvas.Effect>

                            <!-- Outer ring -->
                            <Ellipse Canvas.Left="2" Canvas.Top="2" Width="96" Height="96"
                                     Stroke="{StaticResource CyanBrush}" StrokeThickness="0.28" Fill="Transparent"/>

                            <!-- Latitudes (top half) -->
                            <Ellipse Canvas.Left="2" Canvas.Top="3.0"  Width="96" Height="91.2" Stroke="{StaticResource CyanBrush}" StrokeThickness="0.22" Fill="Transparent" Opacity="0.85"/>
                            <Ellipse Canvas.Left="2" Canvas.Top="6.5"  Width="96" Height="84.6" Stroke="{StaticResource CyanBrush}" StrokeThickness="0.22" Fill="Transparent" Opacity="0.80"/>
                            <Ellipse Canvas.Left="2" Canvas.Top="10.5" Width="96" Height="76.4" Stroke="{StaticResource CyanBrush}" StrokeThickness="0.22" Fill="Transparent" Opacity="0.75"/>
                            <Ellipse Canvas.Left="2" Canvas.Top="15.0" Width="96" Height="67.0" Stroke="{StaticResource CyanBrush}" StrokeThickness="0.22" Fill="Transparent" Opacity="0.70"/>
                            <Ellipse Canvas.Left="2" Canvas.Top="19.5" Width="96" Height="56.0" Stroke="{StaticResource CyanBrush}" StrokeThickness="0.22" Fill="Transparent" Opacity="0.65"/>
                            <Ellipse Canvas.Left="2" Canvas.Top="24.5" Width="96" Height="44.0" Stroke="{StaticResource CyanBrush}" StrokeThickness="0.22" Fill="Transparent" Opacity="0.60"/>
                            <Ellipse Canvas.Left="2" Canvas.Top="30.0" Width="96" Height="30.0" Stroke="{StaticResource CyanBrush}" StrokeThickness="0.22" Fill="Transparent" Opacity="0.55"/>
                            <Ellipse Canvas.Left="2" Canvas.Top="36.0" Width="96" Height="16.0" Stroke="{StaticResource CyanBrush}" StrokeThickness="0.22" Fill="Transparent" Opacity="0.50"/>

                            <!-- Equator (refuerzo) -->
                            <Ellipse Canvas.Left="2" Canvas.Top="49.5" Width="96" Height="1.0" Stroke="{StaticResource CyanBrush}" StrokeThickness="0.32" Fill="Transparent" Opacity="1.0"/>

                            <!-- Latitudes (bottom half, mirror) -->
                            <Ellipse Canvas.Left="2" Canvas.Top="48.0" Width="96" Height="16.0" Stroke="{StaticResource CyanBrush}" StrokeThickness="0.22" Fill="Transparent" Opacity="0.50"/>
                            <Ellipse Canvas.Left="2" Canvas.Top="40.0" Width="96" Height="30.0" Stroke="{StaticResource CyanBrush}" StrokeThickness="0.22" Fill="Transparent" Opacity="0.55"/>
                            <Ellipse Canvas.Left="2" Canvas.Top="33.5" Width="96" Height="44.0" Stroke="{StaticResource CyanBrush}" StrokeThickness="0.22" Fill="Transparent" Opacity="0.60"/>
                            <Ellipse Canvas.Left="2" Canvas.Top="27.0" Width="96" Height="56.0" Stroke="{StaticResource CyanBrush}" StrokeThickness="0.22" Fill="Transparent" Opacity="0.65"/>
                            <Ellipse Canvas.Left="2" Canvas.Top="21.5" Width="96" Height="67.0" Stroke="{StaticResource CyanBrush}" StrokeThickness="0.22" Fill="Transparent" Opacity="0.70"/>
                            <Ellipse Canvas.Left="2" Canvas.Top="16.5" Width="96" Height="76.4" Stroke="{StaticResource CyanBrush}" StrokeThickness="0.22" Fill="Transparent" Opacity="0.75"/>
                            <Ellipse Canvas.Left="2" Canvas.Top="11.5" Width="96" Height="84.6" Stroke="{StaticResource CyanBrush}" StrokeThickness="0.22" Fill="Transparent" Opacity="0.80"/>
                            <Ellipse Canvas.Left="2" Canvas.Top="7.0"  Width="96" Height="91.2" Stroke="{StaticResource CyanBrush}" StrokeThickness="0.22" Fill="Transparent" Opacity="0.85"/>

                            <!-- Longitudes (vertical ellipses) -->
                            <Ellipse Canvas.Left="49.5" Canvas.Top="2" Width="1.0"  Height="96" Stroke="{StaticResource CyanBrush}" StrokeThickness="0.32" Fill="Transparent" Opacity="0.95"/>
                            <Ellipse Canvas.Left="46"   Canvas.Top="2" Width="8"    Height="96" Stroke="{StaticResource CyanBrush}" StrokeThickness="0.18" Fill="Transparent" Opacity="0.70"/>
                            <Ellipse Canvas.Left="42"   Canvas.Top="2" Width="16"   Height="96" Stroke="{StaticResource CyanBrush}" StrokeThickness="0.18" Fill="Transparent" Opacity="0.65"/>
                            <Ellipse Canvas.Left="37"   Canvas.Top="2" Width="26"   Height="96" Stroke="{StaticResource CyanBrush}" StrokeThickness="0.18" Fill="Transparent" Opacity="0.60"/>
                            <Ellipse Canvas.Left="31"   Canvas.Top="2" Width="38"   Height="96" Stroke="{StaticResource CyanBrush}" StrokeThickness="0.18" Fill="Transparent" Opacity="0.55"/>
                            <Ellipse Canvas.Left="24"   Canvas.Top="2" Width="52"   Height="96" Stroke="{StaticResource CyanBrush}" StrokeThickness="0.18" Fill="Transparent" Opacity="0.50"/>
                            <Ellipse Canvas.Left="16"   Canvas.Top="2" Width="68"   Height="96" Stroke="{StaticResource CyanBrush}" StrokeThickness="0.18" Fill="Transparent" Opacity="0.45"/>
                            <Ellipse Canvas.Left="8"    Canvas.Top="2" Width="84"   Height="96" Stroke="{StaticResource CyanBrush}" StrokeThickness="0.18" Fill="Transparent" Opacity="0.40"/>
                        </Canvas>
                    </Viewbox>

                    <!-- Vignette interior eliminado (feedback v4): dibujaba "halo ovalado" gris en el centro.
                         Conservado comentado por si hace falta restaurar.
                    <Rectangle IsHitTestVisible="False" Opacity="0.85">
                        <Rectangle.Fill>
                            <RadialGradientBrush Center="0.5,0.5" GradientOrigin="0.5,0.5" RadiusX="0.32" RadiusY="0.26">
                                <GradientStop Color="#E6000000" Offset="0"/>
                                <GradientStop Color="#73000000" Offset="0.55"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </RadialGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>
                    -->


                    <!-- Center content (eyebrow + 2 titles + subtitle + CTA + hint, all flowing) -->
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="{Binding EditMode.IsActive}" MaxWidth="1760" MaxHeight="940">
                        <!-- Eyebrow with line decorations -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,28">
                            <Rectangle Width="28" Height="1" Fill="{StaticResource CyanBrush}" VerticalAlignment="Center" Margin="0,0,14,0"/>
                            <TextBlock Text="{Binding CurrentSlide.Eyebrow}" Style="{StaticResource MonoFont}" Foreground="{StaticResource CyanBrush}" FontSize="13"/>
                            <Rectangle Width="28" Height="1" Fill="{StaticResource CyanBrush}" VerticalAlignment="Center" Margin="14,0,0,0"/>
                        </StackPanel>

                        <!-- 168px titles: auto-encogen a una caja fija para que el slide más largo no empuje el CTA al borde -->
                        <Viewbox StretchDirection="DownOnly" Stretch="Uniform" HorizontalAlignment="Center" MaxWidth="1280" MaxHeight="360" Margin="0,0,0,12">
                          <TextBlock Text="{Binding CurrentSlide.Title1}" Style="{StaticResource DisplayFont}" FontSize="168" Foreground="{StaticResource Text0Brush}" TextAlignment="Center" LineHeight="160" LineStackingStrategy="BlockLineHeight" TextWrapping="Wrap" Width="1280"/>
                        </Viewbox>

                        <!-- Title 2 — wraps to ~3 lines (matches mockup), clean orange neon (no chromatic glitch) -->
                        <Viewbox StretchDirection="DownOnly" Stretch="Uniform" HorizontalAlignment="Center" MaxWidth="1280" MaxHeight="360">
                        <Grid HorizontalAlignment="Center">
                            <!-- Neon core layer (tight blur, dense) -->
                            <TextBlock Text="{Binding CurrentSlide.Title2}" edit:Editable.IsOn="False" Style="{StaticResource DisplayFont}" FontSize="168" Foreground="{StaticResource CyanBrush}" TextAlignment="Center" LineHeight="160" LineStackingStrategy="BlockLineHeight" TextWrapping="Wrap" Width="1280" Opacity="0.6">
                                <TextBlock.Effect>
                                    <DropShadowEffect Color="{StaticResource CyanColor}" BlurRadius="16" ShadowDepth="0" Opacity="1"/>
                                </TextBlock.Effect>
                            </TextBlock>
                            <!-- Base title (wide halo) — gradient vertical: melocotón → naranja → dorado (feedback v4) -->
                            <TextBlock Text="{Binding CurrentSlide.Title2}" Style="{StaticResource DisplayFont}" FontSize="168" TextAlignment="Center" LineHeight="160" LineStackingStrategy="BlockLineHeight" TextWrapping="Wrap" Width="1280">
                                <TextBlock.Foreground>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#FF8C6E" Offset="0"/>
                                        <GradientStop Color="#F37A4A" Offset="0.45"/>
                                        <GradientStop Color="#FFC857" Offset="1"/>
                                    </LinearGradientBrush>
                                </TextBlock.Foreground>
                                <TextBlock.Effect>
                                    <DropShadowEffect Color="{StaticResource CyanColor}" BlurRadius="48" ShadowDepth="0" Opacity="0.85"/>
                                </TextBlock.Effect>
                            </TextBlock>
                        </Grid>
                        </Viewbox>

                        <!-- Subtitle -->
                        <TextBlock Text="{Binding CurrentSlide.Subtitle}" edit:Editable.Multiline="True" Foreground="{StaticResource Text1Brush}" FontSize="22" TextAlignment="Center" Margin="0,38,0,0" MaxWidth="1100" TextWrapping="Wrap"/>

                        <!-- CTA Button (HUD bracket-corner style) -->
                        <Grid HorizontalAlignment="Center" Margin="0,48,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Border x:Name="PulseButton" Grid.Row="1" Grid.Column="1"
                                    Background="#10F37A4A" BorderBrush="{StaticResource CyanBrush}" BorderThickness="2"
                                    Padding="36,18">
                                <Border.Effect>
                                    <DropShadowEffect Color="{StaticResource CyanColor}" BlurRadius="24" ShadowDepth="0" Opacity="0.35"/>
                                </Border.Effect>
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="12" Height="12" Fill="{StaticResource CyanBrush}" VerticalAlignment="Center" Margin="0,0,16,0">
                                        <Ellipse.Effect>
                                            <DropShadowEffect Color="{StaticResource CyanColor}" BlurRadius="12" ShadowDepth="0" Opacity="0.9"/>
                                        </Ellipse.Effect>
                                    </Ellipse>
                                    <TextBlock Text="{Binding Texts[attract.cta]}" Style="{StaticResource DisplayFont}" Foreground="{StaticResource Text0Brush}" FontSize="22"/>
                                </StackPanel>
                                <Border.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                <DoubleAnimation Storyboard.TargetProperty="(Border.Effect).(DropShadowEffect.Opacity)" From="0.30" To="0.55" Duration="0:0:1.1"/>
                                                <DoubleAnimation Storyboard.TargetProperty="(Border.Effect).(DropShadowEffect.BlurRadius)" From="24" To="36" Duration="0:0:1.1"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Border.Triggers>
                            </Border>

                            <!-- 4 L-bracket corners -->
                            <Path Grid.Row="0" Grid.Column="0" Stroke="{StaticResource CyanBrush}" StrokeThickness="2"
                                  Data="M 0,14 L 0,0 L 14,0">
                                <Path.Effect><DropShadowEffect Color="{StaticResource CyanColor}" BlurRadius="6" ShadowDepth="0" Opacity="0.9"/></Path.Effect>
                            </Path>
                            <Path Grid.Row="0" Grid.Column="2" Stroke="{StaticResource CyanBrush}" StrokeThickness="2"
                                  Data="M 0,0 L 14,0 L 14,14">
                                <Path.Effect><DropShadowEffect Color="{StaticResource CyanColor}" BlurRadius="6" ShadowDepth="0" Opacity="0.9"/></Path.Effect>
                            </Path>
                            <Path Grid.Row="2" Grid.Column="0" Stroke="{StaticResource CyanBrush}" StrokeThickness="2"
                                  Data="M 0,0 L 0,14 L 14,14">
                                <Path.Effect><DropShadowEffect Color="{StaticResource CyanColor}" BlurRadius="6" ShadowDepth="0" Opacity="0.9"/></Path.Effect>
                            </Path>
                            <Path Grid.Row="2" Grid.Column="2" Stroke="{StaticResource CyanBrush}" StrokeThickness="2"
                                  Data="M 0,14 L 14,14 L 14,0">
                                <Path.Effect><DropShadowEffect Color="{StaticResource CyanColor}" BlurRadius="6" ShadowDepth="0" Opacity="0.9"/></Path.Effect>
                            </Path>
                        </Grid>
                        <TextBlock Text="{Binding Texts[attract.hint]}" Style="{StaticResource MonoFont}" Foreground="{StaticResource Text2Brush}" FontSize="13" HorizontalAlignment="Center" Margin="0,22,0,0"/>
                    </StackPanel>

                    <!-- Slide indicator dots -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,110" IsHitTestVisible="False">
                        <Rectangle x:Name="SlideDot0" Width="32" Height="4" Fill="{StaticResource CyanBrush}" Margin="0,0,10,0">
                            <Rectangle.Effect>
                                <DropShadowEffect Color="{StaticResource CyanColor}" BlurRadius="10" ShadowDepth="0" Opacity="0.8"/>
                            </Rectangle.Effect>
                        </Rectangle>
                        <Rectangle x:Name="SlideDot1" Width="8" Height="4" Fill="#33FFFFFF" Margin="0,0,10,0"/>
                        <Rectangle x:Name="SlideDot2" Width="8" Height="4" Fill="#33FFFFFF"/>
                    </StackPanel>
                </Grid>

                <!-- ====== SCREEN 1: SCAN ====== -->
                <Grid x:Name="Screen1_Scan" Visibility="Collapsed" Opacity="0">
                    <Grid>
                        <!-- Huge Radar -->
                        <Grid Width="720" Height="720" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <!-- 5 concentric circles (radii 100/78/56/34/14% of 720 → symmetric margins) -->
                            <Ellipse Stroke="#4DF37A4A" StrokeThickness="1"/>
                            <Ellipse Stroke="#4DF37A4A" StrokeThickness="1" Margin="79"/>
                            <Ellipse Stroke="#4DF37A4A" StrokeThickness="1" Margin="158"/>
                            <Ellipse Stroke="#4DF37A4A" StrokeThickness="1" Margin="238"/>
                            <Ellipse Stroke="#4DF37A4A" StrokeThickness="1" Margin="310"/>
                            <!-- Crosshair lines -->
                            <Rectangle Height="1" Fill="#4DF37A4A" VerticalAlignment="Center"/>
                            <Rectangle Width="1" Fill="#4DF37A4A" HorizontalAlignment="Center"/>
                            <!-- Conic-gradient sweep, approximated with a pie wedge that fades along its
                                 trailing edge. Pivots on the radar CENTRE (360,360); using
                                 RenderTransformOrigin here would pivot on the wedge's own bbox and make
                                 it orbit off-centre (the old "rota y bugeada" bug). -->
                            <Path Fill="{StaticResource CyanBrush}" Opacity="0.30" Data="M 360 360 L 360 0 A 360 360 0 0 1 614.7 180 Z">
                                <Path.OpacityMask>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#88FFFFFF" Offset="0"/>
                                        <GradientStop Color="Transparent" Offset="1"/>
                                    </LinearGradientBrush>
                                </Path.OpacityMask>
                                <Path.RenderTransform>
                                    <RotateTransform x:Name="ScanRadarTransform" Angle="0" CenterX="360" CenterY="360"/>
                                </Path.RenderTransform>
                            </Path>
                            <!-- Center dot with heavy glow -->
                            <Ellipse Width="18" Height="18" Fill="{StaticResource CyanBrush}" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Ellipse.Effect>
                                    <DropShadowEffect Color="{StaticResource CyanColor}" BlurRadius="60" ShadowDepth="0" Opacity="1"/>
                                </Ellipse.Effect>
                            </Ellipse>
                            <!-- Ping blips -->
                            <Canvas x:Name="BlipCanvas" IsHitTestVisible="False">
                                <Ellipse Canvas.Left="216" Canvas.Top="288" Width="8" Height="8" Fill="{StaticResource MagentaBrush}">
                                    <Ellipse.Effect><DropShadowEffect Color="{StaticResource MagentaColor}" BlurRadius="12" ShadowDepth="0"/></Ellipse.Effect>
                                </Ellipse>
                                <Ellipse Canvas.Left="490" Canvas.Top="202" Width="8" Height="8" Fill="{StaticResource MagentaBrush}">
                                    <Ellipse.Effect><DropShadowEffect Color="{StaticResource MagentaColor}" BlurRadius="12" ShadowDepth="0"/></Ellipse.Effect>
                                </Ellipse>
                                <Ellipse Canvas.Left="144" Canvas.Top="518" Width="8" Height="8" Fill="{StaticResource MagentaBrush}">
                                    <Ellipse.Effect><DropShadowEffect Color="{StaticResource MagentaColor}" BlurRadius="12" ShadowDepth="0"/></Ellipse.Effect>
                                </Ellipse>
                                <Ellipse Canvas.Left="562" Canvas.Top="576" Width="8" Height="8" Fill="{StaticResource MagentaBrush}">
                                    <Ellipse.Effect><DropShadowEffect Color="{StaticResource MagentaColor}" BlurRadius="12" ShadowDepth="0"/></Ellipse.Effect>
                                </Ellipse>
                                <Ellipse Canvas.Left="374" Canvas.Top="130" Width="8" Height="8" Fill="{StaticResource MagentaBrush}">
                                    <Ellipse.Effect><DropShadowEffect Color="{StaticResource MagentaColor}" BlurRadius="12" ShadowDepth="0"/></Ellipse.Effect>
                                </Ellipse>
                            </Canvas>
                        </Grid>

                        <!-- Log area at bottom left -->
                        <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="120,0,0,120">
                            <TextBlock Text="{Binding Texts[scan.logTitle]}" Style="{StaticResource MonoFont}" FontSize="13" Foreground="{StaticResource CyanBrush}" Margin="0,0,0,16"/>
                            <ItemsControl x:Name="ScanLogControl" ItemsSource="{Binding ScanLogs}" Width="720">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="40"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Time}" edit:Editable.IsOn="False" Style="{StaticResource MonoFont}" Foreground="{StaticResource Text3Brush}" FontSize="14" Grid.Column="0"/>
                                            <TextBlock Text="{Binding Step}" edit:Editable.IsOn="False" Style="{StaticResource MonoFont}" Foreground="{Binding Color, Converter={StaticResource StringBrushConverter}}" FontSize="14" Grid.Column="1" Margin="14,0,0,0"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <!-- % counter at bottom right -->
                        <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="0,0,120,120">
                            <TextBlock Text="{Binding Texts[scan.progress]}" Style="{StaticResource MonoFont}" FontSize="13" Foreground="{StaticResource CyanBrush}" Margin="0,0,0,12" HorizontalAlignment="Right"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBlock x:Name="ScanProgressText" Text="000" edit:Editable.IsOn="False" Style="{StaticResource DisplayFont}" FontSize="220" Foreground="{StaticResource Text0Brush}" LineHeight="200"/>
                                <TextBlock Text="%" Style="{StaticResource DisplayFont}" FontSize="220" Foreground="{StaticResource CyanBrush}" LineHeight="200"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Grid>

                <!-- ====== SCREEN 2: MAIN HUD ====== -->
                <Grid x:Name="Screen2_Main" Visibility="Collapsed" Opacity="0">
                    
                    <!-- IDENTITY BLOCK — left column at top:180 -->
                    <StackPanel HorizontalAlignment="Left" VerticalAlignment="Top" Width="440" Margin="120,180,0,0">
                      <StackPanel Orientation="Horizontal" Margin="0,0,0,22">
                        <Rectangle Width="28" Height="1" Fill="{StaticResource CyanBrush}" VerticalAlignment="Center" Margin="0,0,14,0"/>
                        <TextBlock Text="{Binding Texts[hud.detected]}" Style="{StaticResource MonoFont}" FontSize="13" Foreground="{StaticResource CyanBrush}"/>
                      </StackPanel>

                      <!-- Marca/Modelo detectados: auto-encogen si el nombre real es largo (no se cortan) -->
                      <Viewbox StretchDirection="DownOnly" Stretch="Uniform" HorizontalAlignment="Left" MaxWidth="440" Margin="0,0,0,10">
                        <TextBlock Style="{StaticResource DisplayFont}" FontSize="58" LineHeight="58" Foreground="{StaticResource Text0Brush}" Text="{Binding DisplayConfig.ChassisName}"/>
                      </Viewbox>
                      <Viewbox StretchDirection="DownOnly" Stretch="Uniform" HorizontalAlignment="Left" MaxWidth="440">
                        <TextBlock Style="{StaticResource DisplayFont}" FontSize="58" LineHeight="58" Foreground="{StaticResource CyanBrush}" Text="{Binding DisplayConfig.ModelName}">
                          <TextBlock.Effect>
                            <DropShadowEffect Color="{StaticResource CyanColor}" BlurRadius="24" ShadowDepth="0" Opacity="0.6"/>
                          </TextBlock.Effect>
                        </TextBlock>
                      </Viewbox>

                      <TextBlock Foreground="{StaticResource Text1Brush}" FontSize="18" Margin="0,24,0,0">
                        <Run Text="{Binding DisplayConfig.Family}"/><Run Text=" · "/><Run Text="SKU " Foreground="{StaticResource Text2Brush}"/><Run Text="{Binding DisplayConfig.Sku}" Foreground="{StaticResource Text2Brush}"/>
                      </TextBlock>
                    
                      <StackPanel Orientation="Horizontal" Margin="0,32,0,0">
                        <Border Background="#0AFFFFFF" BorderBrush="{StaticResource Line2Brush}" BorderThickness="1" Padding="10,8" Margin="0,0,12,0">
                          <StackPanel Orientation="Horizontal">
                            <Ellipse Width="8" Height="8" Fill="{StaticResource OkBrush}" VerticalAlignment="Center" Margin="0,0,8,0">
                                <Ellipse.Effect>
                                    <DropShadowEffect Color="{StaticResource OkColor}" BlurRadius="10" ShadowDepth="0" Opacity="0.8"/>
                                </Ellipse.Effect>
                            </Ellipse>
                            <TextBlock Text="{Binding Texts[hud.badgeGrade]}" Style="{StaticResource MonoFont}" FontSize="11" Foreground="{StaticResource OkBrush}"/>
                          </StackPanel>
                        </Border>
                        <Border Background="#0AFFFFFF" BorderBrush="{StaticResource Line2Brush}" BorderThickness="1" Padding="10,8">
                          <TextBlock Text="{Binding Texts[hud.badgeWarranty]}" Style="{StaticResource MonoFont}" FontSize="11" Foreground="{StaticResource Text1Brush}"/>
                        </Border>
                      </StackPanel>
                    </StackPanel>

                    <!-- Product photo slot (centre-top) — drag a PNG of the unit onto it -->
                    <StackPanel HorizontalAlignment="Left" VerticalAlignment="Top" Width="780" Margin="600,150,0,0">
                        <TextBlock Text="{Binding Texts[hud.productView]}" Style="{StaticResource MonoFont}" FontSize="13" Foreground="{StaticResource Text2Brush}" Margin="0,0,0,14"/>
                        <Grid Height="326" AllowDrop="True" DragOver="ProductImage_DragOver" Drop="ProductImage_Drop">
                            <Border Background="#46140B24" BorderBrush="{StaticResource Line1Brush}" BorderThickness="1">
                                <Image Source="{Binding DisplayConfig.ProductImagePath, Converter={StaticResource PathToImage}}" Stretch="Uniform" Margin="20"/>
                            </Border>
                            <!-- corner brackets (top-left + bottom-right), 26×26 L marks -->
                            <Path Stroke="{StaticResource CyanBrush}" StrokeThickness="2" Width="26" Height="26" HorizontalAlignment="Left" VerticalAlignment="Top" Stretch="None" Data="M 0,26 L 0,0 L 26,0"/>
                            <Path Stroke="{StaticResource CyanBrush}" StrokeThickness="2" Width="26" Height="26" HorizontalAlignment="Right" VerticalAlignment="Bottom" Stretch="None" Data="M 0,26 L 26,26 L 26,0"/>
                        </Grid>
                    </StackPanel>

                    <!-- Component tile grid (bottom) — ordered, tappable, auto-cycling highlight -->
                    <StackPanel HorizontalAlignment="Left" VerticalAlignment="Top" Width="1260" Margin="120,540,0,0">
                        <TextBlock Text="{Binding Texts[hud.components]}" Style="{StaticResource MonoFont}" FontSize="13" Foreground="{StaticResource Text2Brush}" Margin="0,0,0,16"/>
                        <ItemsControl ItemsSource="{Binding Specs}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="5"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Click="SpecNode_Click" Height="158" Margin="0,0,14,14"
                                            Background="#AE140B24" BorderBrush="{StaticResource Line1Brush}" BorderThickness="1"
                                            Foreground="White" Cursor="Hand">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="RootBorder" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Padding="18,16,18,14">
                                                    <Border.Clip>
                                                        <PathGeometry Figures="M 0,0 L 238,0 L 238,146 L 226,158 L 0,158 Z"/>
                                                    </Border.Clip>
                                                    <Grid>
                                                        <Rectangle x:Name="HighlightBg" Fill="{StaticResource CyanBrush}" Opacity="0" />
                                                        <Grid>
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="*"/>
                                                                <RowDefinition Height="Auto"/>
                                                            </Grid.RowDefinitions>
                                                            <!-- top: icon + index -->
                                                            <Grid Grid.Row="0">
                                                                <Path x:Name="IconPath" Data="{Binding IconData, FallbackValue='M 0,0'}" Fill="{StaticResource Text1Brush}" Width="24" Height="24" Stretch="Uniform" HorizontalAlignment="Left"/>
                                                                <TextBlock Text="{Binding IndexText}" edit:Editable.IsOn="False" Style="{StaticResource MonoFont}" Foreground="{StaticResource Text3Brush}" FontSize="10" HorizontalAlignment="Right" VerticalAlignment="Top"/>
                                                            </Grid>
                                                            <!-- middle: label + value -->
                                                            <StackPanel Grid.Row="1" VerticalAlignment="Bottom">
                                                                <TextBlock x:Name="LblTxt" Text="{Binding Label}" Style="{StaticResource MonoFont}" Foreground="{StaticResource Text2Brush}" FontSize="10"/>
                                                                <TextBlock x:Name="ValTxt" Text="{Binding Value}" Style="{StaticResource DisplayFont}" Foreground="{StaticResource Text0Brush}" FontSize="18" Margin="0,5,0,0" TextWrapping="Wrap" TextTrimming="CharacterEllipsis"/>
                                                            </StackPanel>
                                                            <!-- footer: ver detalle -->
                                                            <TextBlock x:Name="CtaTxt" Grid.Row="2" Text="{Binding Texts[hud.tileCta], RelativeSource={RelativeSource AncestorType=Window}}" edit:Editable.IsOn="False" Style="{StaticResource MonoFont}" FontSize="10" Foreground="{StaticResource Text3Brush}" Margin="0,10,0,0"/>
                                                        </Grid>
                                                    </Grid>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <DataTrigger Binding="{Binding IsHighlighted}" Value="True">
                                                        <Setter TargetName="HighlightBg" Property="Opacity" Value="0.12" />
                                                        <Setter TargetName="RootBorder" Property="BorderBrush" Value="{StaticResource CyanBrush}" />
                                                        <Setter TargetName="RootBorder" Property="Effect">
                                                            <Setter.Value>
                                                                <DropShadowEffect Color="{StaticResource CyanColor}" BlurRadius="26" ShadowDepth="0" Opacity="0.45"/>
                                                            </Setter.Value>
                                                        </Setter>
                                                        <Setter TargetName="IconPath" Property="Fill" Value="{StaticResource CyanBrush}" />
                                                        <Setter TargetName="LblTxt" Property="Foreground" Value="{StaticResource CyanBrush}" />
                                                        <Setter TargetName="CtaTxt" Property="Foreground" Value="{StaticResource CyanBrush}" />
                                                    </DataTrigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="HighlightBg" Property="Opacity" Value="0.22" />
                                                        <Setter TargetName="RootBorder" Property="BorderBrush" Value="{StaticResource Text1Brush}" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- Right Price Strip -->
                    <StackPanel HorizontalAlignment="Right" VerticalAlignment="Top" Width="380" Margin="0,180,120,0">
                        <Border Background="#120A0A1A" BorderBrush="{StaticResource Line1Brush}" BorderThickness="1" Padding="26,28">
                            <StackPanel>
                                <TextBlock Text="{Binding Texts[price.label]}" Style="{StaticResource MonoFont}" Foreground="{StaticResource MagentaBrush}"/>
                                <StackPanel Orientation="Horizontal" Margin="0,12,0,0" VerticalAlignment="Bottom">
                                    <TextBlock Text="{Binding FormattedPrice}" edit:Editable.IsOn="False" Style="{StaticResource DisplayFont}" FontSize="88" Foreground="{StaticResource Text0Brush}" LineHeight="88"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0" Visibility="{Binding HasDiscount, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="{Binding FormattedOriginalPrice}" edit:Editable.IsOn="False" Foreground="{StaticResource Text2Brush}" FontSize="14" TextDecorations="Strikethrough" Margin="0,0,12,0"/>
                                    <TextBlock Text="{Binding FormattedDiscount}" edit:Editable.IsOn="False" Style="{StaticResource MonoFont}" Foreground="{StaticResource MagentaBrush}" FontSize="14"/>
                                </StackPanel>
                                
                                <Border Margin="0,22,0,0" Padding="12,14" Background="#0AFFFFFF" BorderBrush="{StaticResource Line1Brush}" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Texts[price.installments]}" Style="{StaticResource MonoFont}" FontSize="11" Foreground="{StaticResource Text2Brush}"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0" VerticalAlignment="Bottom">
                                            <TextBlock Text="{Binding Texts[price.installmentsPrefix]}" Style="{StaticResource DisplayFont}" FontSize="22" Foreground="{StaticResource Text0Brush}"/>
                                            <TextBlock Text="{Binding FormattedMonthly}" edit:Editable.IsOn="False" Style="{StaticResource DisplayFont}" FontSize="22" Foreground="{StaticResource Text0Brush}"/>
                                            <TextBlock Text="€" edit:Editable.IsOn="False" Style="{StaticResource DisplayFont}" FontSize="22" Foreground="{StaticResource Text0Brush}"/>
                                            <TextBlock Text="{Binding Texts[price.noInterest]}" Style="{StaticResource MonoFont}" FontSize="12" Foreground="{StaticResource Text2Brush}" Margin="8,0,0,2" VerticalAlignment="Bottom"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                                
                                <!-- Full-width CTA button -->
                                <Button Margin="0,22,0,0" Padding="16" Background="{StaticResource CyanBrush}" Foreground="#02121a" BorderThickness="0" Cursor="Hand" HorizontalContentAlignment="Center">
                                    <Button.Clip>
                                        <PathGeometry Figures="M 12,0 L 330,0 L 330,40 L 318,52 L 0,52 L 0,12 Z"/>
                                    </Button.Clip>
                                    <TextBlock Text="{Binding Texts[price.cta]}" Style="{StaticResource DisplayFont}" FontWeight="Bold" FontSize="16" TextAlignment="Center"/>
                                    <Button.Effect>
                                        <DropShadowEffect Color="{StaticResource CyanColor}" BlurRadius="24" ShadowDepth="0" Opacity="0.6"/>
                                    </Button.Effect>
                                </Button>

                                <!-- QR + text -->
                                <StackPanel Orientation="Horizontal" Margin="0,18,0,0">
                                    <Border x:Name="QrBorder" Width="156" Height="156" Background="White" Padding="8" Margin="0,0,16,0" VerticalAlignment="Center">
                                        <Image x:Name="QrImage" Stretch="Uniform" RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center" Width="180">
                                        <TextBlock Text="{Binding Texts[price.scanTitle]}" Style="{StaticResource MonoFont}" FontSize="13" Foreground="{StaticResource Text2Brush}" Margin="0,0,0,6"/>
                                        <TextBlock Text="{Binding Texts[price.scanText]}" edit:Editable.Multiline="True" Foreground="{StaticResource Text1Brush}" FontSize="14" TextWrapping="Wrap" LineHeight="20"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Stock indicator -->
                        <Grid Margin="0,22,0,0">
                            <TextBlock Style="{StaticResource MonoFont}" FontSize="12" Foreground="{StaticResource Text2Brush}" HorizontalAlignment="Left">
                                <Run Text="STOCK "/><Run Text="● 3 UNIDADES" Foreground="{StaticResource OkBrush}"/>
                            </TextBlock>
                            <TextBlock Style="{StaticResource MonoFont}" FontSize="12" Foreground="{StaticResource Text2Brush}" HorizontalAlignment="Right">
                                <Run Text="RESERVADO: "/><Run Text="1 HOY" Foreground="{StaticResource Text0Brush}"/>
                            </TextBlock>
                        </Grid>
                    </StackPanel>
                </Grid>

                <!-- ====== SCREEN 3: DETAIL ====== -->
                <Grid x:Name="Screen3_Detail" Visibility="Collapsed" Opacity="0" DataContext="{Binding SelectedSpec}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="560"/>
                    </Grid.ColumnDefinitions>

                    <!-- LEFT: contenido arriba (fila *) + navegación SIEMPRE anclada abajo (fila Auto) -->
                    <Grid Grid.Column="0" Margin="120,138,40,80">
                      <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                      </Grid.RowDefinitions>
                      <StackPanel Grid.Row="0">
                        <!-- header rail: accent bar + icon + "01 / 10 · Procesador" -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,26">
                          <Rectangle Width="46" Height="3" Fill="{Binding AccentBrush, FallbackValue={StaticResource CyanBrush}}" VerticalAlignment="Center" Margin="0,0,18,0">
                            <Rectangle.Effect>
                              <DropShadowEffect Color="{Binding AccentColor, FallbackValue={StaticResource CyanColor}}" BlurRadius="14" ShadowDepth="0" Opacity="0.9"/>
                            </Rectangle.Effect>
                          </Rectangle>
                          <Path Data="{Binding IconData, FallbackValue='M 0,0'}" Fill="{Binding AccentBrush, FallbackValue={StaticResource CyanBrush}}" Height="34" Width="34" Stretch="Uniform" VerticalAlignment="Center"/>
                          <TextBlock Text="{Binding IndexLabelFull}" edit:Editable.IsOn="False" Style="{StaticResource MonoFont}" FontSize="14" Foreground="{Binding AccentBrush, FallbackValue={StaticResource CyanBrush}}" VerticalAlignment="Center" Margin="14,0,0,0"/>
                        </StackPanel>

                        <!-- family eyebrow -->
                        <TextBlock Text="{Binding Family}" Style="{StaticResource MonoFont}" FontSize="18" Foreground="{StaticResource Text2Brush}" Margin="0,0,0,8"/>

                        <!-- hero value: auto-encoge si el nombre es muy largo (nunca se corta ni empuja la navegación) -->
                        <Viewbox StretchDirection="DownOnly" Stretch="Uniform" HorizontalAlignment="Left" MaxWidth="980" MaxHeight="240" Margin="0,0,0,12">
                          <TextBlock Text="{Binding Value}" Style="{StaticResource DisplayFont}" FontSize="116" LineHeight="110" Foreground="{Binding AccentBrush, FallbackValue={StaticResource CyanBrush}}" TextWrapping="Wrap" Width="980">
                            <TextBlock.Effect>
                              <DropShadowEffect Color="{Binding AccentColor, FallbackValue={StaticResource CyanColor}}" BlurRadius="42" ShadowDepth="0" Opacity="0.55"/>
                            </TextBlock.Effect>
                          </TextBlock>
                        </Viewbox>

                        <!-- técnico secundario (chip): pequeño, oculto si no aporta nada al cliente -->
                        <TextBlock Text="{Binding TechDetail}" edit:Editable.IsOn="False" Style="{StaticResource MonoFont}" FontSize="15" Foreground="{StaticResource Text2Brush}" TextWrapping="NoWrap" Margin="0,0,0,28" Visibility="{Binding HasTechDetail, Converter={StaticResource BoolToVis}}"/>

                        <!-- StatStrip: Detail parsed into framed cells -->
                        <Border BorderBrush="{StaticResource Line1Brush}" BorderThickness="1" Background="#05FFFFFF" HorizontalAlignment="Left">
                          <ItemsControl ItemsSource="{Binding DetailTokens}">
                            <ItemsControl.ItemsPanel>
                              <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                              <DataTemplate>
                                <Border BorderBrush="{StaticResource Line1Brush}" BorderThickness="1,0,0,0" Padding="22,14" MinWidth="118">
                                  <StackPanel>
                                    <Rectangle Width="22" Height="2" Margin="0,0,0,8" HorizontalAlignment="Left"
                                               Fill="{Binding DataContext.AccentBrush, RelativeSource={RelativeSource AncestorType=ItemsControl}, FallbackValue={StaticResource CyanBrush}}"/>
                                    <TextBlock Text="{Binding}" edit:Editable.IsOn="False" Style="{StaticResource DisplayFont}" FontSize="19" Foreground="{StaticResource Text0Brush}" TextWrapping="NoWrap"/>
                                  </StackPanel>
                                </Border>
                              </DataTemplate>
                            </ItemsControl.ItemTemplate>
                          </ItemsControl>
                        </Border>

                        <!-- Metrics module: radial gauge + tier + honest scale (benchmarked specs) -->
                        <Border Margin="0,28,0,0" Padding="28,26" Background="#120A0A1A" BorderBrush="{StaticResource Line1Brush}" BorderThickness="1"
                                HorizontalAlignment="Left" Visibility="{Binding HasBench, Converter={StaticResource BoolToVis}}">
                          <StackPanel Orientation="Horizontal">
                            <edit:RadialGauge Value="{Binding BenchScore}" AccentColor="{Binding AccentColor}" GaugeSize="196" VerticalAlignment="Center" Margin="0,0,38,0"/>
                            <StackPanel Width="640" VerticalAlignment="Center">
                              <TextBlock Text="// RENDIMIENTO MEDIDO" Style="{StaticResource MonoFont}" FontSize="12" Foreground="{Binding AccentBrush, FallbackValue={StaticResource CyanBrush}}" Margin="0,0,0,14"/>
                              <TextBlock Text="{Binding Tier}" edit:Editable.IsOn="False" Style="{StaticResource DisplayFont}" FontSize="34" Foreground="{StaticResource Text0Brush}" Margin="0,0,0,8"/>
                              <TextBlock Text="{Binding BenchPercentLabel}" edit:Editable.IsOn="False" Style="{StaticResource MonoFont}" FontSize="12" Foreground="{StaticResource Text2Brush}" Margin="0,0,0,20"/>
                              <!-- honest position scale (0–640px = 0–100) -->
                              <Grid Height="10" Width="640" Background="#10FFFFFF" HorizontalAlignment="Left">
                                <Rectangle HorizontalAlignment="Left" Width="{Binding BenchBarWidth}" Fill="{Binding AccentBrush, FallbackValue={StaticResource CyanBrush}}">
                                  <Rectangle.Effect>
                                    <DropShadowEffect Color="{Binding AccentColor, FallbackValue={StaticResource CyanColor}}" BlurRadius="16" ShadowDepth="0" Opacity="0.8"/>
                                  </Rectangle.Effect>
                                </Rectangle>
                                <Rectangle Width="2" Height="20" Fill="{StaticResource Text0Brush}" HorizontalAlignment="Left" VerticalAlignment="Center"
                                           Margin="{Binding BenchMarkerLeft, Converter={StaticResource LeftMarginConverter}}"/>
                              </Grid>
                              <Grid Width="640" HorizontalAlignment="Left" Margin="0,10,0,0">
                                <TextBlock Text="BÁSICO" Style="{StaticResource MonoFont}" FontSize="10" Foreground="{StaticResource Text3Brush}" HorizontalAlignment="Left"/>
                                <TextBlock Text="TOPE DE GAMA" Style="{StaticResource MonoFont}" FontSize="10" Foreground="{StaticResource Text3Brush}" HorizontalAlignment="Right"/>
                              </Grid>
                            </StackPanel>
                          </StackPanel>
                        </Border>

                        <!-- Non-benchmarked specs: verified component panel -->
                        <Border Margin="0,28,0,0" Padding="26,22" Background="#120A0A1A" BorderBrush="{StaticResource Line1Brush}" BorderThickness="1"
                                HorizontalAlignment="Left" Visibility="{Binding HasBench, Converter={StaticResource InverseBoolToVis}}">
                          <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Path Data="{Binding IconData, FallbackValue='M 0,0'}" Fill="{Binding AccentBrush, FallbackValue={StaticResource CyanBrush}}" Height="28" Width="28" Stretch="Uniform" VerticalAlignment="Center"/>
                            <TextBlock Text="Componente verificado · operativo" Style="{StaticResource MonoFont}" FontSize="14" Foreground="{StaticResource Text1Brush}" VerticalAlignment="Center" Margin="18,0,32,0"/>
                            <Ellipse Width="9" Height="9" Fill="{StaticResource OkBrush}" VerticalAlignment="Center">
                              <Ellipse.Effect>
                                <DropShadowEffect Color="{StaticResource OkColor}" BlurRadius="10" ShadowDepth="0" Opacity="0.9"/>
                              </Ellipse.Effect>
                            </Ellipse>
                          </StackPanel>
                        </Border>

                      </StackPanel>

                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,40,0,0">
                            <Button Click="DetailPrev_Click" Content="◀ Anterior" Style="{StaticResource SecondaryButton}" Margin="0,0,16,0" Cursor="Hand"/>
                            <Button Click="DetailNext_Click" Content="Siguiente ▶" Style="{StaticResource SecondaryButton}" Margin="0,0,16,0" Cursor="Hand"/>
                            <Button Click="DetailBack_Click" Content="Volver al equipo" Style="{StaticResource SecondaryButton}" Cursor="Hand"/>
                        </StackPanel>
                    </Grid>

                    <!-- RIGHT -->
                    <StackPanel Grid.Column="1" Margin="0,200,120,0">
                        <Border Background="#120A0A1A" BorderBrush="{StaticResource Line1Brush}" BorderThickness="1" Padding="36" CornerRadius="0">
                          <StackPanel>
                            <TextBlock Text="// QUÉ SIGNIFICA" Style="{StaticResource MonoFont}" FontSize="12" Foreground="{Binding AccentBrush, FallbackValue={StaticResource CyanBrush}}" Margin="0,0,0,18"/>
                            <TextBlock Text="{Binding Summary}" edit:Editable.Multiline="True" FontSize="22" LineHeight="33" Foreground="{StaticResource Text0Brush}" TextWrapping="Wrap"/>
                    
                            <TextBlock Text="// PARA QUÉ TE SIRVE" Style="{StaticResource MonoFont}" FontSize="12" Foreground="{Binding AccentBrush, FallbackValue={StaticResource CyanBrush}}" Margin="0,38,0,18"/>
                            
                            <ItemsControl ItemsSource="{Binding Pros}">
                              <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                  <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <Border Width="28" Height="28" BorderBrush="{Binding DataContext.AccentBrush, RelativeSource={RelativeSource AncestorType=ItemsControl}}" BorderThickness="1" Background="#1AFFFFFF" Margin="0,0,16,0">
                                      <TextBlock Text="{Binding Index}" edit:Editable.IsOn="False" Style="{StaticResource MonoFont}" FontSize="12" Foreground="{Binding DataContext.AccentBrush, RelativeSource={RelativeSource AncestorType=ItemsControl}}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="{Binding Text}" edit:Editable.Multiline="True" Foreground="{StaticResource Text1Brush}" FontSize="18" VerticalAlignment="Center" TextWrapping="Wrap" MaxWidth="380"/>
                                  </StackPanel>
                                </DataTemplate>
                              </ItemsControl.ItemTemplate>
                            </ItemsControl>
                          </StackPanel>
                        </Border>

                        <!-- Mini spec thumbnails -->
                        <ItemsControl ItemsSource="{Binding Specs, RelativeSource={RelativeSource AncestorType=Window}}" Margin="0,30,0,0">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="5" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Click="SpecNode_Click" Margin="4" Cursor="Hand">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="NavBorder" Padding="6,10" Background="#05FFFFFF" BorderBrush="{StaticResource Line1Brush}" BorderThickness="1">
                                                    <StackPanel HorizontalAlignment="Center">
                                                        <Path x:Name="NavIcon" Data="{Binding IconData, FallbackValue='M 0,0'}" Fill="{StaticResource Text2Brush}" Height="18" Width="18" Stretch="Uniform" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                                        <TextBlock x:Name="NavLbl" Text="{Binding LabelShort}" edit:Editable.IsOn="False" Style="{StaticResource MonoFont}" FontSize="9" Foreground="{StaticResource Text2Brush}" HorizontalAlignment="Center"/>
                                                    </StackPanel>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <DataTrigger Binding="{Binding IsCurrentDetail}" Value="True">
                                                        <Setter TargetName="NavBorder" Property="BorderBrush" Value="{Binding AccentBrush, FallbackValue={StaticResource CyanBrush}}"/>
                                                        <Setter TargetName="NavBorder" Property="Background" Value="#14FFFFFF"/>
                                                        <Setter TargetName="NavIcon" Property="Fill" Value="{Binding AccentBrush, FallbackValue={StaticResource CyanBrush}}"/>
                                                        <Setter TargetName="NavLbl" Property="Foreground" Value="{StaticResource Text0Brush}"/>
                                                    </DataTrigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="NavBorder" Property="BorderBrush" Value="{StaticResource Text1Brush}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <TextBlock Text="{Binding Family}" edit:Editable.IsOn="False" Style="{StaticResource DisplayFont}" FontSize="720" LineHeight="576"
                               Foreground="#08FFFFFF" HorizontalAlignment="Right" VerticalAlignment="Top"
                               Margin="0,80,-120,0" Panel.ZIndex="-1" IsHitTestVisible="False"/>

                    <!-- Animated scan line overlay (mockup .scan-line height=4) -->
                    <Rectangle Height="4" VerticalAlignment="Top" IsHitTestVisible="False" Fill="{Binding AccentBrush, FallbackValue={StaticResource CyanBrush}}" Opacity="0.4" Panel.ZIndex="10">
                        <Rectangle.Effect>
                            <DropShadowEffect Color="{Binding AccentColor, FallbackValue={StaticResource CyanColor}}" BlurRadius="8" ShadowDepth="0" Opacity="0.6"/>
                        </Rectangle.Effect>
                        <Rectangle.RenderTransform>
                            <TranslateTransform x:Name="DetailScanLineTransform" Y="0"/>
                        </Rectangle.RenderTransform>
                        <Rectangle.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever">
                                        <DoubleAnimation Storyboard.TargetName="DetailScanLineTransform" Storyboard.TargetProperty="Y" From="0" To="1080" Duration="0:0:5.5"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Rectangle.Triggers>
                    </Rectangle>
                </Grid>

            </Grid>

            <!-- ================= CHROME & BRACKETS (transparent overlay) ================= -->
            <Grid x:Name="ForegroundChrome" IsHitTestVisible="{Binding EditMode.IsActive}" Panel.ZIndex="40">
                <!-- Corner brackets: 44×44 L-shapes at 24px from each corner -->
                <Canvas IsHitTestVisible="False">
                    <Path Canvas.Left="24" Canvas.Top="24" Stroke="{StaticResource CyanBrush}" StrokeThickness="2" Data="M 0,44 L 0,0 L 44,0">
                        <Path.Effect><DropShadowEffect Color="{StaticResource CyanColor}" BlurRadius="6" ShadowDepth="0" Opacity="0.9"/></Path.Effect>
                    </Path>
                    <Path Canvas.Left="1852" Canvas.Top="24" Stroke="{StaticResource CyanBrush}" StrokeThickness="2" Data="M 44,44 L 44,0 L 0,0">
                        <Path.Effect><DropShadowEffect Color="{StaticResource CyanColor}" BlurRadius="6" ShadowDepth="0" Opacity="0.9"/></Path.Effect>
                    </Path>
                    <Path Canvas.Left="24" Canvas.Top="1012" Stroke="{StaticResource CyanBrush}" StrokeThickness="2" Data="M 0,0 L 0,44 L 44,44">
                        <Path.Effect><DropShadowEffect Color="{StaticResource CyanColor}" BlurRadius="6" ShadowDepth="0" Opacity="0.9"/></Path.Effect>
                    </Path>
                    <Path Canvas.Left="1852" Canvas.Top="1012" Stroke="{StaticResource CyanBrush}" StrokeThickness="2" Data="M 44,0 L 44,44 L 0,44">
                        <Path.Effect><DropShadowEffect Color="{StaticResource CyanColor}" BlurRadius="6" ShadowDepth="0" Opacity="0.9"/></Path.Effect>
                    </Path>
                </Canvas>

                <!-- TOP CHROME ROW: top 36, padding-x 64, transparent (no gradient bar) -->
                <Grid VerticalAlignment="Top" Margin="64,36,64,0" Height="40">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left">
                        <Image Source="Assets/clinicapc-logo.png" Height="40" Margin="0,0,14,0">
                            <Image.Effect>
                                <DropShadowEffect Color="{StaticResource CyanColor}" BlurRadius="14" ShadowDepth="0" Opacity="0.6"/>
                            </Image.Effect>
                        </Image>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
                        <TextBlock Style="{StaticResource MonoFont}" Foreground="{StaticResource Text2Brush}" FontSize="14" VerticalAlignment="Center" Margin="0,0,32,0">
                            <Run Text="SKU "/><Run Text="{Binding DisplayConfig.Sku}" Foreground="{StaticResource Text0Brush}" FontWeight="Bold"/>
                        </TextBlock>
                        <TextBlock Text="{Binding CurrentScreenName}" edit:Editable.IsOn="False" Style="{StaticResource MonoFont}" Foreground="{StaticResource Text2Brush}" FontSize="14" VerticalAlignment="Center" Margin="0,0,32,0"/>
                        <TextBlock Text="{Binding CurrentTimeString}" edit:Editable.IsOn="False" Style="{StaticResource MonoFont}" Foreground="{StaticResource Text2Brush}" FontSize="14" VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>

                <!-- BOTTOM CHROME ROW: bottom 36, padding-x 64, transparent -->
                <Grid VerticalAlignment="Bottom" Margin="64,0,64,36" Height="24">
                    <TextBlock Style="{StaticResource MonoFont}" Foreground="{StaticResource Text2Brush}"
                               FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Left">
                        <Run Text="CLINICAPC · "/><Run Text="{Binding DisplayConfig.ShopAddress}" Foreground="{StaticResource Text0Brush}"/>
                    </TextBlock>
                    <TextBlock Style="{StaticResource MonoFont}" Foreground="{StaticResource Text2Brush}"
                               FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Right"
                               Text="{Binding DisplayConfig.ShopServices}"/>
                </Grid>
            </Grid>

        </Grid>
    </Viewbox>

        <!-- ===== OVERLAY (fuera del Viewbox: fijo, sobre todo) ===== -->
        <Border x:Name="SettingsHotspot" Width="120" Height="120"
                HorizontalAlignment="Right" VerticalAlignment="Top"
                Background="Transparent" Panel.ZIndex="100"
                MouseLeftButtonDown="SettingsHotspot_MouseDown"/>

        <Border x:Name="EditToolbar" VerticalAlignment="Top" HorizontalAlignment="Center"
                Margin="0,18,0,0" Panel.ZIndex="100"
                Background="#F20A0716" BorderBrush="#FFF37A4A" BorderThickness="1" CornerRadius="12"
                Padding="18,10"
                Visibility="{Binding EditMode.IsActive, Converter={StaticResource BoolToVis}}">
            <Border.Effect>
                <DropShadowEffect Color="#FFF37A4A" BlurRadius="24" ShadowDepth="0" Opacity="0.4"/>
            </Border.Effect>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Ellipse Width="10" Height="10" Fill="#FFF37A4A" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock Text="MODO EDICIÓN" FontFamily="{StaticResource JetBrainsMono}" FontWeight="Bold" Foreground="White" FontSize="14" VerticalAlignment="Center"/>
                <TextBlock Text="· toca cualquier texto para editarlo" FontFamily="{StaticResource JetBrainsMono}" Foreground="{StaticResource Text2Brush}" FontSize="12" VerticalAlignment="Center" Margin="8,0,0,0"/>
                <Rectangle Width="1" Height="22" Fill="{StaticResource Line2Brush}" Margin="18,0,18,0"/>
                <TextBlock Text="pantalla" FontFamily="{StaticResource JetBrainsMono}" Foreground="{StaticResource Text2Brush}" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <Button Content="Espera" Click="EditGoAttract_Click" Style="{StaticResource SecondaryButton}" Padding="10,6" Margin="0,0,6,0"/>
                <Button Content="Escaneo" Click="EditGoScan_Click" Style="{StaticResource SecondaryButton}" Padding="10,6" Margin="0,0,6,0"/>
                <Button Content="Resumen" Click="EditGoMain_Click" Style="{StaticResource SecondaryButton}" Padding="10,6" Margin="0,0,6,0"/>
                <Button Content="Detalle" Click="EditGoDetail_Click" Style="{StaticResource SecondaryButton}" Padding="10,6"/>
                <StackPanel Orientation="Horizontal" Margin="18,0,0,0" Visibility="{Binding IsAttractScreen, Converter={StaticResource BoolToVis}}">
                    <Button Content="◀" Click="EditPrevSlide_Click" Style="{StaticResource SecondaryButton}" Padding="10,6" Margin="0,0,6,0"/>
                    <TextBlock Text="slide" FontFamily="{StaticResource JetBrainsMono}" Foreground="{StaticResource Text2Brush}" FontSize="12" VerticalAlignment="Center"/>
                    <Button Content="▶" Click="EditNextSlide_Click" Style="{StaticResource SecondaryButton}" Padding="10,6" Margin="6,0,0,0"/>
                </StackPanel>
                <Rectangle Width="1" Height="22" Fill="{StaticResource Line2Brush}" Margin="18,0,18,0"/>
                <Button Content="Guardar" Click="EditSave_Click" Style="{StaticResource PrimaryButton}" Padding="18,8" Margin="0,0,8,0"/>
                <Button Content="Descartar" Click="EditDiscard_Click" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0"/>
                <Button Content="Salir" Click="EditExit_Click" Style="{StaticResource SecondaryButton}"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>